---
import BaseLayout from '../../components/seo/BaseLayout.astro';
import HeroSection from '../../components/molecules/HeroSection.astro';
import Breadcrumb from '../../components/molecules/Breadcrumb.astro';
import Button from '../../components/atoms/Button.astro';
import { contactPageSchema } from '../../lib/schema/ContactPage';
import { breadcrumbSchema } from '../../lib/schema/BreadcrumbList';

const breadcrumbs = [
  { label: 'Home', href: '/' },
  { label: 'Contact', href: '/contact/' },
];
const schemaPayload = [contactPageSchema(), breadcrumbSchema(breadcrumbs)];
---

<BaseLayout
  title="Contact Pro Exteriors | Roofing Inspections & Quotes"
  description="Talk to a Pro Exteriors specialist. Commercial RFQ, residential inspection, or emergency response — get the right person, fast."
  canonicalPath="/contact/"
  jsonLd={schemaPayload}
>
  <Breadcrumb items={breadcrumbs.slice(1)} />
  <HeroSection
    title="Talk to a Specialist"
    subtitle="Tell us what you need; we'll route you to the right team."
    primaryCta={{ label: 'Call (469) 535-1708', href: 'tel:4695351708' }}
  />
  <section class="py-16 px-4 max-w-5xl mx-auto grid grid-cols-1 md:grid-cols-2 gap-8">
    <div class="bg-surface-elevated p-8 rounded-2xl ring-1 ring-border">
      <h2 class="text-2xl font-bold mb-3">Commercial Inquiry</h2>
      <p class="text-text-secondary mb-6">Property managers, REITs, multi-family operators — start here.</p>
      <Button href="/commercial-roofing/" variant="primary">Commercial Services</Button>
    </div>
    <div class="bg-surface-elevated p-8 rounded-2xl ring-1 ring-border">
      <h2 class="text-2xl font-bold mb-3">Residential Request</h2>
      <p class="text-text-secondary mb-6">Homeowners — request a free inspection or storm-damage assessment.</p>
      <Button href="/residential/" variant="primary">Residential Services</Button>
    </div>
  </section>
  <section class="py-12 text-center">
    <p class="text-text-secondary">Phase 1 placeholder — Step 11 wires the branched lead form.</p>
  </section>
</BaseLayout>
