---
/* ═══════════════════════════════════════════════════════════════════════════
   /residential/roof-replacement — T2 money page (highest-CPC in residential silo)
   Template: residential-service. AIA4 PageBuilder · 2026-05-03

   ━ Conversion hypothesis ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
     (a) Top-5 organic for "roof replacement" in TX/CO/KS/MO/GA within 6 months
     (b) ≥30% form-completion on 'Schedule Replacement Assessment' CTA within 90 days

   ━ SHIP-BLOCKING [REPRESENTATIVE] markers ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
   All image slots · all case studies · testimonial · cost ranges · financing lender
═══════════════════════════════════════════════════════════════════════════ */

import BaseLayout from '../../../components/seo/BaseLayout.astro';
import Breadcrumb from '../../../components/molecules/Breadcrumb.astro';
import FAQ from '../../../components/molecules/FAQ.astro';
import Icon from '../../../components/atoms/Icon.astro';

const title       = "Roof Replacement — Full Home Re-Roofing by Pro Exteriors | 5 States";
const description = "Pro Exteriors replaces residential roofs across TX, CO, KS, MO & GA. Asphalt, metal, tile & slate options. Transparent pricing. Free inspection and detailed estimate.";
const canonicalPath = "/residential/roof-replacement";

const jsonLd = [
  {
    "@context": "https://schema.org",
    "@type": "RoofingContractor",
    "@id": "https://proexteriorsus.com/#roofing-contractor",
    "name": "Pro Exteriors",
    "url": "https://proexteriorsus.com",
    "areaServed": ["Texas","Colorado","Kansas","Missouri","Georgia"].map(n => ({ "@type": "State", "name": n }))
  },
  {
    "@context": "https://schema.org",
    "@type": "Service",
    "serviceType": "Residential Roof Replacement",
    "provider": { "@id": "https://proexteriorsus.com/#roofing-contractor" },
    "areaServed": ["Texas","Colorado","Kansas","Missouri","Georgia"].map(n => ({ "@type": "State", "name": n }))
  }
];

const materials = [
  {
    id: "asphalt", eyebrow: "MOST POPULAR", h3: "Asphalt Shingles",
    body: "GAF and Owens Corning architectural shingles — 25–50 year lifespan, competitive cost, Class 4 impact-resistant options available. GAF Master Elite certified installation means we can issue the Golden Pledge warranty on qualifying jobs.",
    specs: ["Lifespan: 25–50 years","Cost tier: $$","Best for: Standard replacements, any state"],
    link: { label: "Explore Asphalt Shingle Roofing →", href: "/residential/asphalt-shingles" },
    img: "/images/placeholders/material-asphalt.jpg", alt: "Architectural asphalt shingles on a residential roof",
  },
  {
    id: "metal", eyebrow: "", h3: "Metal Roofing",
    body: "Standing seam, stone-coated steel, and corrugated metal. 50-year service life, Class 4 hail rating, energy-efficient reflective surface. Higher upfront cost than asphalt; lower annualized cost over the life of the material.",
    specs: ["Lifespan: 40–50+ years","Cost tier: $$$","Best for: Long-tenure homes, hail belt, mountain climates"],
    link: { label: "Explore Metal Roofing →", href: "/residential/metal-roofing" },
    img: "/images/placeholders/material-metal.jpg", alt: "Standing seam metal roof on a residential home",
  },
  {
    id: "tile", eyebrow: "", h3: "Tile & Clay Roofing",
    body: "Clay tile, concrete tile, and Spanish S-tile. 50–100 year lifespan, fire resistant, thermally massive. Heavier than asphalt — structural deck verification required. Common on custom homes in Texas and Georgia markets.",
    specs: ["Lifespan: 50–100 years","Cost tier: $$$","Best for: Custom homes, Southwestern aesthetics"],
    link: { label: "Explore Tile & Clay Roofing →", href: "/residential/tile-clay-roofing" },
    img: "/images/placeholders/material-tile.jpg", alt: "Clay tile residential roof",
  },
  {
    id: "slate", eyebrow: "", h3: "Natural Slate",
    body: "The permanent ceiling of residential roofing. Quarried slate with a 100–150 year service life depending on the quarry of origin. Heaviest material we install; structural feasibility assessment required. Specialist crews only.",
    specs: ["Lifespan: 100–150 years","Cost tier: $$$$","Best for: Premium homes, generational investment"],
    link: { label: "Explore Natural Slate →", href: "/residential/natural-slate" },
    img: "/images/placeholders/material-slate.jpg", alt: "Natural slate residential roof",
  },
];

const processSteps = [
  { num: 1, icon: "search",       title: "Free Inspection & Assessment",     body: "A Pro Exteriors crew member inspects every element — age, granule condition, decking integrity, flashing, ventilation, and drainage — and gives you a written summary with photos before we discuss pricing." },
  { num: 2, icon: "clipboard",    title: "Detailed Line-Item Estimate",       body: "We scope the full replacement — material, tearoff layers, decking allowance, permit, and disposal — and give you a line-item estimate. No surprise change orders. If we find decking damage mid-project, we bring photos and a price before proceeding." },
  { num: 3, icon: "wrench",       title: "Scheduled Installation",           body: "We put the project on the calendar, show up when we say we will, and complete the replacement in a staged single job. Our crews handle tearoff, deck repair, underlayment, drip edge, and full material installation." },
  { num: 4, icon: "check-circle", title: "Final Walkthrough & Warranty Registration", body: "We walk the finished roof with you, confirm site cleanup, and register your manufacturer warranty before we leave. Manufacturer documentation is delivered to you at job completion." },
];

const faqItems = [
  {
    question: "How long does a roof replacement take?",
    answer: `A standard residential replacement runs one to two days for installation. Permit issuance adds one to five business days depending on the municipality. Total project timeline from signed contract to final inspection is typically seven to fourteen days, weather permitting. We communicate any delay the same day it surfaces. See our guide on the <a href="/blog/best-time-of-year-to-replace-your-roof">best time of year to schedule a roof replacement</a> for a deeper look at timing tradeoffs.`,
  },
  {
    question: "How do I know if I need a replacement instead of a repair?",
    answer: `Repairs make sense when damage is isolated — a few missing shingles, a failed flashing detail, a single leak point on a relatively young roof. Replacement makes sense when the roof is more than 20 years old with widespread granule loss, when you have had multiple leaks across the field, when hail or wind has damaged more than 30–40% of the surface, or when the decking shows structural compromise. Our free inspection gives you a written assessment with photos. See the full diagnostic in our <a href="/blog/5-signs-replacement">five signs your roof needs replacing</a> breakdown.`,
  },
  {
    question: "What does a new roof replacement cost?",
    answer: `Cost depends on square footage, material choice, tearoff layers, decking condition, and roof complexity. <span class="text-slate-500 italic text-sm">[REPRESENTATIVE — insert Pro Exteriors confirmed price ranges per material tier before this ships.]</span> The most accurate number comes from a free inspection and a line-item estimate — which is how every Pro Exteriors project starts. See our guide on <a href="/blog/how-much-does-a-roof-replacement-cost">how much a roof replacement actually costs</a> for a framework to interpret any estimate you receive.`,
  },
  {
    question: "Does Pro Exteriors handle the insurance claim for storm-related replacements?",
    answer: `Yes. Storm-driven replacements are the single most common reason homeowners call us. We document damage at the free inspection, provide a photo report for your insurance carrier, attend the adjuster meeting if requested, and handle supplement filings if the initial payout underestimates the scope. See our <a href="/residential/insurance-claim-assistance">insurance claim assistance</a> page for a full breakdown of how we handle storm-damage claims.`,
  },
];
---

<BaseLayout title={title} description={description} canonicalPath={canonicalPath} jsonLd={jsonLd}>
  <a href="#main" class="sr-only focus:not-sr-only focus:absolute focus:top-2 focus:left-2 focus:z-50 focus:bg-white focus:px-4 focus:py-2 focus:rounded">Skip to main content</a>

  <main id="main">

    {/* ══════ HERO ══════════════════════════════════════════════════════════ */}
    <section
      class="relative isolate overflow-hidden text-white"
      style="min-height: 760px; background-color: var(--color-surface-dark, #0f172a);"
      aria-label="Residential roof replacement — Pro Exteriors"
    >
      <div class="absolute inset-0 -z-10">
        <img src="/images/placeholders/hero-roof-replacement.jpg" alt="" class="w-full h-full object-cover opacity-60" loading="eager" fetchpriority="high" width="1920" height="1080" />
        <div class="absolute inset-0 bg-gradient-to-r from-slate-900 via-slate-900/70 to-slate-900/20"></div>
      </div>
      <div class="mx-auto max-w-screen-xl px-6 lg:px-8 py-20 lg:py-28">
        <Breadcrumb items={[{ label: "Residential Roofing", href: "/residential" }, { label: "Roof Replacement", href: "/residential/roof-replacement" }]} />
        <p class="mt-4 text-sm font-bold uppercase tracking-widest text-white/70">TX · CO · KS · MO · GA</p>
        <h1 class="mt-6 text-5xl lg:text-6xl font-black leading-[1.05] max-w-3xl">Residential Roof Replacement by Pro Exteriors</h1>
        <p class="mt-6 max-w-2xl text-xl lg:text-2xl text-slate-300 leading-relaxed">
          Full re-roofing in asphalt, metal, tile, and slate. Transparent estimates. Manufacturer warranties registered on install day. Serving five states with our own crews.
        </p>
        <div class="mt-10 flex flex-col sm:flex-row gap-4">
          <a href="/contact?intent=roof-replacement&source=roof-replacement-hero" class="inline-flex items-center justify-center px-8 py-4 rounded-lg bg-red-700 hover:bg-red-800 text-white text-lg font-bold transition-colors" data-event-action="cta-click" data-event-label="hero-primary" data-event-category="roof-replacement">Schedule Your Replacement Assessment</a>
          <a href="#process" class="inline-flex items-center justify-center px-8 py-4 rounded-lg border-2 border-white text-white text-lg font-bold hover:bg-white hover:text-slate-900 transition-colors" data-event-action="cta-click" data-event-label="hero-secondary" data-event-category="roof-replacement">See Our Process</a>
        </div>
      </div>
    </section>

    {/* ══════ TRUST STRIP ════════════════════════════════════════════════════ */}
    <section aria-label="Credentials" class="py-8 border-y border-stone-200 bg-stone-50">
      <ul class="mx-auto max-w-screen-xl px-6 lg:px-8 flex flex-wrap items-center justify-center gap-8 lg:gap-16 text-sm font-bold text-slate-900">
        <li class="inline-flex items-center gap-2"><Icon name="clock" class="w-5 h-5 text-red-700" /><span>15+ Years in Business</span></li>
        <li class="inline-flex items-center gap-2"><Icon name="home" class="w-5 h-5 text-red-700" /><span>2,500+ Roofs Replaced <span class="text-slate-500 font-normal text-xs italic" title="Not yet sourced">[REPRESENTATIVE]</span></span></li>
        <li class="inline-flex items-center gap-2"><Icon name="map-pin" class="w-5 h-5 text-red-700" /><span>5-State Coverage</span></li>
        <li class="inline-flex items-center gap-2"><Icon name="star" class="w-5 h-5 text-red-700" /><span><span class="text-slate-500 text-xs font-normal italic mr-1" title="Not yet sourced">[REPRESENTATIVE]</span>Google Rating</span></li>
        <li class="inline-flex items-center gap-2"><Icon name="dollar-sign" class="w-5 h-5 text-red-700" /><span>Financing Available</span></li>
      </ul>
    </section>

    {/* ══════ SERVICE OVERVIEW — REPAIR VS REPLACE ═══════════════════════ */}
    <section aria-label="When to replace vs repair your roof" class="py-20 lg:py-28 bg-white">
      <div class="mx-auto max-w-screen-xl px-6 lg:px-8 grid lg:grid-cols-2 gap-12 lg:gap-20 items-center">
        <div>
          <p class="text-sm font-bold uppercase tracking-widest text-red-700">REPAIR OR REPLACE?</p>
          <h2 class="mt-4 text-4xl lg:text-5xl font-black leading-tight text-slate-900">Five Signals That a Repair Won't Cut It</h2>
          <div class="mt-6 text-lg text-slate-700 leading-relaxed space-y-4">
            <p>
              Most contractors will tell you a roof needs replacing the moment they're
              asked to look at it. That is not the business model at Pro Exteriors. Our
              free inspection starts with an honest assessment of whether replacement is
              actually the right answer, and we put the reasoning in writing.
            </p>
            <p>That said, five signals consistently indicate a replacement is the better economic decision:</p>
          </div>
          <ol class="mt-4 space-y-3">
            {[
              "The roof is more than 20–25 years old with widespread granule loss from the shingles.",
              "Three or more leaks in the past five years that didn't trace to isolated flashing failures.",
              "Decking shows soft spots or sag lines — structural compromise individual repairs can't address.",
              "Hail or wind has damaged more than 30–40% of the shingle field.",
              "Rising energy bills consistent with a failing insulation layer in the roofing assembly.",
            ].map((signal, i) => (
              <li class="flex items-start gap-4">
                <span class="flex-shrink-0 w-8 h-8 rounded-full bg-red-700 text-white text-sm font-black flex items-center justify-center">{i+1}</span>
                <span class="text-base text-slate-700 leading-relaxed pt-1">{signal}</span>
              </li>
            ))}
          </ol>
          <p class="mt-6 text-base text-slate-600">
            See our breakdown of the <a href="/blog/5-signs-replacement" class="underline decoration-slate-300 hover:decoration-slate-900 transition-colors">five signs your roof needs replacing</a>, then
            request a free inspection from a Pro Exteriors <a href="/residential" class="underline decoration-slate-300 hover:decoration-slate-900 transition-colors">residential roofing contractor</a> in your state.
          </p>
        </div>
        <div class="relative rounded-2xl overflow-hidden aspect-[4/3]">
          <img src="/images/placeholders/service-overview-replacement.jpg" alt="Pro Exteriors inspector reviewing a residential roof condition, tablet in hand" class="w-full h-full object-cover" loading="lazy" width="800" height="600" />
        </div>
      </div>
    </section>

    {/* ══════ MATERIALS GRID (4 cards — 2×2 at desktop) ═══════════════════ */}
    <section id="materials" aria-label="Roofing material options" class="py-20 lg:py-28 bg-stone-50">
      <div class="mx-auto max-w-screen-xl px-6 lg:px-8">
        <div class="text-center max-w-3xl mx-auto mb-14">
          <p class="text-sm font-bold uppercase tracking-widest text-red-700">CHOOSE YOUR ROOFING MATERIAL</p>
          <h2 class="mt-4 text-4xl lg:text-5xl font-black text-slate-900">One Replacement. Four Material Options.</h2>
          <p class="mt-4 text-xl text-slate-600">Roof replacement is an opportunity to choose the material that fits your home, your climate, and your time horizon.</p>
        </div>
        <div class="grid md:grid-cols-2 gap-8">
          {materials.map(mat => (
            <article class="bg-white rounded-2xl overflow-hidden shadow-sm hover:shadow-md transition-shadow border border-stone-100 flex flex-col md:flex-row">
              <div class="md:w-48 flex-shrink-0 relative">
                <img src={mat.img} alt={mat.alt} class="w-full h-48 md:h-full object-cover" loading="lazy" width="192" height="192" />
                {mat.eyebrow && (
                  <span class="absolute top-3 left-3 px-2 py-1 rounded text-xs font-bold bg-red-700 text-white uppercase tracking-wide">{mat.eyebrow}</span>
                )}
              </div>
              <div class="p-6 flex flex-col justify-between">
                <div>
                  <h3 class="text-xl font-black text-slate-900">{mat.h3}</h3>
                  <p class="mt-2 text-sm text-slate-700 leading-relaxed">{mat.body}</p>
                  <ul class="mt-3 space-y-1">
                    {mat.specs.map(spec => (
                      <li class="flex items-start gap-2 text-sm text-slate-600">
                        <Icon name="check-circle" class="w-4 h-4 text-red-700 mt-0.5 flex-shrink-0" />
                        <span>{spec}</span>
                      </li>
                    ))}
                  </ul>
                </div>
                <a href={mat.link.href} class="mt-4 text-sm font-bold text-red-700 hover:text-red-800 transition-colors">{mat.link.label}</a>
              </div>
            </article>
          ))}
        </div>
      </div>
    </section>

    {/* ══════ LOCAL EXPERTS PROOF ════════════════════════════════════════════ */}
    <section aria-label="Experience and testimonial" class="py-20 lg:py-28 bg-white">
      <div class="mx-auto max-w-screen-xl px-6 lg:px-8 grid lg:grid-cols-2 gap-12 lg:gap-20 items-start">
        <div>
          <p class="text-sm font-bold uppercase tracking-widest text-red-700">THE NUMBERS</p>
          <h2 class="mt-4 text-4xl lg:text-5xl font-black leading-tight text-slate-900">2,500+ Roofs Replaced. Zero Subcontractors.</h2>
          <p class="mt-6 text-lg text-slate-700 leading-relaxed">
            Pro Exteriors has been replacing residential roofs across Texas, Colorado,
            Kansas, Missouri, and Georgia since 2011. Every project runs through our
            own crews — not labor brokers, not storm-chaser subcontractors. The same
            project manager who scopes the job oversees the installation and signs off
            on the final walkthrough.
          </p>
          <div class="mt-10 grid grid-cols-3 gap-6">
            {[
              { value: "15+",    label: "Years in Business" },
              { value: "2,500+", label: "Roofs Replaced", rep: true },
              { value: "5",      label: "States Served" },
            ].map(stat => (
              <div class="text-center">
                <div class="text-5xl font-black text-red-700">{stat.value}{stat.rep && <span class="ml-0.5 text-xs text-slate-400 font-normal italic" title="Not yet sourced">*</span>}</div>
                <div class="mt-2 text-sm font-bold text-slate-600 uppercase tracking-wide">{stat.label}</div>
              </div>
            ))}
          </div>
          <p class="mt-4 text-xs text-slate-400 italic">* [REPRESENTATIVE — verify against CRM before ship]</p>
        </div>
        <blockquote class="bg-stone-50 rounded-2xl p-8 border border-stone-100">
          <div class="flex gap-1 mb-6">{[1,2,3,4,5].map(() => <Icon name="star" class="w-5 h-5 text-amber-400" />)}</div>
          <p class="text-lg text-slate-800 leading-relaxed italic">
            "[REPRESENTATIVE — NOT YET SOURCED: Real customer testimonial, roof replacement, any served state. Signed release required before ship.]"
          </p>
          <footer class="mt-6 flex items-center gap-4">
            <div class="w-16 h-16 rounded-full overflow-hidden bg-stone-200 flex-shrink-0">
              <img src="/images/placeholders/testimonial-replacement.jpg" alt="Completed residential roof replacement by Pro Exteriors" class="w-full h-full object-cover" loading="lazy" width="64" height="64" />
            </div>
            <div>
              <p class="font-bold text-slate-900">[REPRESENTATIVE — Customer Name]</p>
              <p class="text-sm text-slate-500">[City, State, Year]</p>
            </div>
          </footer>
        </blockquote>
      </div>
    </section>

    {/* ══════ PROCESS ════════════════════════════════════════════════════════ */}
    <section id="process" aria-label="Roof replacement process" class="py-20 lg:py-28 bg-stone-50">
      <div class="mx-auto max-w-screen-xl px-6 lg:px-8">
        <div class="text-center mb-14">
          <p class="text-sm font-bold uppercase tracking-widest text-red-700">OUR PROCESS</p>
          <h2 class="mt-4 text-4xl lg:text-5xl font-black text-slate-900">Free Inspection to Registered Warranty — Four Steps.</h2>
          <p class="mt-4 text-xl text-slate-600">No ambush pricing. No subcontracted crews. This is how every roof replacement runs at Pro Exteriors.</p>
        </div>
        <div class="grid md:grid-cols-2 lg:grid-cols-4 gap-8">
          {processSteps.map(step => (
            <div class="bg-white rounded-2xl p-6 shadow-sm border border-stone-100">
              <div class="w-12 h-12 rounded-xl bg-red-700 flex items-center justify-center mb-4">
                <Icon name={step.icon} class="w-6 h-6 text-white" />
              </div>
              <div class="text-xs font-black text-slate-400 uppercase tracking-widest mb-2">Step {step.num}</div>
              <h3 class="text-lg font-black text-slate-900 mb-3">{step.title}</h3>
              <p class="text-sm text-slate-700 leading-relaxed">{step.body}</p>
            </div>
          ))}
        </div>
        <div class="mt-12 text-center">
          <a href="/contact?intent=roof-replacement&source=roof-replacement-process" class="inline-flex items-center justify-center px-8 py-4 rounded-lg bg-red-700 hover:bg-red-800 text-white text-lg font-bold transition-colors" data-event-action="cta-click" data-event-label="process-cta" data-event-category="roof-replacement">Schedule Your Replacement Assessment</a>
        </div>
      </div>
    </section>

    {/* ══════ CASE STUDIES ════════════════════════════════════════════════════ */}
    <section aria-label="Recent roof replacement projects" class="py-20 lg:py-28 bg-white">
      <div class="mx-auto max-w-screen-xl px-6 lg:px-8">
        <div class="text-center mb-14">
          <p class="text-sm font-bold uppercase tracking-widest text-red-700">RECENT REPLACEMENTS</p>
          <h2 class="mt-4 text-4xl lg:text-5xl font-black text-slate-900">Roof Replacements Across Five States</h2>
        </div>
        <div class="grid md:grid-cols-2 lg:grid-cols-3 gap-8">
          {[
            { state: "Texas",    tag: "Asphalt Replacement", title: "[REPRESENTATIVE — TX Project]", desc: "[REPRESENTATIVE — NOT YET SOURCED]", img: "/images/placeholders/case-replacement-tx.jpg", alt: "Completed roof replacement in Texas by Pro Exteriors" },
            { state: "Colorado", tag: "Metal Upgrade",       title: "[REPRESENTATIVE — CO Project]", desc: "[REPRESENTATIVE — NOT YET SOURCED]", img: "/images/placeholders/case-replacement-co.jpg", alt: "Completed roof replacement in Colorado by Pro Exteriors" },
            { state: "Georgia",  tag: "Full Replacement",    title: "[REPRESENTATIVE — GA/KS/MO Project]", desc: "[REPRESENTATIVE — NOT YET SOURCED]", img: "/images/placeholders/case-replacement-ga.jpg", alt: "Completed roof replacement by Pro Exteriors" },
          ].map(cs => (
            <article class="rounded-2xl overflow-hidden border border-stone-100 shadow-sm hover:shadow-md transition-shadow">
              <div class="aspect-[3/2] overflow-hidden">
                <img src={cs.img} alt={cs.alt} class="w-full h-full object-cover" loading="lazy" width="600" height="400" />
              </div>
              <div class="p-6">
                <div class="flex items-center gap-3 mb-3">
                  <span class="px-3 py-1 rounded text-xs font-bold bg-slate-900 text-white uppercase tracking-wide">{cs.state}</span>
                  <span class="px-3 py-1 rounded text-xs font-bold bg-stone-100 text-slate-700 uppercase tracking-wide">{cs.tag}</span>
                </div>
                <h3 class="text-lg font-black text-slate-900 mb-2">{cs.title}</h3>
                <p class="text-sm text-slate-600">{cs.desc}</p>
              </div>
            </article>
          ))}
        </div>
        <div class="mt-10 text-center">
          <a href="/projects" class="text-base font-bold text-slate-900 underline decoration-slate-300 hover:decoration-slate-900 transition-colors">See All Projects</a>
        </div>
      </div>
    </section>

    {/* ══════ COST & FINANCING ════════════════════════════════════════════════ */}
    <section aria-label="Roof replacement cost and financing" class="py-20 lg:py-28 bg-stone-50">
      <div class="mx-auto max-w-screen-xl px-6 lg:px-8 grid lg:grid-cols-2 gap-12 lg:gap-20 items-center">
        <div class="relative rounded-2xl overflow-hidden aspect-[4/3]">
          <img src="/images/placeholders/cost-estimate-replacement.jpg" alt="Pro Exteriors project manager reviewing line-item estimate with a homeowner" class="w-full h-full object-cover" loading="lazy" width="800" height="600" />
        </div>
        <div>
          <p class="text-sm font-bold uppercase tracking-widest text-red-700">COST & FINANCING</p>
          <h2 class="mt-4 text-4xl lg:text-5xl font-black leading-tight text-slate-900">What Drives the Price of a Roof Replacement</h2>
          <p class="mt-6 text-lg text-slate-700 leading-relaxed">
            Five variables determine what your roof replacement actually costs: square footage,
            material selection, number of tearoff layers, decking condition, and roof complexity
            (pitch, valleys, penetrations). Pro Exteriors gives you a line-item estimate —
            not a handshake number — before a single shingle comes off.
          </p>
          <ul class="mt-6 space-y-3">
            {[
              "Asphalt shingles: [REPRESENTATIVE — insert Pro Exteriors range]/sq ft installed",
              "Metal roofing: [REPRESENTATIVE — insert Pro Exteriors range]/sq ft installed",
              "Tile & clay: [REPRESENTATIVE — insert Pro Exteriors range]/sq ft installed",
              "Natural slate: [REPRESENTATIVE — insert Pro Exteriors range]/sq ft installed",
              "Financing available for qualified homeowners [REPRESENTATIVE — confirm lender]",
            ].map(item => (
              <li class="flex items-start gap-3">
                <Icon name="check-circle" class="w-5 h-5 text-red-700 mt-0.5 flex-shrink-0" />
                <span class="text-slate-700">{item}</span>
              </li>
            ))}
          </ul>
          <div class="mt-8">
            <a href="/contact?intent=roof-replacement&source=roof-replacement-cost" class="inline-flex items-center justify-center px-8 py-4 rounded-lg border-2 border-slate-900 text-slate-900 text-base font-bold hover:bg-slate-900 hover:text-white transition-colors" data-event-action="cta-click" data-event-label="cost-cta" data-event-category="roof-replacement">Get a Line-Item Estimate</a>
          </div>
        </div>
      </div>
    </section>

    {/* ══════ FAQ ════════════════════════════════════════════════════════════ */}
    <section aria-label="Roof replacement FAQ" class="py-20 lg:py-28 bg-white">
      <div class="mx-auto max-w-screen-xl px-6 lg:px-8 max-w-3xl mx-auto">
        <div class="text-center mb-14">
          <p class="text-sm font-bold uppercase tracking-widest text-red-700">FREQUENTLY ASKED</p>
          <h2 class="mt-4 text-4xl lg:text-5xl font-black text-slate-900">Roof Replacement Questions, Answered.</h2>
        </div>
        <FAQ items={faqItems} schemaType="FAQPage" />
      </div>
    </section>

    {/* ══════ FINAL CTA ══════════════════════════════════════════════════════ */}
    <section aria-label="Schedule your roof replacement assessment" class="relative isolate overflow-hidden py-24 lg:py-32 text-white" style="background-color: var(--color-surface-dark, #0f172a);">
      <div class="absolute inset-0 -z-10">
        <img src="/images/placeholders/final-cta-replacement.jpg" alt="" class="w-full h-full object-cover opacity-10" loading="lazy" width="1920" height="600" />
      </div>
      <div class="mx-auto max-w-screen-xl px-6 lg:px-8 text-center">
        <p class="text-sm font-bold uppercase tracking-widest text-red-400">START HERE</p>
        <h2 class="mt-4 text-4xl lg:text-6xl font-black max-w-4xl mx-auto">A Replacement Assessment Costs Nothing. A Delayed Replacement Costs More Every Season.</h2>
        <p class="mt-6 text-xl text-slate-300 max-w-2xl mx-auto">We inspect, document, and estimate. You decide. No pressure, no commission sales, no subcontractors showing up at your door.</p>
        <div class="mt-10 flex flex-col sm:flex-row items-center justify-center gap-4">
          <a href="/contact?intent=roof-replacement&source=roof-replacement-final-cta" class="inline-flex items-center justify-center px-10 py-4 rounded-lg bg-red-700 hover:bg-red-800 text-white text-lg font-bold transition-colors" data-event-action="cta-click" data-event-label="final-cta-primary" data-event-category="roof-replacement">Schedule Your Free Replacement Assessment</a>
          <a href="/residential/insurance-claim-assistance" class="inline-flex items-center gap-2 text-white text-lg font-bold hover:underline" data-event-action="cta-click" data-event-label="final-cta-secondary" data-event-category="roof-replacement">Have Storm Damage? See How We Handle Insurance Claims</a>
        </div>
      </div>
    </section>

  </main>
</BaseLayout>
