---
import BaseLayout from '../../../components/seo/BaseLayout.astro';
import Breadcrumb from '../../../components/molecules/Breadcrumb.astro';
import FAQ from '../../../components/molecules/FAQ.astro';
import Icon from '../../../components/atoms/Icon.astro';

const title = "Clay & Tile Roof Installation — Pro Exteriors | TX, CO, KS, MO & GA";
const description = "Pro Exteriors installs and replaces clay tile, concrete tile & Spanish tile roofing across 5 states. Long-lasting, fire-resistant, and built for the Southwest and hail belt. Free assessment.";
const canonicalPath = "/residential/tile-clay-roofing";

const roofingContractorSchema = {
  "@type": "RoofingContractor",
  "name": "Pro Exteriors",
  "url": "https://proexteriorsus.com",
  "telephone": "[REPRESENTATIVE]",
  "areaServed": ["Texas","Colorado","Kansas","Missouri","Georgia"].map(n => ({ "@type": "State", "name": n }))
};

const serviceSchema = {
  "@type": "Service",
  "name": "Clay and Tile Roof Installation",
  "serviceType": "Clay and Tile Roof Installation",
  "provider": { "@type": "RoofingContractor", "name": "Pro Exteriors" },
  "areaServed": ["Texas","Colorado","Kansas","Missouri","Georgia"].map(n => ({ "@type": "State", "name": n })),
  "description": "Pro Exteriors installs and replaces clay tile, concrete tile, and Spanish tile roofing across Texas, Colorado, Kansas, Missouri, and Georgia. Structural assessment included with every tile installation estimate. 50–100 year lifespan."
};

const jsonLd = [roofingContractorSchema, serviceSchema];

const breadcrumbItems = [
  { label: "Home", href: "/" },
  { label: "Residential Roofing", href: "/residential" },
  { label: "Clay & Tile Roofing", href: "/residential/tile-clay-roofing" }
];

const tileTypes = [
  {
    id: "clay",
    icon: "sun",
    title: "Clay Tile",
    body: "The traditional premium option. Natural clay fired at high temperature — the process that gives clay tile its color permanence (clay doesn't fade), its Class A fire rating, and its 75–100+ year lifespan. Available in Spanish S-tile, flat tile, and barrel profiles. Heavier than concrete tile (typically 10–12 lbs/sq ft) and requires structural verification before installation.",
    badge: "Premium · 75–100+ yr"
  },
  {
    id: "concrete",
    icon: "layers",
    title: "Concrete Tile",
    body: "The more accessible entry point to the tile category — comparable profile options and similar durability to clay at a meaningfully lower cost per square foot. Concrete tile runs 9–11 lbs/sq ft, provides a Class A fire rating, and is available in a wide range of color options. Modern pigments have significantly improved color retention over earlier concrete tile products.",
    badge: "Mid-Range · 50–80 yr"
  },
  {
    id: "spanish",
    icon: "home",
    title: "Spanish (S-Tile)",
    body: "A profile designation, not a material — Spanish tile refers to the curved S-shaped interlocking profile available in both clay and concrete. The most recognizable tile profile on Southwestern and Mediterranean-style homes. The curved profile creates the natural air gap that gives tile roofs their thermal performance advantage. Specify clay or concrete depending on your budget and aesthetic priorities.",
    badge: "Most Common Profile"
  }
];

const processSteps = [
  {
    number: 1,
    icon: "search",
    title: "Structural Assessment",
    body: "Before tile is selected or ordered, a Pro Exteriors inspector evaluates the roof framing, decking condition, and any reinforcement required to support the tile load. Clay and concrete tile run 9–12 lbs per square foot — 3–5× the weight of asphalt shingles. The structural assessment determines whether your home is a straightforward tile candidate, needs reinforcement, or has a geometry that makes tile impractical. We tell you the truth at this step."
  },
  {
    number: 2,
    icon: "layers",
    title: "Tile Selection",
    body: "Once the structure is confirmed to support tile, we work through profile (Spanish S-tile, flat, barrel), material (clay vs. concrete), and color options. If you're in a neighborhood with HOA guidelines or a historic district with material requirements, we review those before selection. Lead times for specialty clay tile can run 4–8 weeks — order early in the project sequence."
  },
  {
    number: 3,
    icon: "hard-hat",
    title: "Staged Installation",
    body: "Tile installation begins with a high-temperature underlayment rated for the thermal cycling tile roofs experience. Tiles are fastened individually per manufacturer requirements for your wind zone. Hip caps, ridge tiles, and flashing details at penetrations are set by hand. A full tile replacement typically runs 5–10 days depending on roof complexity."
  },
  {
    number: 4,
    icon: "check-circle",
    title: "Final Inspection and Warranty",
    body: "Full walk of every run, ridge, hip, valley, and flashing point. Pro Exteriors photographs the completed installation. Manufacturer warranty registration is completed by our team. Your documentation package includes the structural assessment, material specification, and installation record."
  }
];

const faqItems = [
  {
    question: "Is my roof structure strong enough for tile?",
    answer: "It depends — which is why the structural assessment is step one of every tile installation Pro Exteriors undertakes. Clay and concrete tile run 9–12 lbs per square foot. Most homes originally built with asphalt shingles were framed for 2–4 lbs per square foot. The additional dead load needs to be evaluated by a Pro Exteriors installer who can look at your specific framing, rafter span, and decking condition. In many cases, the existing structure is adequate or requires modest reinforcement. In some cases — particularly on older homes with undersized rafters or long rafter spans — the structural work required makes tile impractical. We tell you that at the assessment, not after material is ordered."
  },
  {
    question: "How long does clay tile roofing last?",
    answer: "Clay tile is one of the longest-lived roofing materials available. In favorable climates (dry, moderate thermal cycling, low freeze-thaw frequency), 75–100 year lifespans are documented. In the climates we serve — Texas, Colorado, Kansas, Missouri, Georgia — 60–80 years is a realistic expectation for properly installed clay tile. Concrete tile has a shorter lifespan than clay, typically 50–80 years under similar conditions. Both significantly outlast asphalt shingles (25–30 years) and most other residential roofing materials."
  },
  {
    question: "Can tile roofing withstand hail?",
    answer: "Clay tile is hard and fire-resistant, but it is brittle — and large hailstones can crack individual tiles on impact. This is a real consideration for homes in the Texas and Colorado hail belt, where 2-inch-plus hail events occur with meaningful frequency. Cracked tiles can be replaced individually without replacing the full roof — one practical advantage of tile is that repair-in-place is feasible in a way that asphalt replacement is not. But if you're in a high-frequency large-hail zone and longevity without maintenance interruption is the priority, concrete tile (harder than clay) or impact-resistant asphalt shingles may be a more suitable choice. We'll give you a direct assessment based on your property's location."
  },
  {
    question: "What does tile roof installation cost compared to asphalt?",
    answer: "Tile costs more to install than asphalt — the materials are more expensive, the installation is more labor-intensive, and the project takes longer. A direct comparison on per-square-foot installed cost will show tile at a meaningful premium. The per-year cost comparison is different. Divide the installed cost of clay tile by an 80-year lifespan and compare it to multiple asphalt replacements over the same period, and tile's economic case becomes clearer for homeowners who plan to hold the property long-term. For a specific estimate on your home, the assessment is free."
  }
];
---

<!-- Conversion hypothesis: top-5 organic "clay tile roofing" in served states within 6 months + ≥15 qualified tile inquiries/month within 90 days post-launch -->

<BaseLayout {title} {description} {canonicalPath} {jsonLd}>

  <Breadcrumb items={breadcrumbItems} />

  <!-- ═══ HERO ═══ -->
  <section style="position: relative; min-height: 580px; background: linear-gradient(135deg, var(--color-surface-dark, #0f172a) 0%, #1a1a2e 50%, #16213e 100%); display: flex; align-items: center; padding: 80px 24px;">
    <div style="max-width: 1200px; margin: 0 auto; width: 100%; display: grid; grid-template-columns: 1fr 1fr; gap: 64px; align-items: center;">

      <div>
        <p style="font-size: 0.75rem; font-weight: 700; letter-spacing: 0.12em; text-transform: uppercase; color: var(--color-accent, #f97316); margin-bottom: 16px;">
          CLAY & TILE ROOF INSTALLATION — TX · CO · KS · MO · GA
        </p>
        <h1 style="font-size: clamp(2rem, 4vw, 3rem); font-weight: 800; line-height: 1.1; color: #ffffff; margin-bottom: 20px; letter-spacing: -0.02em;">
          Clay and Tile Roofing by Pro Exteriors
        </h1>
        <p style="font-size: 1.125rem; line-height: 1.65; color: rgba(255,255,255,0.8); margin-bottom: 36px; max-width: 520px;">
          50–100 year lifespan. Fire-resistant. The last roof most homeowners ever need — if the structure supports it.
        </p>
        <div style="display: flex; flex-wrap: wrap; gap: 12px;">
          <a href="/contact?intent=tile-assessment&source=tile-clay-roofing-hero"
             style="display: inline-flex; align-items: center; justify-content: center; gap: 8px; background-color: var(--color-accent, #f97316); color: #ffffff; font-size: 1rem; font-weight: 700; padding: 14px 28px; border-radius: 6px; text-decoration: none; min-height: 48px;"
             data-event-action="cta-click"
             data-event-label="hero-primary"
             data-event-category="tile-clay-roofing">
            Schedule a Free Tile Roof Assessment
          </a>
          <a href="#tile-types"
             style="display: inline-flex; align-items: center; justify-content: center; gap: 8px; background-color: rgba(255,255,255,0.1); color: #ffffff; font-size: 1rem; font-weight: 600; padding: 14px 28px; border-radius: 6px; text-decoration: none; min-height: 48px; border: 1px solid rgba(255,255,255,0.2);"
             data-event-action="cta-click"
             data-event-label="hero-secondary"
             data-event-category="tile-clay-roofing">
            Explore Tile Options
          </a>
        </div>
      </div>

      <div style="aspect-ratio: 4/3; background-color: rgba(255,255,255,0.06); border-radius: 8px; display: flex; align-items: center; justify-content: center;">
        <em style="color: rgba(255,255,255,0.3); font-style: normal; font-size: 0.875rem;" title="Not yet sourced">[REPRESENTATIVE — Clay tile roofing installation photo]</em>
      </div>

    </div>
  </section>

  <!-- ═══ TRUST STRIP ═══ -->
  <div style="background-color: var(--color-surface-dark, #0f172a); border-top: 1px solid rgba(255,255,255,0.08); border-bottom: 1px solid rgba(255,255,255,0.08);">
    <div style="max-width: 1200px; margin: 0 auto; padding: 20px 24px; display: flex; flex-wrap: wrap; gap: 8px 32px; align-items: center; justify-content: center;">
      {[
        { icon: "clock", label: "50–100 Year Lifespan" },
        { icon: "flame", label: "Fire Resistant" },
        { icon: "map-pin", label: "TX · CO · KS · MO · GA" },
        { icon: "star", label: "[REPRESENTATIVE] Google Rating" },
        { icon: "shield", label: "Specialist Crews" }
      ].map(item => (
        <div style="display: flex; align-items: center; gap: 8px; color: rgba(255,255,255,0.85); font-size: 0.875rem; font-weight: 500; white-space: nowrap;">
          <Icon name={item.icon} size={16} color="var(--color-accent, #f97316)" aria-hidden="true" />
          {item.label.includes("[") ? <em style="font-style: normal;" title="Not yet sourced">{item.label}</em> : item.label}
        </div>
      ))}
    </div>
  </div>

  <!-- ═══ SERVICE OVERVIEW ═══ -->
  <section style="padding: 96px 24px; background-color: var(--color-surface, #ffffff);">
    <div style="max-width: 1200px; margin: 0 auto; display: grid; grid-template-columns: 1fr 1fr; gap: 64px; align-items: center;">

      <div>
        <p style="font-size: 0.75rem; font-weight: 700; letter-spacing: 0.12em; text-transform: uppercase; color: var(--color-accent, #f97316); margin-bottom: 12px;">
          WHY TILE ENDURES
        </p>
        <h2 style="font-size: clamp(1.5rem, 3vw, 2.25rem); font-weight: 800; line-height: 1.2; color: var(--color-surface-dark, #0f172a); margin-bottom: 24px; letter-spacing: -0.02em;">
          Clay and Tile Roofing Lasts 50–100 Years. The Upfront Cost Looks Different When You Run the Per-Year Math.
        </h2>
        <div style="font-size: 1rem; line-height: 1.75; color: var(--color-text-secondary, #475569);">
          <p style="margin-bottom: 20px;">
            Clay tile roofing has been the premium residential roofing material in hot,
            dry climates for centuries — naturally fire-resistant (Class A fire rating
            without chemical treatment), thermally dense, and mechanically durable in
            the ways that matter for the Southwest and the southern Great Plains.
          </p>
          <p style="margin-bottom: 20px;">
            The profiles run from Spanish S-tile (the curved barrel profile associated
            with Mediterranean and mission architecture) to flat tile (a contemporary
            profile for modern Southwestern homes) to concrete tile (the more affordable
            sibling that delivers similar durability at lower cost per square foot).
          </p>
          <p>
            The trade-off is weight and installation complexity. Clay and concrete tile
            run 9–12 lbs per square foot versus 2–4 lbs for asphalt shingles. Before
            any tile installation, Pro Exteriors conducts a structural assessment of the
            roof framing and decking to verify the structure can support the load — or
            determine what reinforcement is required. This step is not optional, and any
            tile contractor who skips it is taking a risk with your structure.
          </p>
        </div>
        <div style="margin-top: 32px;">
          <a href="/contact?intent=tile-assessment&source=tile-clay-roofing-overview"
             style="display: inline-flex; align-items: center; gap: 8px; background-color: var(--color-accent, #f97316); color: #ffffff; font-size: 0.9375rem; font-weight: 700; padding: 13px 24px; border-radius: 6px; text-decoration: none;"
             data-event-action="cta-click"
             data-event-label="overview-cta"
             data-event-category="tile-clay-roofing">
            Schedule Your Free Tile Roof Assessment
          </a>
        </div>
      </div>

      <div style="aspect-ratio: 4/3; background-color: var(--color-surface-subtle, #f8fafc); border-radius: 8px; display: flex; align-items: center; justify-content: center; border: 1px solid var(--color-border, #e2e8f0);">
        <em style="color: var(--color-text-muted, #94a3b8); font-style: normal; font-size: 0.875rem;" title="Not yet sourced">[REPRESENTATIVE — Spanish S-tile installation photo]</em>
      </div>

    </div>
  </section>

  <!-- ═══ TILE TYPES GRID ═══ -->
  <section id="tile-types" style="padding: 96px 24px; background-color: var(--color-surface-subtle, #f8fafc);">
    <div style="max-width: 1200px; margin: 0 auto;">
      <div style="text-align: center; margin-bottom: 56px;">
        <p style="font-size: 0.75rem; font-weight: 700; letter-spacing: 0.12em; text-transform: uppercase; color: var(--color-accent, #f97316); margin-bottom: 12px;">
          TILE OPTIONS
        </p>
        <h2 style="font-size: clamp(1.5rem, 3vw, 2.25rem); font-weight: 800; line-height: 1.2; color: var(--color-surface-dark, #0f172a); letter-spacing: -0.02em;">
          Three Tile Profiles. Different Aesthetics, Different Price Points.
        </h2>
      </div>
      <div style="display: grid; grid-template-columns: repeat(auto-fit, minmax(300px, 1fr)); gap: 24px;">
        {tileTypes.map(tile => (
          <div style="background-color: var(--color-surface, #ffffff); border: 1px solid var(--color-border, #e2e8f0); border-radius: 8px; padding: 32px; position: relative;">
            <div style="position: absolute; top: 16px; right: 16px; background-color: var(--color-accent, #f97316); color: #ffffff; font-size: 0.6875rem; font-weight: 700; letter-spacing: 0.06em; text-transform: uppercase; padding: 4px 10px; border-radius: 4px;">
              {tile.badge}
            </div>
            <div style="width: 48px; height: 48px; background-color: rgba(249,115,22,0.1); border-radius: 8px; display: flex; align-items: center; justify-content: center; margin-bottom: 20px;">
              <Icon name={tile.icon} size={24} color="var(--color-accent, #f97316)" aria-hidden="true" />
            </div>
            <h3 style="font-size: 1.125rem; font-weight: 700; color: var(--color-surface-dark, #0f172a); margin-bottom: 12px; line-height: 1.3;">
              {tile.title}
            </h3>
            <p style="font-size: 0.9375rem; line-height: 1.65; color: var(--color-text-secondary, #475569);">
              {tile.body}
            </p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- ═══ STAT BAND + TESTIMONIAL ═══ -->
  <section style="padding: 96px 24px; background-color: var(--color-surface-dark, #0f172a);">
    <div style="max-width: 1200px; margin: 0 auto;">
      <div style="display: grid; grid-template-columns: repeat(auto-fit, minmax(200px, 1fr)); gap: 32px; margin-bottom: 72px; text-align: center;">
        {[
          { value: "15+", label: "Years in Business" },
          { value: "5", label: "States Served" },
          { value: "[REPRESENTATIVE]", label: "Tile Installations Completed" }
        ].map(stat => (
          <div>
            <p style="font-size: clamp(2.5rem, 5vw, 3.5rem); font-weight: 800; color: var(--color-accent, #f97316); line-height: 1; margin-bottom: 8px;">
              {stat.value.includes("[") ? <em style="font-style: normal;" title="Not yet sourced">{stat.value}</em> : stat.value}
            </p>
            <p style="font-size: 0.9375rem; color: rgba(255,255,255,0.7); font-weight: 500;">{stat.label}</p>
          </div>
        ))}
      </div>
      <div style="display: grid; grid-template-columns: 1fr 1fr; gap: 64px; align-items: center;">
        <div>
          <p style="font-size: 1rem; line-height: 1.75; color: rgba(255,255,255,0.75);">
            Pro Exteriors operates as licensed residential roofing specialists across Texas,
            Colorado, Kansas, Missouri, and Georgia — covering the Southern Great Plains and
            the Southeast markets where Spanish tile, flat tile, and barrel tile are common
            architectural choices on custom homes and upscale residential developments.
            Our crews are trained on the structural requirements that tile installation
            demands, including decking reinforcement assessment and proper tile fastening
            in wind-load zones.
          </p>
        </div>
        <div style="background-color: rgba(255,255,255,0.05); border: 1px solid rgba(255,255,255,0.1); border-radius: 8px; padding: 32px;">
          <div style="display: flex; gap: 4px; margin-bottom: 16px;" aria-label="5 out of 5 stars">
            {[1,2,3,4,5].map(() => (
              <Icon name="star" size={18} color="#f59e0b" aria-hidden="true" />
            ))}
          </div>
          <blockquote style="font-size: 1rem; line-height: 1.65; color: rgba(255,255,255,0.85); font-style: italic; margin-bottom: 20px;">
            <em title="Not yet sourced">[REPRESENTATIVE — Real customer testimonial on clay or tile roofing installation. Signed release required before ship.]</em>
          </blockquote>
          <div style="display: flex; align-items: center; gap: 12px;">
            <div style="width: 40px; height: 40px; border-radius: 50%; background-color: rgba(255,255,255,0.1); display: flex; align-items: center; justify-content: center;">
              <em style="font-style: normal; color: rgba(255,255,255,0.4); font-size: 0.75rem;" title="Not yet sourced">IMG</em>
            </div>
            <div>
              <p style="font-weight: 600; color: #ffffff; font-size: 0.875rem;">
                <em style="font-style: normal;" title="Not yet sourced">[REPRESENTATIVE — Customer Name, City, State]</em>
              </p>
              <p style="font-size: 0.8125rem; color: rgba(255,255,255,0.5);">Verified Customer</p>
            </div>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- ═══ PROCESS ═══ -->
  <section id="process" style="padding: 96px 24px; background-color: var(--color-surface, #ffffff);">
    <div style="max-width: 1200px; margin: 0 auto;">
      <div style="text-align: center; margin-bottom: 56px;">
        <p style="font-size: 0.75rem; font-weight: 700; letter-spacing: 0.12em; text-transform: uppercase; color: var(--color-accent, #f97316); margin-bottom: 12px;">
          THE INSTALLATION PROCESS
        </p>
        <h2 style="font-size: clamp(1.5rem, 3vw, 2.25rem); font-weight: 800; line-height: 1.2; color: var(--color-surface-dark, #0f172a); letter-spacing: -0.02em;">
          Four Steps. The First One Determines Everything Else.
        </h2>
      </div>
      <div style="display: grid; grid-template-columns: repeat(auto-fit, minmax(240px, 1fr)); gap: 24px;">
        {processSteps.map(step => (
          <div style="position: relative; padding: 32px; background-color: var(--color-surface-subtle, #f8fafc); border-radius: 8px; border: 1px solid var(--color-border, #e2e8f0);">
            <div style="font-size: 3rem; font-weight: 800; color: rgba(249,115,22,0.15); line-height: 1; margin-bottom: 16px;">
              {step.number.toString().padStart(2, '0')}
            </div>
            <h3 style="font-size: 1.0625rem; font-weight: 700; color: var(--color-surface-dark, #0f172a); margin-bottom: 12px; line-height: 1.3;">
              {step.title}
            </h3>
            <p style="font-size: 0.9375rem; line-height: 1.65; color: var(--color-text-secondary, #475569);">
              {step.body}
            </p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- ═══ CASE STUDIES ═══ -->
  <section style="padding: 96px 24px; background-color: var(--color-surface-subtle, #f8fafc);">
    <div style="max-width: 1200px; margin: 0 auto;">
      <div style="text-align: center; margin-bottom: 56px;">
        <p style="font-size: 0.75rem; font-weight: 700; letter-spacing: 0.12em; text-transform: uppercase; color: var(--color-accent, #f97316); margin-bottom: 12px;">
          PROJECT EXAMPLES
        </p>
        <h2 style="font-size: clamp(1.5rem, 3vw, 2.25rem); font-weight: 800; line-height: 1.2; color: var(--color-surface-dark, #0f172a); letter-spacing: -0.02em;">
          Tile Roofing from the Field.
        </h2>
      </div>
      <div style="display: grid; grid-template-columns: repeat(auto-fit, minmax(300px, 1fr)); gap: 24px;">
        {["cs-1","cs-2","cs-3"].map((id, i) => (
          <div style="background-color: var(--color-surface, #ffffff); border: 1px solid var(--color-border, #e2e8f0); border-radius: 8px; overflow: hidden;">
            <div style="aspect-ratio: 16/9; background-color: var(--color-surface-subtle, #f8fafc); display: flex; align-items: center; justify-content: center;">
              <em style="color: var(--color-text-muted, #94a3b8); font-style: normal; font-size: 0.8125rem;" title="Not yet sourced">[REPRESENTATIVE — Tile project photo {i+1}]</em>
            </div>
            <div style="padding: 24px;">
              <p style="font-size: 0.6875rem; font-weight: 700; letter-spacing: 0.08em; text-transform: uppercase; color: var(--color-accent, #f97316); margin-bottom: 8px;">
                <em style="font-style: normal;" title="Not yet sourced">[REPRESENTATIVE]</em>
              </p>
              <h3 style="font-size: 1.0625rem; font-weight: 700; color: var(--color-surface-dark, #0f172a); margin-bottom: 8px; line-height: 1.3;">
                <em style="font-style: normal;" title="Not yet sourced">[REPRESENTATIVE — Project title, city, state]</em>
              </h3>
              <p style="font-size: 0.875rem; color: var(--color-text-secondary, #475569); line-height: 1.6;">
                <em style="font-style: normal;" title="Not yet sourced">[REPRESENTATIVE — Tile type, profile, scope, structural notes]</em>
              </p>
            </div>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- ═══ COST / VALUE SPLIT ═══ -->
  <section style="padding: 96px 24px; background-color: var(--color-surface, #ffffff);">
    <div style="max-width: 1200px; margin: 0 auto; display: grid; grid-template-columns: 1fr 1fr; gap: 64px; align-items: center;">

      <div style="aspect-ratio: 4/3; background-color: var(--color-surface-subtle, #f8fafc); border-radius: 8px; display: flex; align-items: center; justify-content: center; border: 1px solid var(--color-border, #e2e8f0);">
        <em style="color: var(--color-text-muted, #94a3b8); font-style: normal; font-size: 0.875rem;" title="Not yet sourced">[REPRESENTATIVE — Tile installation in progress or completed project photo]</em>
      </div>

      <div>
        <p style="font-size: 0.75rem; font-weight: 700; letter-spacing: 0.12em; text-transform: uppercase; color: var(--color-accent, #f97316); margin-bottom: 12px;">
          THE COST QUESTION
        </p>
        <h2 style="font-size: clamp(1.5rem, 3vw, 2.25rem); font-weight: 800; line-height: 1.2; color: var(--color-surface-dark, #0f172a); margin-bottom: 24px; letter-spacing: -0.02em;">
          Higher Upfront. Lower Per-Year. The Math Is Different for Tile.
        </h2>
        <div style="font-size: 1rem; line-height: 1.75; color: var(--color-text-secondary, #475569);">
          <p style="margin-bottom: 20px;">
            Clay and concrete tile installation costs more upfront than asphalt shingles —
            a meaningful premium on materials, and an installation that takes longer because
            of structural verification, heavier materials, and the detail work that tile
            profiles require. That is not in dispute.
          </p>
          <p style="margin-bottom: 20px;">
            The per-year cost comparison is different. A high-quality asphalt shingle roof
            lasts 25–30 years and needs replacement at the end of that cycle. A clay tile
            installation runs 75–100+ years. Divide the installed cost by the lifespan
            and tile's per-year ownership cost is often lower than multiple asphalt shingle
            replacements over the same timeframe.
          </p>
          <p>
            For a full comparison of residential roofing material options, see the
            <a href="/residential/roof-replacement" style="color: var(--color-accent, #f97316); text-decoration: underline;">roof replacement</a>
            page. If natural permanence is the priority and budget is not the constraint,
            <a href="/residential/natural-slate" style="color: var(--color-accent, #f97316); text-decoration: underline;">natural slate roofing</a>
            is the other premium option worth considering.
          </p>
        </div>
