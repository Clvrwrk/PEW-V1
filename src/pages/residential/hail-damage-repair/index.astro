        <h2 id="faq-heading" style="font-size: clamp(1.5rem, 3vw, 2.25rem); font-weight: 800; color: var(--color-text-primary, #0f172a); line-height: 1.2;">
          Hail Damage Repair Questions, Answered.
        </h2>
      </div>
      <FAQ items={faqItems} schemaType="FAQPage" />
    </div>
  </section>

  <!-- ═══════════════════════════════════════════
       FINAL CTA BANNER
  ═══════════════════════════════════════════ -->
  <section
    style="position: relative; background-color: var(--color-surface-dark, #0f172a); padding: 96px 24px; overflow: hidden; text-align: center;"
