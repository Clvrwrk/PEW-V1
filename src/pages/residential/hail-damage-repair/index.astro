      <div style="text-align: center; margin-bottom: 48px;">
        <p style="color: var(--color-accent, #f97316); font-size: 0.75rem; font-weight: 700; letter-spacing: 0.12em; text-transform: uppercase; margin-bottom: 12px;">RECENT HAIL DAMAGE REPAIRS</p>
        <h2 id="cases-heading" style="font-size: clamp(1.5rem, 3vw, 2.25rem); font-weight: 800; color: var(--color-text-primary, #0f172a); line-height: 1.2;">
          Across the Hail Belt — Texas, Colorado, Kansas
        </h2>
      </div>
      <div style="display: grid; grid-template-columns: repeat(auto-fit, minmax(300px, 1fr)); gap: 28px; margin-bottom: 40px;">
        {caseStudies.map(cs => (
          <article style="background-color: var(--color-surface-subtle, #f8fafc); border-radius: 8px; overflow: hidden;">
            <div style="aspect-ratio: 16/9; background-color: #e2e8f0; overflow: hidden;">
              <img src="[REPRESENTATIVE — NOT YET SOURCED]" alt={cs.alt} width="400" height="225" loading="lazy" style="width: 100%; height: 100%; object-fit: cover;" title="Not yet sourced" />
            </div>
            <div style="padding: 24px;">
              <p style="font-size: 0.75rem; font-weight: 700; color: var(--color-accent, #f97316); text-transform: uppercase; letter-spacing: 0.08em; margin-bottom: 8px;">{cs.state} · {cs.tag}</p>
              <h3 style="font-size: 1rem; font-weight: 700; color: var(--color-text-primary, #0f172a); margin-bottom: 10px; line-height: 1.4;"><em title="Not yet sourced">{cs.title}</em></h3>
              <p style="font-size: 0.875rem; line-height: 1.6; color: var(--color-text-secondary, #475569); margin: 0;"><em title="Not yet sourced">{cs.description}</em></p>
            </div>
          </article>
        ))}
      </div>
      <div style="text-align: center;">
        <a href="/projects" style="font-size: 0.9375rem; font-weight: 600; color: var(--color-accent, #f97316); text-decoration: underline;">See All Projects</a>
      </div>
    </div>
  </section>

  <!-- ═══════════════════════════════════════════
       INSURANCE BAND
  ═══════════════════════════════════════════ -->
  <section style="background-color: var(--color-surface-subtle, #f8fafc); padding: 80px 24px;" aria-labelledby="insurance-heading">
    <div style="max-width: 1200px; margin: 0 auto; display: grid; grid-template-columns: 1fr; gap: 48px; align-items: center;">
      <div style="background-color: #e2e8f0; border-radius: 8px; overflow: hidden; aspect-ratio: 4/3; max-width: 480px; width: 100%;">
        <img src="[REPRESENTATIVE — NOT YET SOURCED]" alt="Pro Exteriors crew conducting hail damage inspection on a residential roof" width="480" height="360" loading="lazy" style="width: 100%; height: 100%; object-fit: cover;" title="Not yet sourced" />
      </div>
      <div>
        <p style="color: var(--color-accent, #f97316); font-size: 0.75rem; font-weight: 700; letter-spacing: 0.12em; text-transform: uppercase; margin-bottom: 12px;">HAIL DAMAGE AND YOUR INSURANCE CLAIM</p>
        <h2 id="insurance-heading" style="font-size: clamp(1.5rem, 3vw, 2.25rem); font-weight: 800; color: var(--color-text-primary, #0f172a); line-height: 1.2; margin-bottom: 20px;">
          Hail Damage Is Typically Covered. The Documentation Is What Matters.
        </h2>
        <div style="font-size: 1rem; line-height: 1.75; color: var(--color-text-secondary, #475569);">
          <p style="margin-bottom: 16px;">
            Standard homeowner insurance policies cover hail as a named peril. Whether a specific claim is approved — and for what dollar amount — depends on your policy deductibles, the adjuster's assessment, and the quality of the damage documentation.
          </p>
          <p>
            Pro Exteriors coordinates the adjuster inspection and reviews the carrier's estimate against our scope of work. When the initial payout falls short of the actual repair cost, we file a supplement request with your carrier. The earlier you call after a hail event, the cleaner the causation documentation. See our <a href="/residential/insurance-claim-assistance" style="color: var(--color-accent, #f97316); font-weight: 600; text-decoration: underline;">insurance claim assistance</a> page for a full breakdown of how the process works.
          </p>
        </div>
      </div>
    </div>
  </section>

  <!-- ═══════════════════════════════════════════
       FAQ
  ═══════════════════════════════════════════ -->
  <section style="background-color: var(--color-surface-light, #ffffff); padding: 80px 24px;" aria-labelledby="faq-heading">
