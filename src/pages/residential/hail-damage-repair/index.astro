    <div style="position: absolute; inset: 0; z-index: 0;" aria-hidden="true">
      <img src="[REPRESENTATIVE — NOT YET SOURCED]" alt="" width="1440" height="480" loading="lazy" style="width: 100%; height: 100%; object-fit: cover; opacity: 0.10;" title="Not yet sourced" />
    </div>
    <div style="position: relative; z-index: 1; max-width: 700px; margin: 0 auto;">
      <p style="color: var(--color-accent, #f97316); font-size: 0.75rem; font-weight: 700; letter-spacing: 0.12em; text-transform: uppercase; margin-bottom: 16px;">START HERE</p>
      <h2 style="font-size: clamp(1.75rem, 4vw, 2.75rem); font-weight: 800; color: #ffffff; line-height: 1.15; margin-bottom: 20px;">
