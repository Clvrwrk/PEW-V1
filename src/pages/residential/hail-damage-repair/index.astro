          style="display: inline-flex; align-items: center; gap: 8px; background-color: var(--color-accent, #f97316); color: #ffffff; font-size: 1rem; font-weight: 700; padding: 18px 36px; border-radius: 6px; text-decoration: none; min-height: 56px;"
          data-event-action="cta-click"
