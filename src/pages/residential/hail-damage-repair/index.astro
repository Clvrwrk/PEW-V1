        </a>
        <a
          href="/residential/insurance-claim-assistance"
          style="display: inline-flex; align-items: center; gap: 8px; color: #ffffff; font-size: 1rem; font-weight: 600; text-decoration: none; border-bottom: 2px solid rgba(255,255,255,0.4); padding-bottom: 2px; min-height: 44px;"
          data-event-action="cta-click"
          data-event-label="final-cta-secondary"
