---
/* ═══════════════════════════════════════════════════════════════════════════
   /residential/metal-roofing — T2 money page
   ───────────────────────────────────────────────────────────────────────────
   Template: residential-service (inherits asphalt-shingles pattern)
   Build pipeline: AIA4 PageBuilder · Phase 0–6 · 2026-05-03
   Copy:  design/templates/metal-roofing/copy.yaml
   Brief: design/templates/metal-roofing/brief.yaml

   ━ Conversion hypothesis ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
     (a) Top-5 organic for "metal roof installation" in TX/CO/KS/MO/GA within 6 months
     (b) ≥20% form-completion on 'Get a Metal Roof Quote' CTA within 90 days

   ━ SHIP-BLOCKING [REPRESENTATIVE] markers ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
   All image slots · all case studies · testimonial · phone · cost ranges
   Insurance premium discount claim in FAQ — verify before ship
═══════════════════════════════════════════════════════════════════════════ */

import BaseLayout from '../../../components/seo/BaseLayout.astro';
import Breadcrumb from '../../../components/molecules/Breadcrumb.astro';
import FAQ from '../../../components/molecules/FAQ.astro';
import Icon from '../../../components/atoms/Icon.astro';

const title       = "Metal Roof Installation for Homes — Pro Exteriors | TX, CO, KS, MO & GA";
const description = "Standing seam, corrugated & stone-coated metal roofing installed across 5 states. 50-year lifespans. GAF certified. Get a free metal roof assessment from Pro Exteriors.";
const canonicalPath = "/residential/metal-roofing";

const serviceSchema = {
  "@context": "https://schema.org",
  "@type": "Service",
  "serviceType": "Metal Roof Installation for Homes",
  "provider": { "@id": "https://proexteriorsus.com/#roofing-contractor" },
  "areaServed": [
    { "@type": "State", "name": "Texas" },
    { "@type": "State", "name": "Colorado" },
    { "@type": "State", "name": "Kansas" },
    { "@type": "State", "name": "Missouri" },
    { "@type": "State", "name": "Georgia" }
  ],
  "hasOfferCatalog": {
    "@type": "OfferCatalog",
    "name": "Metal Roofing Systems",
    "itemListElement": [
      { "@type": "Offer", "itemOffered": { "@type": "Service", "name": "Standing Seam Metal Roof Installation" } },
      { "@type": "Offer", "itemOffered": { "@type": "Service", "name": "Stone-Coated Steel Roof Installation" } },
      { "@type": "Offer", "itemOffered": { "@type": "Service", "name": "Corrugated Metal Roof Installation" } }
    ]
  }
};

const roofingContractorSchema = {
  "@context": "https://schema.org",
  "@type": "RoofingContractor",
  "@id": "https://proexteriorsus.com/#roofing-contractor",
  "name": "Pro Exteriors",
  "url": "https://proexteriorsus.com",
  "areaServed": [
    { "@type": "State", "name": "Texas" },
    { "@type": "State", "name": "Colorado" },
    { "@type": "State", "name": "Kansas" },
    { "@type": "State", "name": "Missouri" },
    { "@type": "State", "name": "Georgia" }
  ]
};

const jsonLd = [roofingContractorSchema, serviceSchema];

const systems = [
  {
    id: "standing-seam",
    eyebrow: "MOST DURABLE",
    h3: "Standing Seam Metal Roofing",
    body: `The premium metal roofing system for residential applications. Concealed
           fasteners eliminate the moisture intrusion risk that exposed-fastener panels
           carry over time. Standing seam panels interlock at raised seams running
           vertically from ridge to eave — a clean architectural surface with no exposed
           hardware. Typical service life is 50+ years with minimal maintenance.`,
    specs: ["Lifespan: 50+ years","Fasteners: Concealed (no penetrations)","Wind rating: Up to 140 mph","Best for: Long-tenure homes, mountain climates, premium builds"],
    img: "/images/placeholders/metal-standing-seam.jpg",
    alt: "Standing seam metal roof with raised vertical seams on a residential home",
  },
  {
    id: "stone-coated",
    eyebrow: "POPULAR IN HAIL BELT",
    h3: "Stone-Coated Steel Roofing",
    body: `Stone-coated steel panels deliver the look of tile, shake, or shingles
           over a steel substrate that earns a Class 4 hail rating — the highest
           impact-resistance classification under UL 2218. For homes in Texas,
           Colorado, and Kansas where large hail is a recurring threat, stone-coated
           steel is the most durable alternative to natural materials at a fraction
           of the weight.`,
    specs: ["Lifespan: 40–50 years","Hail rating: Class 4 (UL 2218)","Weight: ~1.4 lbs/sq ft","Best for: Hail-belt markets, tile aesthetics without tile weight"],
    img: "/images/placeholders/metal-stone-coated.jpg",
    alt: "Stone-coated steel residential roofing panels in a shake profile",
  },
  {
    id: "corrugated",
    eyebrow: "",
    h3: "Corrugated Metal Roofing",
    body: `Corrugated metal panels have found a home in modern farmhouse, industrial,
           and rural residential architecture. Lower upfront cost than standing seam.
           Exposed fasteners require periodic inspection and resealing — proper
           condensation management is especially important in humid climates like
           Georgia. Galvanized and Galvalume substrates available.`,
    specs: ["Lifespan: 30–45 years (properly maintained)","Fasteners: Exposed (inspect every 5–7 years)","Cost: Lower than standing seam","Best for: Farmhouse, rural, modern industrial aesthetics"],
    img: "/images/placeholders/metal-corrugated.jpg",
    alt: "Corrugated metal roofing on a modern farmhouse residential build",
  },
];

const processSteps = [
  { num: 1, icon: "search",       title: "Free Structural Assessment",     body: "Metal roofing systems vary in weight and attachment requirements. We assess the existing deck, framing, and ventilation before recommending a system — some standing seam profiles require specific clip spacing and deck conditions." },
  { num: 2, icon: "clipboard",    title: "System Selection",               body: "Based on your home's architecture, local weather profile (hail frequency, wind load, temperature range), and budget, we recommend the right panel system and substrate from our standing seam, stone-coated, and corrugated lines." },
  { num: 3, icon: "wrench",       title: "Professional Installation",      body: "Our crews install metal panels per manufacturer specifications, including proper underlayment, drip edge, ridge cap, and penetration sealing. GAF-certified installation protocol on qualifying systems." },
  { num: 4, icon: "check-circle", title: "Inspection & Warranty Documentation", body: "Final inspection of all seams, fasteners, and penetration details. Manufacturer warranty documentation delivered to you before we leave the job. Warranties transfer to the next owner at point of home sale." },
];

const faqItems = [
  {
    question: "How long does a metal roof last?",
    answer: `Standing seam metal roofing has a documented service life of 50+ years. Stone-coated steel systems run 40–50 years. Corrugated metal, properly maintained, runs 30–45 years — all significantly longer than the 25–30 year practical lifespan of architectural asphalt shingles. The transferable warranty documentation Pro Exteriors provides at job completion gives you evidence of that lifespan when you sell the house. See <a href="/blog/5-signs-replacement">five signs your roof needs replacing</a> if you are trying to decide whether to repair or replace your current roof.`,
  },
  {
    question: "Can metal roofing withstand hail?",
    answer: `Standing seam and stone-coated steel panels are rated Class 4 under UL 2218 — the highest hail-impact classification for roofing materials. A Class 4 rating means the panel withstood two direct strikes from a 2-inch steel ball dropped from 20 feet without fracturing. For homeowners in Texas, Colorado, and Kansas where hail events exceeding 1 inch in diameter are common, metal roofing is the most durable residential option available. Our team handles <a href="/residential/hail-damage-repair">hail damage assessment</a> across all five served states. <span class="text-slate-500 italic text-sm">[REPRESENTATIVE — verify insurance premium discount claim before ship]</span>`,
  },
  {
    question: "Is metal roofing louder than asphalt shingles when it rains?",
    answer: `With solid sheathing under the panels — which is standard in residential metal roofing installation — the indoor noise level during a rainstorm is comparable to asphalt shingles over the same substrate. The "loud tin roof" perception comes from agricultural metal roofing installed over open framing with no solid deck — a different product on a different structure. Proper residential installation includes solid OSB or plywood sheathing and underlayment that absorbs sound.`,
  },
  {
    question: "What does metal roof installation cost?",
    answer: `Cost varies significantly by system type, roof complexity, and square footage. Standing seam is the most expensive; stone-coated steel is mid-range; corrugated is the entry point. <span class="text-slate-500 italic text-sm">[REPRESENTATIVE — insert Pro Exteriors confirmed price ranges before ship]</span> The more useful number is cost per year of service life — a standing seam roof at twice the upfront cost of asphalt, lasting twice as long, often has a comparable or lower annualized cost. See our guide on <a href="/blog/how-much-does-a-roof-replacement-cost">how much a roof replacement actually costs</a> for a framework to evaluate any estimate you receive.`,
  },
];
---

<BaseLayout
  title={title}
  description={description}
  canonicalPath={canonicalPath}
  jsonLd={jsonLd}
>
  <a href="#main" class="sr-only focus:not-sr-only focus:absolute focus:top-2 focus:left-2 focus:z-50 focus:bg-white focus:px-4 focus:py-2 focus:rounded">Skip to main content</a>

  <main id="main">

    {/* ══════ HERO ══════════════════════════════════════════════════════════ */}
    <section
      class="relative isolate overflow-hidden text-white"
      style="min-height: 760px; background-color: var(--color-surface-dark, #0f172a);"
      aria-label="Metal roof installation — Pro Exteriors"
    >
      <div class="absolute inset-0 -z-10">
        <img
          src="/images/placeholders/hero-metal-roofing.jpg"
          alt=""
          class="w-full h-full object-cover opacity-60"
          loading="eager"
          fetchpriority="high"
          width="1920"
          height="1080"
        />
        <div class="absolute inset-0 bg-gradient-to-r from-slate-900 via-slate-900/70 to-slate-900/20"></div>
      </div>
      <div class="mx-auto max-w-screen-xl px-6 lg:px-8 py-20 lg:py-28">
        <Breadcrumb items={[
          { label: "Residential Roofing", href: "/residential" },
          { label: "Metal Roof Installation", href: "/residential/metal-roofing" }
        ]} />
        <p class="mt-4 text-sm font-bold uppercase tracking-widest text-white/70">TX · CO · KS · MO · GA</p>
        <h1 class="mt-6 text-5xl lg:text-6xl font-black leading-[1.05] max-w-3xl">
          Metal Roof Installation by Pro Exteriors
        </h1>
        <p class="mt-6 max-w-2xl text-xl lg:text-2xl text-slate-300 leading-relaxed">
          Standing seam, stone-coated steel, and corrugated metal roofing for homes across five states. A 50-year decision. Made by certified crews who know the difference.
        </p>
        <div class="mt-10 flex flex-col sm:flex-row gap-4">
          <a
            href="/contact?intent=metal-roof-assessment&source=metal-roofing-hero"
            class="inline-flex items-center justify-center px-8 py-4 rounded-lg bg-red-700 hover:bg-red-800 text-white text-lg font-bold transition-colors focus-visible:outline-2 focus-visible:outline-white focus-visible:outline-offset-2"
            data-event-action="cta-click"
            data-event-label="hero-primary"
            data-event-category="metal-roofing"
          >Get a Free Metal Roof Assessment</a>
          <a
            href="#systems"
            class="inline-flex items-center justify-center px-8 py-4 rounded-lg border-2 border-white text-white text-lg font-bold hover:bg-white hover:text-slate-900 transition-colors focus-visible:outline-2 focus-visible:outline-white focus-visible:outline-offset-2"
            data-event-action="cta-click"
            data-event-label="hero-secondary"
            data-event-category="metal-roofing"
          >Compare Metal Roofing Systems</a>
        </div>
      </div>
    </section>

    {/* ══════ TRUST STRIP ════════════════════════════════════════════════════ */}
    <section aria-label="Metal roofing credentials" class="py-8 border-y border-stone-200 bg-stone-50">
      <ul class="mx-auto max-w-screen-xl px-6 lg:px-8 flex flex-wrap items-center justify-center gap-8 lg:gap-16 text-sm font-bold text-slate-900">
        <li class="inline-flex items-center gap-2"><Icon name="shield-check" class="w-5 h-5 text-red-700" /><span>GAF Certified</span></li>
        <li class="inline-flex items-center gap-2"><Icon name="clock" class="w-5 h-5 text-red-700" /><span>50-Year Lifespan</span></li>
        <li class="inline-flex items-center gap-2"><Icon name="bolt" class="w-5 h-5 text-red-700" /><span>Class 4 Hail Resistant</span></li>
        <li class="inline-flex items-center gap-2"><Icon name="map-pin" class="w-5 h-5 text-red-700" /><span>5-State Coverage</span></li>
        <li class="inline-flex items-center gap-2">
          <Icon name="star" class="w-5 h-5 text-red-700" />
          <span><span class="text-slate-500 text-xs font-normal italic mr-1" title="Not yet sourced">[REPRESENTATIVE]</span>Google Rating</span>
        </li>
      </ul>
    </section>

    {/* ══════ SERVICE OVERVIEW ════════════════════════════════════════════════ */}
    <section aria-label="About metal roofing for homes" class="py-20 lg:py-28 bg-white">
      <div class="mx-auto max-w-screen-xl px-6 lg:px-8 grid lg:grid-cols-2 gap-12 lg:gap-20 items-center">
        <div>
          <p class="text-sm font-bold uppercase tracking-widest text-red-700">WHY METAL ROOFING</p>
          <h2 class="mt-4 text-4xl lg:text-5xl font-black leading-tight text-slate-900">A 50-Year Roof. Not a 25-Year Replacement Cycle.</h2>
          <div class="mt-6 text-lg text-slate-700 leading-relaxed space-y-4">
            <p>
              The math on metal roofing is simple and most contractors would rather you
              not run it. A standing seam metal roof installed today costs more upfront than
              architectural shingles. Stretched over 50 years of service life versus two or
              three asphalt replacement cycles, the per-year cost often lands lower — and
              that figure does not account for energy savings from metal's reflective surface
              or the insurance premium reductions available to homeowners in hail-belt markets
              who upgrade to a Class 4 system.
            </p>
            <p>
              Pro Exteriors installs metal roofing for homes across Texas, Colorado, Kansas,
              Missouri, and Georgia as a trusted <a href="/residential" class="underline decoration-slate-300 hover:decoration-slate-900 transition-colors">residential roofing contractor</a>
              serving the region for more than 15 years. Our crews work with Galvalume standing
              seam, stone-coated steel systems, and corrugated profiles — the right system
              depends on the home's architecture, the local weather profile, and the budget.
              That recommendation starts with a free assessment, not a sales pitch.
            </p>
          </div>
          <div class="mt-8 flex flex-wrap gap-3">
            <span class="px-4 py-2 rounded-full bg-slate-100 text-slate-800 text-sm font-bold">GAF Certified Installer</span>
            <span class="px-4 py-2 rounded-full bg-slate-100 text-slate-800 text-sm font-bold">50-Year Panel Warranty</span>
            <span class="px-4 py-2 rounded-full bg-slate-100 text-slate-800 text-sm font-bold">Class 4 Impact Resistant</span>
          </div>
        </div>
        <div class="relative rounded-2xl overflow-hidden aspect-[4/3]">
          <img
            src="/images/placeholders/service-overview-metal.jpg"
            alt="Close-up of standing seam metal roof panels with raised seams catching afternoon light"
            class="w-full h-full object-cover"
            loading="lazy"
            width="800"
            height="600"
          />
        </div>
      </div>
    </section>

    {/* ══════ SYSTEMS GRID ════════════════════════════════════════════════════ */}
    <section id="systems" aria-label="Metal roofing system options" class="py-20 lg:py-28 bg-stone-50">
      <div class="mx-auto max-w-screen-xl px-6 lg:px-8">
        <div class="text-center max-w-3xl mx-auto mb-14">
          <p class="text-sm font-bold uppercase tracking-widest text-red-700">METAL ROOFING SYSTEMS</p>
          <h2 class="mt-4 text-4xl lg:text-5xl font-black text-slate-900">Three Systems. One Certified Installer.</h2>
          <p class="mt-4 text-xl text-slate-600">Metal roofing is not a single product. Here are the three systems we install and when each makes the most sense.</p>
        </div>
        <div class="grid md:grid-cols-2 lg:grid-cols-3 gap-8">
          {systems.map(sys => (
            <article class="bg-white rounded-2xl overflow-hidden shadow-sm hover:shadow-md transition-shadow border border-stone-100">
              <div class="aspect-[4/3] overflow-hidden relative">
                <img src={sys.img} alt={sys.alt} class="w-full h-full object-cover" loading="lazy" width="400" height="300" />
                {sys.eyebrow && (
                  <span class="absolute top-4 left-4 px-3 py-1 rounded text-xs font-bold bg-red-700 text-white uppercase tracking-wide">{sys.eyebrow}</span>
                )}
              </div>
              <div class="p-6">
                <h3 class="text-xl font-black text-slate-900">{sys.h3}</h3>
                <p class="mt-3 text-base text-slate-700 leading-relaxed">{sys.body}</p>
                <ul class="mt-4 space-y-1">
                  {sys.specs.map(spec => (
                    <li class="flex items-start gap-2 text-sm text-slate-600">
                      <Icon name="check-circle" class="w-4 h-4 text-red-700 mt-0.5 flex-shrink-0" />
                      <span>{spec}</span>
                    </li>
                  ))}
                </ul>
              </div>
            </article>
          ))}
        </div>
      </div>
    </section>

    {/* ══════ LOCAL EXPERTS PROOF ════════════════════════════════════════════ */}
    <section aria-label="Metal roofing experience and customer testimonial" class="py-20 lg:py-28 bg-white">
      <div class="mx-auto max-w-screen-xl px-6 lg:px-8 grid lg:grid-cols-2 gap-12 lg:gap-20 items-start">
        <div>
          <p class="text-sm font-bold uppercase tracking-widest text-red-700">FIVE STATES. ONE CREW.</p>
          <h2 class="mt-4 text-4xl lg:text-5xl font-black leading-tight text-slate-900">Metal Roofing Expertise in Every Market We Serve</h2>
          <p class="mt-6 text-lg text-slate-700 leading-relaxed">
            Metal roofing installation is a specialty within a specialty. The thermal
            expansion tolerances on a standing seam panel in a Colorado mountain climate
            are different from those on a Texas ranch. Our crews have installed metal
            roofing across the hail belt — Richardson and Euless in Texas, the Denver
            foothills in Colorado, Wichita in Kansas — and we bring the same installation
            standards to every state we operate in.
          </p>
          <div class="mt-10 grid grid-cols-3 gap-6">
            {[
              { value: "15+", label: "Years in Business" },
              { value: "50+", label: "Year Panel Warranty" },
              { value: "5",   label: "States Served" },
            ].map(stat => (
              <div class="text-center">
                <div class="text-5xl font-black text-red-700">{stat.value}</div>
                <div class="mt-2 text-sm font-bold text-slate-600 uppercase tracking-wide">{stat.label}</div>
              </div>
            ))}
          </div>
        </div>
        <blockquote class="bg-stone-50 rounded-2xl p-8 border border-stone-100">
          <div class="flex gap-1 mb-6">{[1,2,3,4,5].map(() => <Icon name="star" class="w-5 h-5 text-amber-400" />)}</div>
          <p class="text-lg text-slate-800 leading-relaxed italic">
            "[REPRESENTATIVE — NOT YET SOURCED: Real customer testimonial, metal roofing installation, any served state. Signed release required before ship.]"
          </p>
          <footer class="mt-6 flex items-center gap-4">
            <div class="w-16 h-16 rounded-full overflow-hidden bg-stone-200 flex-shrink-0">
              <img src="/images/placeholders/testimonial-metal.jpg" alt="Completed metal roof project by Pro Exteriors" class="w-full h-full object-cover" loading="lazy" width="64" height="64" />
            </div>
            <div>
              <p class="font-bold text-slate-900">[REPRESENTATIVE — Customer Name]</p>
              <p class="text-sm text-slate-500">[City, State, Year]</p>
            </div>
          </footer>
        </blockquote>
      </div>
    </section>

    {/* ══════ PROCESS ════════════════════════════════════════════════════════ */}
    <section aria-label="Metal roof installation process" class="py-20 lg:py-28 bg-stone-50">
      <div class="mx-auto max-w-screen-xl px-6 lg:px-8">
        <div class="text-center mb-14">
          <p class="text-sm font-bold uppercase tracking-widest text-red-700">HOW IT WORKS</p>
          <h2 class="mt-4 text-4xl lg:text-5xl font-black text-slate-900">From Structural Check to Warranty Transfer — Four Steps.</h2>
          <p class="mt-4 text-xl text-slate-600">Metal roofing is a long-term investment. Our process is designed to make sure you get the right system, installed correctly, with documentation that holds up for 50 years.</p>
        </div>
        <div class="grid md:grid-cols-2 lg:grid-cols-4 gap-8">
          {processSteps.map(step => (
            <div class="bg-white rounded-2xl p-6 shadow-sm border border-stone-100">
              <div class="w-12 h-12 rounded-xl bg-red-700 flex items-center justify-center mb-4">
                <Icon name={step.icon} class="w-6 h-6 text-white" />
              </div>
              <div class="text-xs font-black text-slate-400 uppercase tracking-widest mb-2">Step {step.num}</div>
              <h3 class="text-lg font-black text-slate-900 mb-3">{step.title}</h3>
              <p class="text-sm text-slate-700 leading-relaxed">{step.body}</p>
            </div>
          ))}
        </div>
        <div class="mt-12 text-center">
          <a
            href="/contact?intent=metal-roof-assessment&source=metal-roofing-process"
            class="inline-flex items-center justify-center px-8 py-4 rounded-lg bg-red-700 hover:bg-red-800 text-white text-lg font-bold transition-colors"
            data-event-action="cta-click"
            data-event-label="process-cta"
            data-event-category="metal-roofing"
          >Schedule Your Free Assessment</a>
        </div>
      </div>
    </section>

    {/* ══════ CASE STUDIES ════════════════════════════════════════════════════ */}
    <section aria-label="Recent metal roofing projects" class="py-20 lg:py-28 bg-white">
      <div class="mx-auto max-w-screen-xl px-6 lg:px-8">
        <div class="text-center mb-14">
          <p class="text-sm font-bold uppercase tracking-widest text-red-700">RECENT PROJECTS</p>
          <h2 class="mt-4 text-4xl lg:text-5xl font-black text-slate-900">Metal Roofing Installations Across Five States</h2>
          <p class="mt-4 text-xl text-slate-600">Real projects. Documented from tearoff to final inspection.</p>
        </div>
        <div class="grid md:grid-cols-2 lg:grid-cols-3 gap-8">
          {[
            { state: "Colorado", tag: "Standing Seam", title: "[REPRESENTATIVE — CO Project: Standing Seam Upgrade, Denver Foothills]", desc: "[REPRESENTATIVE — NOT YET SOURCED]", img: "/images/placeholders/case-metal-co.jpg", alt: "Completed standing seam metal roof in Colorado by Pro Exteriors" },
            { state: "Texas",    tag: "Stone-Coated Steel", title: "[REPRESENTATIVE — TX Project: Stone-Coated Steel, Hail-Resistant]", desc: "[REPRESENTATIVE — NOT YET SOURCED]", img: "/images/placeholders/case-metal-tx.jpg", alt: "Completed stone-coated metal roof in Texas by Pro Exteriors" },
            { state: "Kansas",   tag: "Metal Roofing", title: "[REPRESENTATIVE — KS/MO Project: Metal Roof Installation]", desc: "[REPRESENTATIVE — NOT YET SOURCED]", img: "/images/placeholders/case-metal-ks.jpg", alt: "Completed metal roof in Kansas by Pro Exteriors" },
          ].map(cs => (
            <article class="rounded-2xl overflow-hidden border border-stone-100 shadow-sm hover:shadow-md transition-shadow">
              <div class="aspect-[3/2] overflow-hidden">
                <img src={cs.img} alt={cs.alt} class="w-full h-full object-cover" loading="lazy" width="600" height="400" />
              </div>
              <div class="p-6">
                <div class="flex items-center gap-3 mb-3">
                  <span class="px-3 py-1 rounded text-xs font-bold bg-slate-900 text-white uppercase tracking-wide">{cs.state}</span>
                  <span class="px-3 py-1 rounded text-xs font-bold bg-stone-100 text-slate-700 uppercase tracking-wide">{cs.tag}</span>
                </div>
                <h3 class="text-lg font-black text-slate-900 mb-2">{cs.title}</h3>
                <p class="text-sm text-slate-600">{cs.desc}</p>
              </div>
            </article>
          ))}
        </div>
        <div class="mt-10 text-center">
          <a href="/projects" class="text-base font-bold text-slate-900 underline decoration-slate-300 hover:decoration-slate-900 transition-colors">See All Projects</a>
