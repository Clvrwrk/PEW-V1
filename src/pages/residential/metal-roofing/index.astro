    {/* ══════ FINAL CTA ══════════════════════════════════════════════════════ */}
    <section
      aria-label="Schedule your free metal roof assessment"
      class="relative isolate overflow-hidden py-24 lg:py-32 text-white"
      style="background-color: var(--color-surface-dark, #0f172a);"
    >
      <div class="absolute inset-0 -z-10">
        <img src="/images/placeholders/final-cta-metal.jpg" alt="" class="w-full h-full object-cover opacity-10" loading="lazy" width="1920" height="600" />
      </div>
      <div class="mx-auto max-w-screen-xl px-6 lg:px-8 text-center">
        <p class="text-sm font-bold uppercase tracking-widest text-red-400">START HERE</p>
        <h2 class="mt-4 text-4xl lg:text-6xl font-black max-w-3xl mx-auto">Your Metal Roof Assessment Starts with a Phone Call or a Form.</h2>
        <p class="mt-6 text-xl text-slate-300 max-w-2xl mx-auto">
          We will assess your home's structure, walk you through the right system for your climate and budget, and give you a line-item estimate. No pressure. No commission. An honest answer from a certified crew.
        </p>
        <div class="mt-10 flex flex-col sm:flex-row items-center justify-center gap-4">
          <a
            href="/contact?intent=metal-roof-assessment&source=metal-roofing-final-cta"
            class="inline-flex items-center justify-center px-10 py-4 rounded-lg bg-red-700 hover:bg-red-800 text-white text-lg font-bold transition-colors"
