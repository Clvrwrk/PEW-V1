    {/* ══════ COST / VALUE ════════════════════════════════════════════════════ */}
    <section aria-label="Metal roofing cost and value" class="py-20 lg:py-28 bg-stone-50">
      <div class="mx-auto max-w-screen-xl px-6 lg:px-8 grid lg:grid-cols-2 gap-12 lg:gap-20 items-center">
        <div class="relative rounded-2xl overflow-hidden aspect-[4/3]">
          <img src="/images/placeholders/metal-aerial.jpg" alt="Metal roof panels on a residential home, wide aerial view showing full coverage" class="w-full h-full object-cover" loading="lazy" width="800" height="600" />
        </div>
        <div>
          <p class="text-sm font-bold uppercase tracking-widest text-red-700">COST & VALUE</p>
          <h2 class="mt-4 text-4xl lg:text-5xl font-black leading-tight text-slate-900">The Most Expensive Roof You'll Ever Buy. The Last One You'll Buy.</h2>
          <p class="mt-6 text-lg text-slate-700 leading-relaxed">
            Metal roofing costs more upfront than asphalt — that is a fact and we
            do not pretend otherwise. Over a 50-year window, a standing seam metal roof
            eliminates one or two full replacement cycles. Add the energy savings from
            reflective metal surfaces and the transferable warranty that adds documented
            value at the point of home sale — and the math usually favors metal for
            homeowners who plan to stay in the house.
          </p>
          <ul class="mt-6 space-y-3">
            {[
              "Standing seam: [REPRESENTATIVE — insert Pro Exteriors range] installed",
              "Stone-coated steel: [REPRESENTATIVE — insert Pro Exteriors range] installed",
              "Corrugated: [REPRESENTATIVE — insert Pro Exteriors range] installed",
              "Financing available through third-party lenders for qualified homeowners [REPRESENTATIVE — confirm lender]",
            ].map(item => (
              <li class="flex items-start gap-3">
                <Icon name="check-circle" class="w-5 h-5 text-red-700 mt-0.5 flex-shrink-0" />
                <span class="text-slate-700">{item}</span>
              </li>
            ))}
          </ul>
          <div class="mt-8">
            <a
              href="/contact?intent=metal-roof-assessment&source=metal-roofing-cost"
              class="inline-flex items-center justify-center px-8 py-4 rounded-lg border-2 border-slate-900 text-slate-900 text-base font-bold hover:bg-slate-900 hover:text-white transition-colors"
              data-event-action="cta-click"
              data-event-label="cost-cta"
              data-event-category="metal-roofing"
            >Get a Line-Item Estimate</a>
          </div>
        </div>
      </div>
    </section>

    {/* ══════ FAQ ════════════════════════════════════════════════════════════ */}
    <section aria-label="Metal roofing FAQ" class="py-20 lg:py-28 bg-white">
      <div class="mx-auto max-w-screen-xl px-6 lg:px-8 max-w-3xl mx-auto">
        <div class="text-center mb-14">
          <p class="text-sm font-bold uppercase tracking-widest text-red-700">FREQUENTLY ASKED</p>
          <h2 class="mt-4 text-4xl lg:text-5xl font-black text-slate-900">Your Metal Roof Questions, Answered.</h2>
        </div>
