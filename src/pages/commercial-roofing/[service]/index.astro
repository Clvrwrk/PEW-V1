---
/**
 * src/pages/commercial-roofing/[service]/index.astro
 * Commercial service-detail template — magazine-quality layout.
 *
 * When structured frontmatter fields (intro, benefits, processSteps, etc.)
 * are present, the page renders rich visual sections matching the Figma
 * reference design. When absent, sections are skipped and the MDX body
 * renders as a prose article — graceful degradation for services that
 * haven't been populated yet.
 */
import { getCollection, type CollectionEntry } from 'astro:content';
import BaseLayout from '../../../components/seo/BaseLayout.astro';
import ServiceHero from '../../../components/molecules/ServiceHero.astro';
import SplitIntro from '../../../components/molecules/SplitIntro.astro';
import BenefitsGrid from '../../../components/molecules/BenefitsGrid.astro';
import StructureTypes from '../../../components/molecules/StructureTypes.astro';
import QualityProcess from '../../../components/molecules/QualityProcess.astro';
import ProjectGallery from '../../../components/molecules/ProjectGallery.astro';
import CTABanner from '../../../components/molecules/CTABanner.astro';
import FAQ from '../../../components/molecules/FAQ.astro';
import Card from '../../../components/molecules/Card.astro';
import ServiceTile from '../../../components/molecules/ServiceTile.astro';
import ServiceCard from '../../../components/molecules/ServiceCard.astro';
import CaseStudyCard from '../../../components/molecules/CaseStudyCard.astro';
import PartnerNetworkDisclosure from '../../../components/atoms/PartnerNetworkDisclosure.astro';
import { serviceSchema } from '../../../lib/schema/Service';
import { breadcrumbSchema } from '../../../lib/schema/BreadcrumbList';
import { faqPageSchema } from '../../../lib/schema/FAQPage';

export async function getStaticPaths() {
  const urlSegment = (canonicalPath: string): string =>
    canonicalPath.replace(/\/$/, '').split('/').pop() ?? '';

  const services = await getCollection('services', ({ data }) => data.vertical === 'commercial');
  return services.map((entry) => ({
    params: { service: urlSegment(entry.data.canonicalPath) },
    props: { entry },
  }));
}

interface Props {
  entry: CollectionEntry<'services'>;
}

const { entry } = Astro.props;
const { Content } = await entry.render();
const data = entry.data;

// Detect whether this service has magazine-quality structured data
const hasMagazineLayout = !!(data.intro || data.benefits || data.processSteps);

// Sibling services for cross-sell (up to 4 for the magazine layout)
const allCommercial = await getCollection('services', ({ data: d }) => d.vertical === 'commercial');
const siblings = allCommercial
  .filter((s) => s.slug !== entry.slug)
  .slice(0, 4);

// Case studies for this vertical
const caseStudies = await getCollection('caseStudies', ({ data: d }) => d.industryCategory === 'commercial');
const topStudies = caseStudies.slice(0, 2);

const breadcrumbs = [
  { label: 'Commercial Roofing', href: '/commercial-roofing/' },
  { label: data.name, href: data.canonicalPath },
];

const schemaPayload: Record<string, any>[] = [
  serviceSchema(
    { name: data.name, description: data.description, url: data.canonicalPath },
    'Pro Exteriors',
  ),
  breadcrumbSchema([{ label: 'Home', href: '/' }, ...breadcrumbs]),
];
if (data.faqs && data.faqs.length > 0) {
  schemaPayload.push(faqPageSchema(data.faqs));
}
---

<BaseLayout
  title={data.title}
  description={data.description}
  canonicalPath={data.canonicalPath}
  jsonLd={schemaPayload}
>
  {/* ── 1. Hero ───────────────────────────────────────── */}
  <ServiceHero
    title={data.h1}
    image={data.heroImage}
    video={data.heroVideo}
    breadcrumbs={breadcrumbs}
  />

  {hasMagazineLayout ? (
    <>
      {/* ── 2. Intro split ──────────────────────────────── */}
      {data.intro && (
        <SplitIntro
          heading={data.intro.heading}
          body={data.intro.body}
          image={data.intro.image}
          badges={data.intro.badges}
        />
      )}

      {/* ── 3. Benefits grid ────────────────────────────── */}
      {data.benefits && (
        <BenefitsGrid
          heading={data.benefits.heading}
          subtitle={data.benefits.subtitle}
          items={data.benefits.items}
        />
      )}

      {/* ── 4. Structure types ──────────────────────────── */}
      {data.structureTypes && (
        <StructureTypes
          heading={data.structureTypes.heading}
          items={data.structureTypes.items}
        />
      )}

      {/* ── 5. Quality process ──────────────────────────── */}
      {data.processSteps && (
        <QualityProcess
          heading={data.processSteps.heading}
          image={data.processSteps.image}
          steps={data.processSteps.steps}
        />
      )}

      {/* ── 6. Project gallery ──────────────────────────── */}
      {data.galleryImages && data.galleryImages.length > 0 && (
        <ProjectGallery
          heading={`Completed ${data.name} Projects`}
          images={data.galleryImages}
        />
      )}

      {/* ── 7. Case studies ──────────────────────────────── */}
      {topStudies.length > 0 && (
        <section class="py-16 sm:py-24">
          <div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8">
            <div class="flex items-baseline justify-between mb-12">
              <div>
                <h2 class="text-3xl font-display font-bold tracking-tight text-text-primary">Case Studies</h2>
                <p class="mt-2 text-text-secondary">Real world results for our partners.</p>
              </div>
              <a href="/projects/" class="hidden sm:inline-flex text-sm font-medium text-accent hover:underline">
                View All Stories &rarr;
              </a>
            </div>
            <div class="grid grid-cols-1 md:grid-cols-2 gap-8">
              {topStudies.map((study) => (
                <CaseStudyCard
                  title={study.data.projectName}
                  description={study.data.description}
                  href={study.data.canonicalPath}
                  image={study.data.heroImage ?? '/images/projects/tpo-gallery-1.webp'}
                  industryTag={study.data.industryTag ?? study.data.industryCategory.toUpperCase()}
                  industryIcon={study.data.industryIcon ?? 'building'}
                  stats={study.data.stats ?? []}
                />
              ))}
            </div>
          </div>
        </section>
      )}

      {/* ── 7.5. Editorial body ──────────────────────────────
         Magazine layouts can ALSO carry a long-form prose body in the
         markdown (deeper editorial: tables, pull-quotes, "Why us", etc.).
         Render only if the entry actually has body content beyond the
         frontmatter. */}
      {entry.body && entry.body.trim().length > 50 && (
        <article class="prose prose-slate mx-auto max-w-3xl px-4 py-16">
          <Content />
        </article>
      )}
    </>
  ) : (
    <>
      {/* ── Fallback: prose MDX body ────────────────────── */}
      <article class="prose mx-auto max-w-3xl px-4 py-16">
        <Content />
      </article>

      {data.partnerFulfilled && (
        <div class="mx-auto max-w-3xl px-4 pb-8">
          <PartnerNetworkDisclosure />
        </div>
      )}
    </>
  )}

  {/* ── 8. Service FAQ ───────────────────────────────── */}
  {data.faqs && data.faqs.length > 0 && (
    <section class="py-16 sm:py-24">
      <div class="mx-auto max-w-4xl px-4">
        <h2 class="mb-12 text-center text-3xl font-display font-bold tracking-tight text-text-primary">Service FAQ</h2>
        <FAQ faqs={data.faqs} />
      </div>
    </section>
  )}

  {/* ── 9. Other commercial services ─────────────────── */}
  {siblings.length > 0 && (
    <section class="py-16 sm:py-24 bg-surface-inset">
      <div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8">
        <h2 class="mb-12 text-center text-3xl font-display font-bold tracking-tight text-text-primary">Other Commercial Solutions</h2>
        <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 gap-6">
          {siblings.map((sibling) => (
            <ServiceCard
              title={sibling.data.name}
              description={sibling.data.description}
              href={sibling.data.canonicalPath}
              image={sibling.data.heroImage}
              icon={sibling.data.cardIcon ?? 'building'}
              eyebrow="COMMERCIAL"
            />
          ))}
        </div>
      </div>
    </section>
  )}

  {/* ── 10. CTA banner ───────────────────────────────── */}
  {data.ctaBanner ? (
    <CTABanner
      heading={data.ctaBanner.heading}
      subtitle={data.ctaBanner.subtitle}
      ctaText={data.ctaBanner.ctaText}
      ctaHref={data.ctaBanner.ctaHref}
    />
  ) : (
    <CTABanner
      heading={`Ready to discuss ${data.name.toLowerCase()}?`}
      subtitle="Talk to a specialist about your commercial roofing needs."
      ctaText="Get a Quote"
      ctaHref="/contact/?vertical=commercial"
    />
  )}
</BaseLayout>
