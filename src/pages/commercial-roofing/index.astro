          class="inline-flex items-center justify-center px-8 py-5 bg-white text-red-700 text-lg font-black rounded-lg hover:bg-stone-100 transition-colors focus:outline-none focus:ring-4 focus:ring-white focus:ring-offset-2 focus:ring-offset-red-700 whitespace-nowrap shadow-lg lg:flex-shrink-0"
          data-cta-name="reliability_cta_schedule"
        >
          Schedule Mine →
        </a>
      </aside>
    </div>
  </section>

  <!-- ════════════════════════════════════════════════════════════════════════
       INSTITUTIONAL CASE STUDIES — bento layout (3 real cases + CTA card)
       Per Chris's intake decision: replaced 4 fictional Figma cases + Gold
       Standard testimonial with the 3 real Pro Exteriors TPO case studies.
  ════════════════════════════════════════════════════════════════════════════ -->
  <section class="bg-stone-100 py-24 px-6 lg:px-8" aria-labelledby="cases-heading">
    <div class="max-w-7xl mx-auto flex flex-col gap-16">
      <header class="flex flex-col items-center text-center gap-4">
        <h2 id="cases-heading" class="text-4xl font-black text-slate-900 leading-tight">Institutional Case Studies</h2>
        <p class="text-lg text-slate-600 leading-7">Proven performance across diverse industry sectors.</p>
      </header>

      <!--
        Bento — 2-row × 3-col grid with EVERY CELL FILLED (no orphan cells).
        Round-3 fix: the prior asymmetric layout left col-2 of row-2 empty,
        producing the unbalanced look Chris flagged.

        Layout (lg breakpoint):
          Row 1:  TechPark spans cols 1-2 (wide landscape) | CTA spans col 3 row 1-2
          Row 2:  Fort Worth col 1 (square)                | Dallas Mall col 2 (square) | CTA continues
          Row 3:  ─ closed ─

        Total tiles = 4 (3 cases + 1 CTA), 6 cells, 0 orphans.
        Mobile collapses to single-column stack in source order.
      -->
      <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6 lg:auto-rows-[300px]">

        <!-- Card 1: TechPark — wide landscape, top-left, spans 2 cols -->
        <a
          href={caseStudies[0].href}
          class="group relative block rounded-xl overflow-hidden h-80 md:h-auto lg:col-span-2 lg:row-span-1 focus:outline-none focus:ring-4 focus:ring-red-400 focus:ring-offset-2"
          data-cta-name={caseStudies[0].ctaName}
        >
          <img src={caseStudies[0].image} alt={caseStudies[0].alt} class="absolute inset-0 w-full h-full object-cover transition-transform duration-500 group-hover:scale-105" loading="lazy" decoding="async" />
          <div class="absolute inset-0 bg-gradient-to-t from-slate-900/95 via-slate-900/40 to-slate-900/0"></div>
          <span class="absolute top-6 left-6 px-3 py-1 bg-white text-slate-900 text-xs font-black uppercase tracking-wider">{caseStudies[0].industryTag}</span>
          <div class="absolute bottom-6 left-6 right-6 flex flex-col gap-2">
            <h3 class="text-2xl font-bold text-white leading-8">{caseStudies[0].heading}</h3>
            <p class="text-sm text-white/80 leading-5">{caseStudies[0].summary}</p>
          </div>
        </a>

        <!-- Card 4: Vertical CTA — col 3, spans both rows, full height -->
        <div class="bg-red-700 rounded-xl h-80 md:h-auto lg:col-span-1 lg:row-span-2 flex flex-col items-center justify-center text-center p-8 gap-6">
          <div class="flex flex-col gap-3">
            <h3 class="text-2xl font-black text-white leading-8">Your Project Next?</h3>
            <p class="text-sm text-white/90 leading-5">Submit a quick RFQ and a project manager will be on your roof within two business days.</p>
          </div>
          <div class="flex flex-col gap-3 w-full">
            <a
              href="/contact/?vertical=commercial&intent=rfp"
              class="inline-flex items-center justify-center px-6 py-3 bg-white text-slate-900 text-sm font-bold rounded hover:bg-stone-100 transition-colors focus:outline-none focus:ring-2 focus:ring-white focus:ring-offset-2 focus:ring-offset-red-700"
              data-cta-name="cases_submit_rfp"
            >
              Submit RFP
            </a>
            <a
              href="#assessment-form"
              class="inline-flex items-center justify-center px-6 py-3 bg-transparent text-white text-sm font-bold rounded border-2 border-white hover:bg-white/10 transition-colors focus:outline-none focus:ring-2 focus:ring-white focus:ring-offset-2 focus:ring-offset-red-700"
              data-cta-name="cases_request_assessment"
            >
              Request Assessment
            </a>
          </div>
        </div>

        <!-- Card 2: Fort Worth — square, row-2 col-1 -->
        <a
          href={caseStudies[2].href}
          class="group relative block rounded-xl overflow-hidden h-80 md:h-auto lg:col-span-1 lg:row-span-1 focus:outline-none focus:ring-4 focus:ring-red-400 focus:ring-offset-2"
          data-cta-name={caseStudies[2].ctaName}
        >
          <img src={caseStudies[2].image} alt={caseStudies[2].alt} class="absolute inset-0 w-full h-full object-cover transition-transform duration-500 group-hover:scale-105" loading="lazy" decoding="async" />
          <div class="absolute inset-0 bg-gradient-to-t from-slate-900/95 via-slate-900/40 to-slate-900/0"></div>
          <span class="absolute top-6 left-6 px-3 py-1 bg-white text-slate-900 text-xs font-black uppercase tracking-wider">{caseStudies[2].industryTag}</span>
          <div class="absolute bottom-6 left-6 right-6 flex flex-col gap-2">
            <h3 class="text-xl font-bold text-white leading-7">{caseStudies[2].heading}</h3>
            <p class="text-sm text-white/80 leading-5">{caseStudies[2].summary}</p>
          </div>
        </a>

        <!-- Card 3: Dallas North Mall — square, row-2 col-2 (was wide landscape; resized to fill the cell that was orphaned) -->
        <a
          href={caseStudies[1].href}
          class="group relative block rounded-xl overflow-hidden h-80 md:h-auto lg:col-span-1 lg:row-span-1 focus:outline-none focus:ring-4 focus:ring-red-400 focus:ring-offset-2"
          data-cta-name={caseStudies[1].ctaName}
        >
          <img src={caseStudies[1].image} alt={caseStudies[1].alt} class="absolute inset-0 w-full h-full object-cover transition-transform duration-500 group-hover:scale-105" loading="lazy" decoding="async" />
          <div class="absolute inset-0 bg-gradient-to-t from-slate-900/95 via-slate-900/40 to-slate-900/0"></div>
          <span class="absolute top-6 left-6 px-3 py-1 bg-white text-slate-900 text-xs font-black uppercase tracking-wider">{caseStudies[1].industryTag}</span>
          <div class="absolute bottom-6 left-6 right-6 flex flex-col gap-2">
            <h3 class="text-xl font-bold text-white leading-7">{caseStudies[1].heading}</h3>
            <p class="text-sm text-white/80 leading-5">{caseStudies[1].summary}</p>
          </div>
        </a>

      </div>

      <div class="text-center">
        <a
          href="/projects/"
          class="inline-flex items-center gap-2 text-red-700 font-bold hover:text-red-800 focus:outline-none focus:ring-2 focus:ring-red-400 focus:ring-offset-2"
          data-cta-name="cases_view_all"
        >
          View All Projects
          <Icon name="arrow-right" size={16} class="flex-shrink-0" />
        </a>
      </div>
    </div>
  </section>

  <!-- ════════════════════════════════════════════════════════════════════════
       DALLAS ROOTED, NATIONWIDE REACH — full-width map (matches /locations/)
       Per Chris's revision: removed the left copy column; map is now the
       full-width primary surface, headed by a centered title + subhead the
       same way /pages/locations/index.astro renders it.
  ════════════════════════════════════════════════════════════════════════════ -->
  <section id="reach" class="py-20 bg-surface-inset overflow-hidden" aria-labelledby="reach-heading">
    <div class="max-w-7xl mx-auto px-4">
      <div class="text-center mb-12">
        <h2 id="reach-heading" class="text-3xl font-bold text-slate-900">Dallas Rooted. Nationwide Reach.</h2>
        <p class="text-text-secondary mt-4 text-lg">
          Click any office pin to view details and dispatch the closest team.
        </p>
      </div>
      <div class="bg-surface-elevated p-4 rounded-3xl shadow-xl ring-1 ring-border">
        <OfficeLocationsMap client:visible />
      </div>
    </div>
  </section>

  <!-- ════════════════════════════════════════════════════════════════════════
       COMMERCIAL FAQ — 3 questions in accordion (FAQ molecule handles a11y)
  ════════════════════════════════════════════════════════════════════════════ -->
  <section class="bg-stone-100 py-24 px-6 lg:px-8" aria-labelledby="faq-heading">
    <div class="max-w-3xl mx-auto flex flex-col gap-12">
      <h2 id="faq-heading" class="text-3xl font-black text-slate-900 text-center leading-9">Commercial FAQ</h2>
      <FAQ faqs={faqs} />
    </div>
  </section>

  <!-- ════════════════════════════════════════════════════════════════════════
       GET YOUR EXECUTIVE ROOF ASSESSMENT — inline form posting to /api/lead
       Figma's 4 qualifying fields are preserved, plus required contact fields
       (firstName/lastName/email/phone) the existing API endpoint requires.
       Qualifying fields concatenate into projectDetails before POST.
  ════════════════════════════════════════════════════════════════════════════ -->
  <section id="assessment-form" class="bg-slate-900 py-24 px-6 lg:px-8" aria-labelledby="assessment-heading">
    <div class="max-w-3xl mx-auto flex flex-col gap-8">
      <header class="flex flex-col gap-6">
        <h2 id="assessment-heading" class="text-4xl font-black text-white leading-tight">
          Get Your Executive Roof Assessment
        </h2>
        <p class="text-lg text-white/80 leading-7">
          Schedule a comprehensive analysis of your facility's current roof
          condition. Our reports include thermal imaging, core samples, and a
          multi-year maintenance roadmap. No commitment. Real diagnostic.
        </p>
        <div class="flex items-center gap-4">
          <div class="flex" aria-hidden="true">
            <span class="w-12 h-12 bg-blue-100 rounded-full ring-2 ring-slate-900 flex items-center justify-center text-slate-900 font-bold">JD</span>
            <span class="w-12 h-12 -ml-3 bg-blue-100 rounded-full ring-2 ring-slate-900 flex items-center justify-center text-slate-900 font-bold">SM</span>
            <span class="w-12 h-12 -ml-3 bg-blue-100 rounded-full ring-2 ring-slate-900 flex items-center justify-center text-slate-900 font-bold">RK</span>
          </div>
          <p class="text-sm text-white">
            <span class="text-red-400 font-semibold">Expert consultation</span> ready for your call.
          </p>
        </div>
      </header>

      <form
        id="executive-assessment-form"
        class="bg-white rounded-2xl p-10 flex flex-col gap-6 shadow-2xl"
        novalidate
      >
        <!-- Qualifying fields (Figma design) -->
        <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
          <label class="flex flex-col gap-2">
            <span class="text-xs font-bold uppercase tracking-wider text-slate-900">Company Name</span>
            <input
              type="text"
              name="companyName"
              placeholder="e.g. Global Logistics Inc."
              required
              class="px-4 py-4 bg-gray-100 rounded-lg text-base text-slate-900 placeholder-gray-500 focus:outline-none focus:ring-2 focus:ring-red-400"
            />
          </label>

          <label class="flex flex-col gap-2">
            <span class="text-xs font-bold uppercase tracking-wider text-slate-900">Facility Type</span>
            <select
              name="facilityType"
              required
              class="px-4 py-4 bg-gray-100 rounded-lg text-base text-slate-900 focus:outline-none focus:ring-2 focus:ring-red-400"
            >
              <option value="">Select facility type</option>
              <option>Warehouse / Industrial</option>
              <option>Retail / Big Box</option>
              <option>Multi-Tenant Office</option>
              <option>Education / Institutional</option>
              <option>Healthcare</option>
              <option>Manufacturing</option>
              <option>Other</option>
            </select>
          </label>

          <label class="flex flex-col gap-2">
            <span class="text-xs font-bold uppercase tracking-wider text-slate-900">Approx. Sq. Ft.</span>
            <input
              type="number"
              name="squareFootage"
              placeholder="e.g. 100,000"
              min="0"
              required
              class="px-4 py-4 bg-gray-100 rounded-lg text-base text-slate-900 placeholder-gray-500 focus:outline-none focus:ring-2 focus:ring-red-400"
            />
          </label>

          <label class="flex flex-col gap-2">
            <span class="text-xs font-bold uppercase tracking-wider text-slate-900">Timeline</span>
            <select
              name="timeline"
              required
              class="px-4 py-4 bg-gray-100 rounded-lg text-base text-slate-900 focus:outline-none focus:ring-2 focus:ring-red-400"
            >
              <option value="">Select timeline</option>
              <option>Immediate / Emergency</option>
              <option>Within 30 days</option>
              <option>Within 90 days</option>
              <option>Planning for next budget cycle</option>
            </select>
          </label>
        </div>

        <!-- Project Details (textarea) — full freeform context for the assessment -->
        <label class="flex flex-col gap-2">
          <span class="text-xs font-bold uppercase tracking-wider text-slate-900">Project Details</span>
          <textarea
            name="projectDetailsFreeform"
            rows="4"
            placeholder="Tell us about the roof condition, recent leaks or storm damage, any deadlines from leadership or insurance, deck type if known, manufacturer warranty status, anything else worth knowing before we walk the roof."
            class="px-4 py-4 bg-gray-100 rounded-lg text-base text-slate-900 placeholder-gray-500 leading-6 focus:outline-none focus:ring-2 focus:ring-red-400 resize-y min-h-[120px]"
          ></textarea>
          <span class="text-xs text-slate-600">Optional, but the more context the sharper the assessment.</span>
        </label>

        <!-- Contact fields (required by /api/lead schema) -->
        <div class="border-t border-neutral-200 pt-6 grid grid-cols-1 md:grid-cols-2 gap-6">
          <label class="flex flex-col gap-2">
            <span class="text-xs font-bold uppercase tracking-wider text-slate-900">First Name</span>
            <input
              type="text"
              name="firstName"
              autocomplete="given-name"
              required
              class="px-4 py-4 bg-gray-100 rounded-lg text-base text-slate-900 focus:outline-none focus:ring-2 focus:ring-red-400"
            />
          </label>

          <label class="flex flex-col gap-2">
            <span class="text-xs font-bold uppercase tracking-wider text-slate-900">Last Name</span>
            <input
              type="text"
              name="lastName"
              autocomplete="family-name"
              required
              class="px-4 py-4 bg-gray-100 rounded-lg text-base text-slate-900 focus:outline-none focus:ring-2 focus:ring-red-400"
            />
          </label>

          <label class="flex flex-col gap-2">
            <span class="text-xs font-bold uppercase tracking-wider text-slate-900">Email</span>
            <input
              type="email"
              name="email"
              autocomplete="email"
              required
              class="px-4 py-4 bg-gray-100 rounded-lg text-base text-slate-900 focus:outline-none focus:ring-2 focus:ring-red-400"
            />
          </label>

          <label class="flex flex-col gap-2">
            <span class="text-xs font-bold uppercase tracking-wider text-slate-900">Phone</span>
            <input
              type="tel"
              name="phone"
              autocomplete="tel"
              required
              class="px-4 py-4 bg-gray-100 rounded-lg text-base text-slate-900 focus:outline-none focus:ring-2 focus:ring-red-400"
            />
          </label>
        </div>

        <!-- Honeypot — hidden from users; blocks bots -->
        <div class="absolute -left-[9999px]" aria-hidden="true">
          <label>
            Website (leave blank)
            <input type="text" name="website" tabindex="-1" autocomplete="off" />
          </label>
        </div>

        <!-- Hidden routing fields the API expects -->
        <input type="hidden" name="vertical"  value="commercial" />
        <input type="hidden" name="formType"  value="executive-assessment" />
        <input type="hidden" name="campaign"  value="commercial-roofing-pillar-2026-05" />

        <button
          type="submit"
          class="w-full py-4 bg-red-700 hover:bg-red-800 text-white text-lg font-black uppercase tracking-widest rounded-lg shadow-lg transition-colors focus:outline-none focus:ring-2 focus:ring-red-400 focus:ring-offset-2"
          data-cta-name="form_assessment_submit"
        >
          Send Assessment Request
        </button>

        <p class="text-center text-[10px] uppercase tracking-wide text-slate-600">
          Confidentiality assured · 24-hour response
        </p>

        <div id="form-status" role="status" aria-live="polite" class="text-center text-sm font-medium hidden"></div>
      </form>
    </div>
  </section>

  <script is:inline>
    (function () {
      const form = document.getElementById('executive-assessment-form');
      if (!form) return;
      const status = document.getElementById('form-status');

      form.addEventListener('submit', async (event) => {
        event.preventDefault();
        status.classList.add('hidden');

        const data = Object.fromEntries(new FormData(form).entries());

        // Honeypot — silent fail on bot submissions
        if (data.website && String(data.website).trim() !== '') return;

        // Compose qualifying fields + freeform textarea into the projectDetails
        // string the API expects. Qualifying fields lead so the sales team
        // sees the structured info first; the prospect's freeform text follows.
        const qualifiers = [
          data.companyName    && `Company: ${data.companyName}`,
          data.facilityType   && `Facility: ${data.facilityType}`,
          data.squareFootage  && `Approx. Sq. Ft.: ${data.squareFootage}`,
          data.timeline       && `Timeline: ${data.timeline}`,
        ].filter(Boolean).join(' · ');

        const freeform = (data.projectDetailsFreeform || '').toString().trim();
        const projectDetails = freeform
          ? `${qualifiers}\n\n— Project notes —\n${freeform}`
          : qualifiers;

        const payload = {
          firstName:      data.firstName,
          lastName:       data.lastName,
          email:          data.email,
          phone:          data.phone,
          vertical:       data.vertical,
          formType:       data.formType,
          campaign:       data.campaign,
          projectDetails,
        };

        // Fire attempt event for GA4 / GTM
        if (window.dataLayer) {
          window.dataLayer.push({
            event: 'form_submit_attempt',
            formId: 'executive-assessment',
            vertical: 'commercial',
          });
        }

        try {
          const submitBtn = form.querySelector('button[type="submit"]');
          if (submitBtn) {
            submitBtn.disabled = true;
            submitBtn.textContent = 'Sending…';
          }

          const response = await fetch('/api/lead', {
            method: 'POST',
            headers: { 'Content-Type': 'application/json' },
            body: JSON.stringify(payload),
          });

          if (!response.ok) throw new Error('Submission failed');

          if (window.dataLayer) {
            window.dataLayer.push({
              event: 'form_submit_success',
              formId: 'executive-assessment',
              vertical: 'commercial',
            });
          }

          window.location.href = '/thank-you/';
        } catch (err) {
          console.error('[ASSESSMENT FORM] Error:', err);
          status.textContent = 'Sorry — something went wrong. Please call (469) 535-1708 or try again.';
          status.classList.remove('hidden');
          status.classList.add('text-red-700');

          const submitBtn = form.querySelector('button[type="submit"]');
          if (submitBtn) {
            submitBtn.disabled = false;
            submitBtn.textContent = 'Send Assessment Request';
          }
        }
      });
    })();
  </script>

</BaseLayout>
