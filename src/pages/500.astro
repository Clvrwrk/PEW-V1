---
import BaseLayout from '../components/seo/BaseLayout.astro';
import Button from '../components/atoms/Button.astro';
---

<BaseLayout
  title="Something Went Wrong | Pro Exteriors"
  description="Pro Exteriors is experiencing a temporary issue serving this page. Please try again or contact us directly."
  canonicalPath="/500"
  noindex={true}
>
  <section class="mx-auto max-w-3xl px-4 py-24 text-center">
    <p class="text-base font-semibold text-accent">500</p>
    <h1 class="mt-4 text-4xl font-display font-bold tracking-tight text-text-primary sm:text-5xl">
      Something went wrong on our end.
    </h1>
    <p class="mt-6 text-lg text-text-secondary">
      Try again in a moment, or call us at (469) 535-1708 if it persists.
    </p>
    <div class="mt-10 flex flex-wrap justify-center gap-4">
      <Button href="/" variant="primary" size="lg">Back to Home</Button>
      <Button href="tel:4695351708" variant="secondary" size="lg">Call (469) 535-1708</Button>
    </div>
  </section>
</BaseLayout>
