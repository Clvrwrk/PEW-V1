---
/**
 * src/pages/projects/index.astro
 * Case-study hub (Step 8d).
 * URL: /projects/ — the canonical hub linked from the primary nav.
 */
import { getCollection } from 'astro:content';
import BaseLayout from '../../components/seo/BaseLayout.astro';
import HeroSection from '../../components/molecules/HeroSection.astro';
import Breadcrumb from '../../components/molecules/Breadcrumb.astro';
import Card from '../../components/molecules/Card.astro';
import { collectionPageSchema } from '../../lib/schema/CollectionPage';
import { breadcrumbSchema } from '../../lib/schema/BreadcrumbList';

const studies = await getCollection('caseStudies');
const items = studies.map((s) => ({
  name: s.data.projectName,
  url: s.data.canonicalPath,
  description: s.data.description,
}));

const breadcrumbs = [
  { label: 'Home', href: '/' },
  { label: 'Projects', href: '/projects/' },
];

const schemaPayload = [
  collectionPageSchema(items, 'Pro Exteriors Projects', 'Selected projects across commercial and residential roofing.'),
  breadcrumbSchema(breadcrumbs),
];
---

<BaseLayout
  title="Projects & Case Studies | Pro Exteriors"
  description="Selected commercial and residential roofing projects from Pro Exteriors. See how we solve real exterior problems for property leaders."
  canonicalPath="/projects/"
  jsonLd={schemaPayload}
>
  <Breadcrumb items={breadcrumbs.slice(1)} />

  <HeroSection
    title="Projects Worth Showing"
    subtitle="A growing portfolio of commercial assets and residential homes Pro Exteriors has restored, replaced, and protected."
  />

  <section class="py-20 px-4 max-w-7xl mx-auto">
    {studies.length === 0 ? (
      <p class="text-center text-text-tertiary">More projects coming soon.</p>
    ) : (
      <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-8">
        {studies.map((s) => (
          <Card
            title={s.data.projectName}
            description={s.data.description}
            eyebrow={s.data.industryCategory}
            href={s.data.canonicalPath}
          />
        ))}
      </div>
    )}
  </section>
</BaseLayout>
