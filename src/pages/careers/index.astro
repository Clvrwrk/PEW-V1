---
import BaseLayout from '../../components/seo/BaseLayout.astro';
import HeroSection from '../../components/molecules/HeroSection.astro';
import Breadcrumb from '../../components/molecules/Breadcrumb.astro';
import { breadcrumbSchema } from '../../lib/schema/BreadcrumbList';

const breadcrumbs = [
  { label: 'Home', href: '/' },
  { label: 'Careers', href: '/careers/' },
];
const schemaPayload = [breadcrumbSchema(breadcrumbs)];
---

<BaseLayout
  title="Careers at Pro Exteriors | Build a Long Career in Roofing"
  description="Pro Exteriors is hiring craftspeople, project managers, and operators. Local routes, real benefits, no storm-chasing. Open positions inside."
  canonicalPath="/careers/"
  jsonLd={schemaPayload}
>
  <Breadcrumb items={breadcrumbs.slice(1)} />
  <HeroSection
    title="Build Your Career with Pro Exteriors"
    subtitle="Local routes. Real benefits. A team that ships and a craft you can grow into."
    primaryCta={{ label: 'Email Us About Open Roles', href: 'mailto:careers@proexteriors.com' }}
  />
  <section class="py-16 px-4 max-w-3xl mx-auto">
    <p class="text-text-secondary">Phase 1 placeholder. Open positions and application flow ship in Phase 2.</p>
  </section>
</BaseLayout>
