 *     hail-damage-repair, insurance-claim-assistance, tarp-installation
 *   Tier 2 (material / upgrade): asphalt-shingles, metal-roofing, tile-clay,
 *     natural-slate, gutters, siding
 * All 11 pillar pages are now linked. Previously missing: roof-replacement,
 * storm-damage-repair, hail-damage-repair (not in grid), plus tarp-installation
 * and insurance-claim-assistance (buried in body text only).
 */
const serviceGrid = [
  // ── Tier 1: Emergency / Transactional ────────────────────────────────────
  { id: "roof-replacement",         title: "Roof Replacement",          href: "/residential-roofing/replacement/",         body: "Full residential roof replacement — tear-off, decking inspection, new underlayment, material installation, and cleanup. We install GAF, Owens Corning, and specialty systems including metal and tile. Every replacement includes a line-item estimate before a single nail goes in.", anchor: "residential roof replacement", img: "/images/placeholders/service-replacement.jpg", alt: "Pro Exteriors crew completing a full residential roof replacement — new architectural shingles being laid on a Texas home" },
  { id: "storm-damage-repair",      title: "Storm Damage Repair",       href: "/residential-roofing/storm-damage/",      body: "Hail, wind, and falling debris cause damage that isn't always visible from the ground. We inspect, document, and repair storm-damaged residential roofs across all five states. Insurance claim coordination is part of the job — we meet the adjuster on your behalf and handle the supplement process.", anchor: "storm damage roof repair", img: "/images/placeholders/service-storm.jpg", alt: "Pro Exteriors inspector documenting storm hail damage on a residential roof, close-up on dented shingle" },
  { id: "hail-damage-repair",       title: "Hail Damage Repair",        href: "/residential-roofing/storm-damage/",       body: "Hail damage is often invisible to the homeowner but material to the insurance carrier. We document impact patterns with photos, thermal imaging where applicable, and manufacturer impact-test data — the documentation package that gets claims approved rather than denied. Specialist crews across TX, CO, KS, MO, and GA.", anchor: "hail damage roof repair", img: "/images/placeholders/service-hail.jpg", alt: "Close-up of hail impact marks on asphalt shingles — bruising and granule loss pattern documented by Pro Exteriors inspector" },
  { id: "insurance-claim",          title: "Insurance Claim Assistance", href: "/contact/residential-roofing/inspection/", body: "We handle the documentation, adjuster meetings, and supplement filings that determine how much your carrier pays. Not as an upsell — as part of the project. RCV vs. ACV policy differences, depreciation holds, and code-upgrade coverage are all inside our workflow.", anchor: "insurance claim assistance for roof damage", img: "/images/placeholders/service-insurance.jpg", alt: "Pro Exteriors project manager reviewing roofing insurance claim documents with a homeowner" },
  { id: "tarp-installation",        title: "Emergency Tarping",         href: "/residential-roofing/emergency/",        body: "When a storm tears off shingles or a tree hits the roof, the clock starts. We deploy emergency tarping crews from each of our five state markets — the tarp goes on first, the full assessment follows, and you get written documentation the same day. Active leak, active storm, or post-storm standby.", anchor: "emergency roof tarp installation", img: "/images/placeholders/service-tarp.jpg", alt: "Pro Exteriors crew securing blue tarp on a storm-damaged residential roof — in-progress emergency response" },
  // ── Tier 2: Material / Upgrade ───────────────────────────────────────────
  { id: "asphalt-shingles",         title: "Asphalt Shingles",          href: "/residential-roofing/asphalt-shingles/",         body: "The most-installed residential roofing material in North America and the right answer for the majority of homes we touch. We install GAF and Owens Corning architectural shingles with the manufacturer's full warranty paperwork attached — not a builder-grade three-tab pretending to be premium. Class 4 impact-rated upgrade available in hail-belt markets like Wichita and Denver.", anchor: "asphalt shingle roofing systems", img: "/images/placeholders/service-asphalt.jpg", alt: "Close-up of properly installed architectural asphalt shingles on a residential roof, showing exposure pattern and ridge cap detail" },
  { id: "metal-roofing",            title: "Metal Roofing",             href: "/residential-roofing/metal/",            body: "Standing-seam metal is the highest-performing residential roof we install — energy-efficient, hail-resistant, with a 50-year service life that outlasts most homeowners' time in the house. Premium upfront, but the math works on a long-tenure home in a high-hail market. We install Galvalume, painted steel, and copper.", anchor: "metal roofing for homes", img: "/images/placeholders/service-metal.jpg", alt: "Standing-seam metal roof on a residential home, raised rib detail catching afternoon light" },
  { id: "tile-clay",                title: "Tile & Clay",               href: "/residential-roofing/asphalt-shingles/",        body: "Mediterranean and Spanish-tile aesthetics, fireproof construction, and a service life that can exceed 75 years on the right structural deck. Tile is heavy — we verify the framing carries the load before we quote. Common in upscale residential builds across our Texas and Atlanta markets.", anchor: "tile and clay roofing options", img: "/images/placeholders/service-tile.jpg", alt: "Spanish clay tile residential roof with detailed flashing at the ridge" },
  { id: "natural-slate",            title: "Natural Slate",             href: "/residential-roofing/asphalt-shingles/",            body: "The top of the residential roofing material pyramid. Quarried slate roofs routinely outlive the home around them. Cost matches longevity — slate is a generational investment, not a 15-year decision. We're certified to install Vermont, Pennsylvania, and Spanish slate.", anchor: "natural slate installation", img: "/images/placeholders/service-slate.jpg", alt: "Natural slate residential roof, varied gray tones, in late-day sunlight" },
  { id: "gutters",                  title: "Gutters",                   href: "/contact/residential-roofing/inspection/",         body: "Seamless aluminum gutter systems sized for actual residential roof pitch and rainfall load. We install five-inch standard and six-inch oversized systems, with leaf guards and downspout extensions engineered to handle the storm runoff in any of our markets — from Texas summer downpours to Kansas spring squalls.", anchor: "seamless gutter systems", img: "/images/placeholders/service-gutters.jpg", alt: "Newly installed seamless aluminum gutter on a residential home, downspout detail visible" },
  { id: "siding",                   title: "Siding",                    href: "/contact/residential-roofing/inspection/",                   body: "Fiber-cement and vinyl siding in coordinated colors and profiles — often quoted alongside roof replacement on storm-damage jobs because the same hailstorm that damages a roof usually damages the siding too. We bundle the work and the insurance documentation rather than asking the homeowner to manage two contractors.", anchor: "fiber-cement and vinyl siding", img: "/images/placeholders/service-siding.jpg", alt: "Fiber-cement siding installation on a residential exterior, board-and-batten profile detail" },
];

const processSteps = [
  { num: 1, icon: "search",        title: "Free inspection",     body: "Twenty-one-point check of the roof, attic ventilation, flashing, and gutter system. Photo and video documentation we share with you the same day." },
  { num: 2, icon: "clipboard",     title: "Detailed proposal",   body: "Line-item estimate covering materials, labor, decking allowance, and disposal. No surprise change orders mid-project — if we find decking damage, we bring photos and a price, then you decide." },
  { num: 3, icon: "wrench",        title: "Expert installation", body: "GAF Master Elite-certified installation methods on every job. Owens Corning Platinum protocol where the system calls for it. Our crews, not subcontractors." },
  { num: 4, icon: "shield-check",  title: "Warranty & follow-up",body: "Lifetime craftsmanship warranty, manufacturer warranty registered in your name, and a property-linked maintenance file that transfers to the next owner if you sell." },
