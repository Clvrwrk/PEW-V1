---
import { getCollection } from 'astro:content';
import BaseLayout from '../../components/seo/BaseLayout.astro';
import HeroSection from '../../components/molecules/HeroSection.astro';
import StatBand from '../../components/molecules/StatBand.astro';
import ServiceTile from '../../components/molecules/ServiceTile.astro';
import PropertyCardCallout from '../../components/molecules/PropertyCardCallout.astro';
import FAQ from '../../components/molecules/FAQ.astro';
import Breadcrumb from '../../components/molecules/Breadcrumb.astro';
import Button from '../../components/atoms/Button.astro';
import { collectionPageSchema } from '../../lib/schema/CollectionPage';
import { breadcrumbSchema } from '../../lib/schema/BreadcrumbList';

const residentialServiceEntries = await getCollection('services', ({ data }) => data.vertical === 'residential');
const residentialServices = residentialServiceEntries
  .map((entry) => ({ name: entry.data.name, url: entry.data.canonicalPath }))
  .sort((a, b) => a.name.localeCompare(b.name));

const faqs = [
  {
    question: "Do you offer free roof inspections?",
    answer: "Yes, we provide complimentary professional roof inspections for homeowners to identify potential issues or storm damage."
  },
  {
    question: "How do I know if I have storm damage?",
    answer: "Common signs include missing shingles, granule loss, bruising on shingles, or leaks inside your home. Our experts can provide a definitive assessment."
  }
];

const mainSchema = [
  collectionPageSchema(residentialServices, "Residential Roofing Services", "Premium roofing and exterior solutions for homeowners."),
  breadcrumbSchema([
    { label: "Home", href: "/" },
    { label: "Residential Roofing", href: "/residential-roofing/" }
  ])
];
---

<BaseLayout 
  title="Residential Roofing Services | Pro Exteriors" 
  description="Your local experts for residential roof replacement, repair, and storm damage restoration. Not 'storm chasers'—we're your neighbors."
  canonicalPath="/residential-roofing/"
  jsonLd={mainSchema}
>
  <Breadcrumb items={[{ label: "Home", href: "/" }, { label: "Residential Roofing", href: "/residential-roofing/" }]} />

  <HeroSection 
    title="Premium Protection for Your Family Home"
    subtitle="Expert craftsmanship meets local accountability. We're here when you need us, and we'll be here tomorrow."
    primaryCta={{ label: "Plan Your Replacement", href: "/residential-roofing/replacement/" }}
    secondaryCta={{ label: "Get a Free Inspection", href: "/contact/?vertical=residential" }}
    image="/images/residential-hero.jpg"
  />

  <section class="bg-danger-surface border-y border-danger-border py-6">
    <div class="max-w-7xl mx-auto px-4 flex flex-col md:flex-row items-center justify-between gap-6">
      <div class="flex items-center gap-4 text-danger-text">
        <div class="w-12 h-12 bg-danger-surface rounded-full flex items-center justify-center shrink-0">
          <svg class="w-6 h-6" fill="none" viewBox="0 0 24 24" stroke="currentColor">
            <path strokeLinecap="round" strokeLinejoin="round" strokeWidth={2} d="M13 10V3L4 14h7v7l9-11h-7z" />
          </svg>
        </div>
        <div>
          <h3 class="font-bold text-lg">Need Help Fast?</h3>
          <p class="text-danger-text">Recent storm damage? We can have an expert on-site within 48 hours.</p>
        </div>
      </div>
      <Button href="/contact/?type=emergency" variant="primary" class="bg-danger hover:bg-danger-hover">Request Emergency Service</Button>
    </div>
  </section>

  <StatBand 
    stats={[
      { label: "Homeowners Served", value: "3,500+", suffix: "" },
      { label: "Google Rating", value: "4.9", suffix: "/5" },
      { label: "Local Experience", value: "15", suffix: "Years" },
      { label: "Warranty Satisfaction", value: "100", suffix: "%" }
    ]}
    data-todo="source-stats"
  />

  <section class="py-20 px-4 max-w-7xl mx-auto">
    <div class="text-center mb-16">
      <h2 class="text-3xl font-bold mb-4 italic">Local Experts. Not "Storm Chasers."</h2>
      <p class="text-xl text-text-secondary max-w-3xl mx-auto text-center">We live and work in your community. Our reputation is built on quality, not volume.</p>
    </div>

    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-4 gap-6">
      {residentialServices.map(service => (
        <ServiceTile 
          title={service.name}
          description="High-quality materials and meticulous installation for your home's most critical protection."
          href={service.url}
          icon="home"
        />
      ))}
    </div>
  </section>

  <PropertyCardCallout />

  <section class="py-20 bg-surface-inset">
    <div class="max-w-4xl mx-auto px-4">
      <h2 class="text-3xl font-bold text-center mb-12">Residential Roofing FAQ</h2>
      <FAQ faqs={faqs} />
    </div>
  </section>
</BaseLayout>
