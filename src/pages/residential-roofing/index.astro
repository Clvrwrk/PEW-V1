<BaseLayout
  title={title}
  description={description}
  canonicalPath={canonicalPath}
  jsonLd={jsonLd}
>
  <a href="#main" class="sr-only focus:not-sr-only focus:absolute focus:top-2 focus:left-2 focus:z-50 focus:bg-white focus:px-4 focus:py-2 focus:rounded">Skip to main content</a>

  <main id="main">

    {/* ══════ HERO ══════════════════════════════════════════════════════════ */}
    <section
      class="relative isolate overflow-hidden text-white"
      style="min-height: 870px; background-color: var(--color-surface-dark, #0f172a);"
      aria-label="Residential roofing — Pro Exteriors"
    >
      <div class="absolute inset-0 -z-10">
        {/* IMAGE: hero-residential — [REPRESENTATIVE — NOT YET SOURCED] */}
        <img src="/images/placeholders/hero-residential.jpg" alt="" class="w-full h-full object-cover opacity-60" loading="eager" fetchpriority="high" />
        <div class="absolute inset-0 bg-gradient-to-r from-slate-900 via-slate-900/60 to-slate-900/0"></div>
      </div>
      <div class="mx-auto max-w-screen-xl px-6 lg:px-8 py-24 lg:py-32">
        <Breadcrumb items={[{ label: "Residential", href: "/residential-roofing/" }]} />
        <p class="mt-4 text-sm font-bold uppercase tracking-widest text-white/70">RESIDENTIAL ROOFING · TX · CO · KS · MO · GA</p>
        <h1 class="mt-6 text-5xl lg:text-7xl font-black leading-[1.05] max-w-3xl">Residential Roofing Contractor</h1>
        <p class="mt-6 max-w-2xl text-xl lg:text-2xl text-slate-300 leading-relaxed">
          Emergency storm response one day, premium roof replacement the next. We're a residential roofing company that operates across five states with our own crews — never subcontracted, never out-of-state storm chasers — and the receipts to back every claim on this page.
        </p>
        <div class="mt-10 flex flex-col sm:flex-row gap-4">
          <a
            href="/contact/emergency/?intent=emergency&source=residential-pillar"
            class="inline-flex items-center justify-center px-8 py-4 rounded-lg bg-red-700 hover:bg-red-800 text-white text-lg font-bold focus-visible:outline-2 focus-visible:outline-white focus-visible:outline-offset-2"
            data-event-name="cta_click"
            data-event-cta-id="hero_emergency"
            data-event-intent="emergency"
            data-event-source="residential-pillar-hero"
          >Emergency Roof Repair</a>
          <a
            href="/contact/residential-roofing/inspection/?intent=inspection&source=residential-pillar"
            class="inline-flex items-center justify-center px-8 py-4 rounded-lg border-2 border-white text-white text-lg font-bold hover:bg-white hover:text-slate-900 focus-visible:outline-2 focus-visible:outline-white focus-visible:outline-offset-2"
            data-event-name="cta_click"
            data-event-cta-id="hero_inspection"
            data-event-intent="inspection"
            data-event-source="residential-pillar-hero"
          >Plan Your New Roof</a>
        </div>
      </div>
    </section>

    {/* ══════ TRUST STRIP ════════════════════════════════════════════════════ */}
    <section aria-label="Credentials and accreditations" class="py-8 border-y border-stone-200 bg-stone-50">
      <ul class="mx-auto max-w-screen-xl px-6 lg:px-8 flex flex-wrap items-center justify-center gap-8 lg:gap-24 text-base font-bold text-slate-900">
        <li class="inline-flex items-center gap-2">
          <Icon name="star" class="w-5 h-5" />
          <span>Google 4.9/5 (240+ Reviews)</span>
          <span class="ml-1 text-xs font-normal italic text-slate-500" title="Per CLAUDE.md hard gate — not yet sourced">[REPRESENTATIVE]</span>
        </li>
        <li>BBB A+ ACCREDITED</li>
        <li>GAF MASTER ELITE&reg;</li>
        <li>CERTIFIED OWENS CORNING</li>
      </ul>
    </section>

    {/* ══════ DUAL FEATURE CARDS ════════════════════════════════════════════ */}
    <section aria-label="Emergency and planned-replacement paths" class="bg-stone-50 py-16">
      <div class="mx-auto max-w-screen-xl px-6 lg:px-8 grid gap-6 md:grid-cols-2">
        {/* Emergency card */}
        <article class="relative overflow-hidden rounded-xl min-h-[500px] flex items-end p-8 text-white isolate">
          <img src="/images/placeholders/feature-emergency.jpg" alt="Real Pro Exteriors crew installing a blue tarp on a storm-damaged residential roof — gritty, in-progress, not staged" class="absolute inset-0 w-full h-full object-cover -z-10" loading="lazy" />
          <div class="absolute inset-0 -z-10 bg-gradient-to-l from-black via-black/40 to-black/10"></div>
          <div>
            <span class="inline-flex items-center px-3 py-1 rounded text-xs font-bold bg-red-700 text-white uppercase tracking-wide">URGENT RESPONSE</span>
            <h2 class="mt-4 text-3xl font-black leading-tight">Roof damage? We're on it in 48 hours.</h2>
            <p class="mt-4 max-w-md text-base text-slate-200">Storm hits, roof leaks, deductible just doubled. Our emergency roof repair crews are deployed from each of our five state markets — Texas, Colorado, Kansas, Missouri, and Georgia — so the response time isn't contingent on a truck driving in from somewhere else. <a href="/residential-roofing/emergency/" class="underline decoration-white/40 hover:decoration-white">Tarp installation</a> happens first, full assessment follows, insurance documentation comes with us in the door.</p>
            <a href="/contact/emergency/?intent=emergency&source=residential-pillar-emergency-card"
               class="mt-6 inline-flex items-center gap-2 text-base font-bold text-white hover:underline"
               data-event-name="cta_click"
               data-event-cta-id="feature_card_emergency"
               data-event-intent="emergency"
               data-event-source="residential-pillar-emergency-card">
              Request Inspection <Icon name="arrow-right" class="w-4 h-4" />
            </a>
          </div>
        </article>

        {/* Premium card */}
        <article class="relative overflow-hidden rounded-xl min-h-[500px] flex items-end p-8 text-white isolate">
          <img src="/images/placeholders/feature-premium.jpg" alt="Real Pro Exteriors completed residential project — modern home exterior with new architectural shingles, sun on the roof line" class="absolute inset-0 w-full h-full object-cover -z-10" loading="lazy" />
          <div class="absolute inset-0 -z-10 bg-gradient-to-l from-slate-900 via-slate-900/40 to-slate-900/10"></div>
          <div>
            <span class="inline-flex items-center px-3 py-1 rounded text-xs font-bold bg-slate-900 text-white uppercase tracking-wide">PREMIUM UPGRADE</span>
            <h2 class="mt-4 text-3xl font-black leading-tight">Planning your dream roof</h2>
            <p class="mt-4 max-w-md text-base text-slate-200">The other half of residential roofing is the planned project — the twenty-year-old shingles you've been watching, the tile-to-metal conversion you've been pricing, the architectural shingle upgrade your HOA finally approved. We bring the same crews, the same warranties, and the same transparent pricing to the planned side as the emergency side.</p>
            <a href="/residential-roofing/asphalt-shingles/"
               class="mt-6 inline-flex items-center gap-2 text-base font-bold text-white hover:underline"
               data-event-name="cta_click"
               data-event-cta-id="feature_card_premium"
