---
/**
 * src/pages/blog/[slug]/index.astro
 * Blog supporter post template (Step 8b).
 * Pillar pages live alongside posts at the same URL depth so this route also
 * resolves pillar entries when a slug matches a pillar — Astro getStaticPaths
 * builds the union of both collections.
 */
import { getCollection, type CollectionEntry } from 'astro:content';
import BaseLayout from '../../../components/seo/BaseLayout.astro';
import HeroSection from '../../../components/molecules/HeroSection.astro';
import Breadcrumb from '../../../components/molecules/Breadcrumb.astro';
import FAQ from '../../../components/molecules/FAQ.astro';
import { articleSchema } from '../../../lib/schema/Article';
import { collectionPageSchema } from '../../../lib/schema/CollectionPage';
import { breadcrumbSchema } from '../../../lib/schema/BreadcrumbList';
import { faqPageSchema } from '../../../lib/schema/FAQPage';

export async function getStaticPaths() {
  const posts = await getCollection('blogPosts');
  const pillars = await getCollection('pillars');

  const postPaths = posts.map((entry) => ({
    params: { slug: entry.slug },
    props: { kind: 'post' as const, entry },
  }));

  // Filter out any pillar slug that collides with a post slug — posts win.
  const postSlugs = new Set<string>(posts.map((p) => p.slug));
  const pillarPaths = pillars
    .filter((p) => !postSlugs.has(p.slug))
    .map((entry) => ({
      params: { slug: entry.slug },
      props: { kind: 'pillar' as const, entry },
    }));

  return [...postPaths, ...pillarPaths];
}

type Props =
  | { kind: 'post'; entry: CollectionEntry<'blogPosts'> }
  | { kind: 'pillar'; entry: CollectionEntry<'pillars'> };

const { kind, entry } = Astro.props as Props;
const { Content } = await entry.render();
const data = entry.data;

const fallbackImagesByPillar: Record<string, string> = {
  'commercial-roofing': '/images/blog/commercial-roofing-featured.webp',
  'residential-roofing': '/images/blog/residential-roofing-featured.webp',
  'roof-repair': '/images/services/commercial/repair-hero.webp',
  'storm-damage': '/images/services/residential/storm-damage-hero.webp',
  proplan: '/images/commercial-hero.webp',
  'total-home-shield': '/images/residential-hero.webp',
  'property-card': '/images/locations-hero.webp',
};

const postData = kind === 'post' ? (entry as CollectionEntry<'blogPosts'>).data : null;
const pillarData = kind === 'pillar' ? (entry as CollectionEntry<'pillars'>).data : null;
const heroImage = postData
  ? postData.heroImage ?? fallbackImagesByPillar[postData.pillar] ?? '/images/blog-hero.webp'
  : pillarData?.heroImage ?? '/images/blog-hero.webp';
const categoryLabel = postData?.pillar.replace(/-/g, ' ');
const publishedDate = postData?.publishDate.toLocaleDateString('en-US', {
  month: 'long',
  day: 'numeric',
  year: 'numeric',
});

const breadcrumbs = [
  { label: 'Home', href: '/' },
  { label: 'Blog', href: '/blog/' },
  { label: 'name' in data ? data.name : data.title, href: data.canonicalPath },
];

let schemaPayload: Record<string, any>[] = [breadcrumbSchema(breadcrumbs)];

if (kind === 'post') {
  const post = entry as CollectionEntry<'blogPosts'>;
  schemaPayload.unshift(
    articleSchema({
      title: post.data.title,
      description: post.data.description,
      datePublished: post.data.publishDate.toISOString(),
      dateModified: post.data.updatedDate?.toISOString(),
      author: post.data.author,
      image: `https://pc-demo.cleverwork.io${heroImage}`,
      url: `https://pc-demo.cleverwork.io${post.data.canonicalPath}`,
    }),
  );
  if (post.data.faqs && post.data.faqs.length > 0) {
    schemaPayload.push(faqPageSchema(post.data.faqs));
  }
} else {
  const pillar = entry as CollectionEntry<'pillars'>;
  // List supporter posts that target this pillar
  const allPosts = await getCollection('blogPosts', ({ data: d }) => d.pillar === pillar.slug);
  const supporters = allPosts.map((p) => ({
    name: p.data.title,
    url: p.data.canonicalPath,
    description: p.data.description,
  }));
  schemaPayload.unshift(
    collectionPageSchema(supporters, pillar.data.title, pillar.data.description),
  );
}
---

<BaseLayout
  title={data.title}
  description={data.description}
  canonicalPath={data.canonicalPath}
  jsonLd={schemaPayload}
>
  <Breadcrumb items={breadcrumbs.slice(1)} />

  {kind === 'post' ? (
    <>
      <article>
        <header class="bg-surface-inset">
          <div class="mx-auto grid max-w-7xl gap-10 px-4 py-16 lg:grid-cols-[minmax(0,0.9fr)_minmax(360px,0.7fr)] lg:items-center lg:px-8 lg:py-20">
            <div>
              <p class="text-sm font-bold uppercase tracking-widest text-accent">{categoryLabel}</p>
              <h1 class="mt-4 text-4xl font-display font-bold tracking-tight text-text-primary sm:text-5xl lg:text-6xl">
                {data.title}
              </h1>
              <p class="mt-6 max-w-3xl text-xl leading-8 text-text-secondary">{data.description}</p>
              <div class="mt-8 flex flex-wrap items-center gap-x-4 gap-y-2 text-sm text-text-tertiary">
                <span>By {postData?.author}</span>
                {publishedDate && <span aria-hidden="true">•</span>}
                {publishedDate && <time datetime={postData?.publishDate.toISOString()}>{publishedDate}</time>}
              </div>
            </div>
            <div class="overflow-hidden rounded-3xl bg-border shadow-xl ring-1 ring-border">
              <img
                src={heroImage}
                alt=""
                class="h-full min-h-[280px] w-full object-cover"
                loading="eager"
                fetchpriority="high"
                decoding="async"
              />
            </div>
          </div>
        </header>

        <div class="mx-auto grid max-w-7xl gap-12 px-4 py-16 lg:grid-cols-[minmax(0,48rem)_18rem] lg:px-8">
          <div class="prose prose-lg max-w-none prose-headings:font-display prose-a:text-accent">
            <Content />
          </div>
          <aside class="h-fit rounded-2xl bg-surface-elevated p-6 ring-1 ring-border">
            <p class="text-sm font-bold uppercase tracking-widest text-text-tertiary">Article Focus</p>
            <p class="mt-3 text-lg font-semibold capitalize text-text-primary">{categoryLabel}</p>
            <a href="/blog/" class="mt-6 inline-flex text-sm font-bold text-accent hover:underline">Back to Knowledge Hub →</a>
          </aside>
        </div>
      </article>
      {(entry as CollectionEntry<'blogPosts'>).data.faqs && (entry as CollectionEntry<'blogPosts'>).data.faqs!.length > 0 && (
        <section class="bg-surface-inset py-16">
          <div class="mx-auto max-w-3xl px-4">
            <h2 class="mb-10 text-3xl font-bold text-center">Related questions</h2>
            <FAQ faqs={(entry as CollectionEntry<'blogPosts'>).data.faqs!} />
          </div>
        </section>
      )}
    </>
  ) : (
    <>
      <HeroSection
        title={(entry as CollectionEntry<'pillars'>).data.name}
        subtitle={(entry as CollectionEntry<'pillars'>).data.intro}
        image={heroImage}
      />
      <article class="prose mx-auto max-w-3xl px-4 py-16">
        <Content />
      </article>
    </>
  )}
</BaseLayout>
