---
import BaseLayout from '../../components/seo/BaseLayout.astro';
import HeroSection from '../../components/molecules/HeroSection.astro';
import Breadcrumb from '../../components/molecules/Breadcrumb.astro';
import Badge from '../../components/atoms/Badge.astro';
import { getCollection } from 'astro:content';
import { collectionPageSchema } from '../../lib/schema/CollectionPage';
import { breadcrumbSchema } from '../../lib/schema/BreadcrumbList';

const blogPosts = await getCollection('blogPosts');
const pillars = await getCollection('pillars');

const fallbackImagesByPillar: Record<string, string> = {
  'commercial-roofing': '/images/blog/commercial-roofing-featured.webp',
  'residential-roofing': '/images/blog/residential-roofing-featured.webp',
  'roof-repair': '/images/services/commercial/repair-hero.webp',
  'storm-damage': '/images/services/residential/storm-damage-hero.webp',
  proplan: '/images/commercial-hero.webp',
  'total-home-shield': '/images/residential-hero.webp',
  'property-card': '/images/locations-hero.webp',
};

const formatCategory = (pillar: string) => pillar.replace(/-/g, ' ');

const posts = blogPosts
  .sort((a, b) => b.data.publishDate.getTime() - a.data.publishDate.getTime())
  .map((post) => ({
    title: post.data.title,
    excerpt: post.data.description,
    category: formatCategory(post.data.pillar),
    categorySlug: post.data.pillar,
    date: post.data.publishDate.toLocaleDateString('en-US', {
      month: 'long',
      day: 'numeric',
      year: 'numeric',
    }),
    image: post.data.heroImage ?? fallbackImagesByPillar[post.data.pillar] ?? '/images/blog-hero.webp',
    url: post.data.canonicalPath,
  }));

const categories = [
  { label: 'All', slug: 'all' },
  ...Array.from(new Map(posts.map((post) => [post.categorySlug, { label: post.category, slug: post.categorySlug }])).values()),
];

const mainSchema = [
  collectionPageSchema(posts.map(p => ({ name: p.title, url: p.url, description: p.excerpt })), "Pro Exteriors Blog", "Insights and guides on roofing and exterior maintenance."),
  breadcrumbSchema([
    { label: "Home", href: "/" },
    { label: "Blog", href: "/blog/" }
  ])
];
---

<BaseLayout 
  title="Roofing Insights & Guides | Pro Exteriors Blog" 
  description="Expert advice on roof maintenance, material selection, and storm damage restoration for Texas property owners."
  canonicalPath="/blog/"
  jsonLd={mainSchema}
>
  <Breadcrumb items={[{ label: "Home", href: "/" }, { label: "Blog", href: "/blog/" }]} />

  <HeroSection 
    title="Knowledge Hub"
    subtitle={`${posts.length} roofing guides organized around commercial roofing, residential roofing, roof repair, and storm-damage intent.`}
    primaryCta={{ label: "Subscribe to Newsletter", href: "#subscribe" }}
    secondaryCta={{ label: "Read Featured Story", href: posts[0]?.url ?? "/blog/commercial-roofing/" }}
    image="/images/blog-hero.webp"
  />

  <section class="py-12 border-b">
    <div class="max-w-7xl mx-auto px-4 flex flex-wrap gap-4 justify-center">
      {categories.map((cat, index) => (
        <button
          type="button"
          class={`px-6 py-2 rounded-full text-sm font-medium transition-colors ${index === 0 ? 'bg-brand-primary text-text-on-brand' : 'bg-surface-inset text-text-secondary hover:bg-border'}`}
          data-blog-filter={cat.slug}
          aria-pressed={index === 0 ? 'true' : 'false'}
        >
          {cat.label}
        </button>
      ))}
    </div>
  </section>

  <section class="py-20 px-4 max-w-7xl mx-auto">
    <div class="mb-10 text-center" aria-live="polite">
      <p class="text-sm font-semibold uppercase tracking-widest text-text-tertiary" data-blog-count>
        Showing all {posts.length} guides
      </p>
    </div>
    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-10" data-blog-grid>
      {posts.map(post => (
        <article class="group" data-blog-card data-category={post.categorySlug}>
          <div class="aspect-video bg-border rounded-2xl mb-6 overflow-hidden relative">
            <a href={post.url} class="block h-full" aria-label={`Read ${post.title}`}>
              <img
                src={post.image}
                alt=""
                class="h-full w-full object-cover transition duration-300 group-hover:scale-105"
                loading="lazy"
                decoding="async"
              />
            </a>
            <div class="absolute top-4 left-4 z-10">
              <Badge variant="primary">{post.category}</Badge>
            </div>
          </div>
          <div class="space-y-4">
            <p class="text-sm text-text-tertiary">{post.date}</p>
            <h3 class="text-2xl font-bold text-text-primary group-hover:text-accent transition-colors">
              <a href={post.url}>{post.title}</a>
            </h3>
            <p class="text-text-secondary line-clamp-3">{post.excerpt}</p>
            <a href={post.url} class="inline-block text-text-primary font-bold hover:underline">Read Article →</a>
          </div>
        </article>
      ))}
    </div>
  </section>

  <section class="py-20 px-4 max-w-7xl mx-auto">
    <div class="mb-10">
      <h2 class="text-3xl font-bold text-text-primary">Pillar Guides</h2>
      <p class="mt-2 text-text-secondary">Start with the pillar, then move into the supporting articles.</p>
    </div>
    <div class="grid grid-cols-1 md:grid-cols-2 gap-8">
      {pillars.map((pillar) => (
        <article class="rounded-2xl bg-surface-elevated p-8 ring-1 ring-border">
          <Badge variant="cert">{pillar.data.vertical}</Badge>
          <h3 class="mt-4 text-2xl font-bold text-text-primary">
            <a href={pillar.data.canonicalPath}>{pillar.data.name}</a>
          </h3>
          <p class="mt-3 text-text-secondary">{pillar.data.intro}</p>
          <a href={pillar.data.canonicalPath} class="mt-6 inline-block text-text-primary font-bold hover:underline">Open Pillar →</a>
        </article>
      ))}
    </div>
  </section>

  <section id="subscribe" class="py-20 bg-surface-inverted text-text-inverted rounded-3xl mx-4 mb-20 overflow-hidden relative">
    <div class="absolute inset-0 opacity-10 pointer-events-none">
      <!-- Decorative pattern -->
      <svg class="w-full h-full" fill="currentColor" viewBox="0 0 100 100" preserveAspectRatio="none">
        <path d="M0 100 L100 0 L100 100 Z" />
      </svg>
    </div>
    <div class="max-w-4xl mx-auto px-4 relative z-10 text-center">
      <h2 class="text-3xl font-bold mb-4">Stay Ahead of the Storm</h2>
      <p class="text-xl text-text-inverted-secondary mb-10">Get expert roofing tips and DFW weather alerts delivered to your inbox.</p>
      <form class="flex flex-col sm:flex-row gap-4 max-w-md mx-auto">
        <input type="email" placeholder="Enter your email" class="flex-1 px-6 py-4 rounded-full bg-surface-elevated border-border focus:outline-none focus:ring-2 focus:ring-accent text-text-primary placeholder-text-tertiary" required />
        <button type="submit" class="px-8 py-4 bg-brand-primary hover:bg-brand-accent-hover text-text-on-brand font-bold rounded-full transition-colors">Subscribe</button>
      </form>
    </div>
  </section>

  <script is:inline>
    (() => {
      const buttons = Array.from(document.querySelectorAll('[data-blog-filter]'));
      const cards = Array.from(document.querySelectorAll('[data-blog-card]'));
      const count = document.querySelector('[data-blog-count]');

      const setActive = (activeButton) => {
        buttons.forEach((button) => {
          const isActive = button === activeButton;
          button.setAttribute('aria-pressed', isActive ? 'true' : 'false');
          button.classList.toggle('bg-brand-primary', isActive);
          button.classList.toggle('text-text-on-brand', isActive);
          button.classList.toggle('bg-surface-inset', !isActive);
          button.classList.toggle('text-text-secondary', !isActive);
        });
      };

      buttons.forEach((button) => {
        button.addEventListener('click', () => {
          const filter = button.getAttribute('data-blog-filter');
          let visible = 0;

          cards.forEach((card) => {
            const matches = filter === 'all' || card.getAttribute('data-category') === filter;
            card.toggleAttribute('hidden', !matches);
            if (matches) visible += 1;
          });

          setActive(button);
          if (count) {
            count.textContent = filter === 'all'
              ? `Showing all ${visible} guides`
              : `Showing ${visible} ${button.textContent?.trim() ?? ''} guides`;
          }
        });
      });
    })();
  </script>
</BaseLayout>
