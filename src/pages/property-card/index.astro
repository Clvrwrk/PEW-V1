---
import BaseLayout from '../../components/seo/BaseLayout.astro';
import HeroSection from '../../components/molecules/HeroSection.astro';
import Breadcrumb from '../../components/molecules/Breadcrumb.astro';
import Button from '../../components/atoms/Button.astro';
import { breadcrumbSchema } from '../../lib/schema/BreadcrumbList';

const breadcrumbs = [
  { label: 'Home', href: '/' },
  { label: 'Property Card', href: '/property-card/' },
];
const schemaPayload = [breadcrumbSchema(breadcrumbs)];
---

<BaseLayout
  title="Pro Exteriors Property Card | Exterior Health Report"
  description="A complete health and history report for your home's exterior — Pro Exteriors compiles roof, gutters, siding, and storm risk in one document."
  canonicalPath="/property-card/"
  jsonLd={schemaPayload}
>
  <Breadcrumb items={breadcrumbs.slice(1)} />
  <HeroSection
    title="The Property Card"
    subtitle="A complete health and history report for your home's exterior. No commitment — just transparency."
    primaryCta={{ label: 'Get Yours', href: '/property-card/get-yours/' }}
    secondaryCta={{ label: 'See a Sample', href: '/property-card/preview/' }}
  />
  <article class="prose mx-auto max-w-3xl px-4 py-16">
    <h2>What's inside</h2>
    <ul>
      <li>Roof age, system, and remaining life estimate</li>
      <li>Gutters and siding condition snapshot</li>
      <li>Storm history for your address (last 5 years)</li>
      <li>HOA and subdivision context if applicable</li>
    </ul>
  </article>
</BaseLayout>
