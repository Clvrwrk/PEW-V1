---
import BaseLayout from '../../components/seo/BaseLayout.astro';
import HeroSection from '../../components/molecules/HeroSection.astro';
import Breadcrumb from '../../components/molecules/Breadcrumb.astro';
import { breadcrumbSchema } from '../../lib/schema/BreadcrumbList';

const breadcrumbs = [
  { label: 'Home', href: '/' },
  { label: 'Property Card', href: '/property-card/' },
  { label: 'Preview', href: '/property-card/preview/' },
];
const schemaPayload = [breadcrumbSchema(breadcrumbs)];
---

<BaseLayout
  title="Pro Exteriors Property Card — Sample Preview"
  description="See what's in a Pro Exteriors Property Card before you request your own. Roof, gutters, siding, and storm history at a glance."
  canonicalPath="/property-card/preview/"
  jsonLd={schemaPayload}
>
  <Breadcrumb items={breadcrumbs.slice(1)} />
  <HeroSection title="A Sample Property Card" subtitle="Anonymized and abbreviated, but the format is real." />
  <section class="py-16 px-4 max-w-3xl mx-auto">
    <p class="text-text-secondary">Phase 1 placeholder. Sample card render lands in Phase 2.</p>
  </section>
</BaseLayout>
