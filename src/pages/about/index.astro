---
import BaseLayout from '../../components/seo/BaseLayout.astro';
import HeroSection from '../../components/molecules/HeroSection.astro';
import Breadcrumb from '../../components/molecules/Breadcrumb.astro';
import Card from '../../components/molecules/Card.astro';
import { aboutPageSchema } from '../../lib/schema/AboutPage';
import { breadcrumbSchema } from '../../lib/schema/BreadcrumbList';

const breadcrumbs = [
  { label: 'Home', href: '/' },
  { label: 'About', href: '/about/' },
];

const schemaPayload = [aboutPageSchema(), breadcrumbSchema(breadcrumbs)];
---

<BaseLayout
  title="About Pro Exteriors | Local Roofing Experts"
  description="Pro Exteriors builds long-term partnerships with property leaders. Local accountability, engineered systems, conversion-grade craft. Meet the team."
  canonicalPath="/about/"
  jsonLd={schemaPayload}
>
  <Breadcrumb items={breadcrumbs.slice(1)} />

  <HeroSection
    title="A Roofing Partner. Not Just a Contractor."
    subtitle="Pro Exteriors is the local team for property leaders who measure outcomes in years, not weeks."
    primaryCta={{ label: 'Meet the Leadership', href: '/about/leadership/' }}
    secondaryCta={{ label: 'Read Our Mission', href: '/about/mission/' }}
  />

  <section class="py-20 px-4 max-w-7xl mx-auto">
    <div class="grid grid-cols-1 md:grid-cols-3 gap-8">
      <Card title="Our Mission" description="The standards we hold and the outcomes we measure." href="/about/mission/" eyebrow="Mission & Values" />
      <Card title="Leadership" description="The people accountable to your roof and your bottom line." href="/about/leadership/" eyebrow="Leadership" />
      <Card title="Careers" description="Build a long-term career with a team that ships." href="/careers/" eyebrow="Join Us" />
    </div>
  </section>
</BaseLayout>
