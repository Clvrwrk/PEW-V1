---
import BaseLayout from '../../components/seo/BaseLayout.astro';
import HeroSection from '../../components/molecules/HeroSection.astro';
import Breadcrumb from '../../components/molecules/Breadcrumb.astro';
import { breadcrumbSchema } from '../../lib/schema/BreadcrumbList';

const breadcrumbs = [
  { label: 'Home', href: '/' },
  { label: 'About', href: '/about/' },
  { label: 'Mission & Values', href: '/about/mission/' },
];
const schemaPayload = [breadcrumbSchema(breadcrumbs)];
---

<BaseLayout
  title="Mission & Values | Pro Exteriors"
  description="Pro Exteriors is built on local accountability, engineering-grade craft, and outcomes that compound for property leaders. Read our standards."
  canonicalPath="/about/mission/"
  jsonLd={schemaPayload}
>
  <Breadcrumb items={breadcrumbs.slice(1)} />
  <HeroSection title="Mission & Values" subtitle="Standards we hold; outcomes we measure." />
  <article class="prose mx-auto max-w-3xl px-4 py-16">
    <p>Phase 1 placeholder. Real mission/values copy from leadership lands in Phase 2.</p>
    {/* TODO(content): Mission & Values copy from Pro Exteriors leadership */}
  </article>
</BaseLayout>
