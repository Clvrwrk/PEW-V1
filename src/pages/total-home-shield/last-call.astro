---
import BaseLayout from '../../components/seo/BaseLayout.astro';
import HeroSection from '../../components/molecules/HeroSection.astro';
import Breadcrumb from '../../components/molecules/Breadcrumb.astro';
import { breadcrumbSchema } from '../../lib/schema/BreadcrumbList';

const breadcrumbs = [
  { label: 'Home', href: '/' },
  { label: 'Total Home Shield', href: '/total-home-shield/' },
  { label: 'Last Call', href: '/total-home-shield/last-call/' },
];
const schemaPayload = [breadcrumbSchema(breadcrumbs)];
---

<BaseLayout
  title="Last Call: Total Home Shield Loyalty Offer | Pro Exteriors"
  description="Last call to claim your $997 Pro Exteriors Total Home Shield loyalty offer. Annual exterior care for proactive homeowners."
  canonicalPath="/total-home-shield/last-call/"
  jsonLd={schemaPayload}
>
  <Breadcrumb items={breadcrumbs.slice(1)} />
  <HeroSection
    title="Last Call"
    subtitle="50 households. Limited slots. The annual offer closes when capacity is reached."
    primaryCta={{ label: 'Claim Your Offer', href: '/total-home-shield/claim-offer/' }}
  />
  <article class="prose mx-auto max-w-3xl px-4 py-16">
    <p>Phase 1 placeholder. Verbatim campaign copy lands with Step 8c.</p>
  </article>
</BaseLayout>
