---
import BaseLayout from '../../components/seo/BaseLayout.astro';
import HeroSection from '../../components/molecules/HeroSection.astro';
import Breadcrumb from '../../components/molecules/Breadcrumb.astro';
import PartnerNetworkDisclosure from '../../components/atoms/PartnerNetworkDisclosure.astro';
import Button from '../../components/atoms/Button.astro';
import { breadcrumbSchema } from '../../lib/schema/BreadcrumbList';

const breadcrumbs = [
  { label: 'Home', href: '/' },
  { label: 'Total Home Shield', href: '/total-home-shield/' },
  { label: 'Claim Your Offer', href: '/total-home-shield/claim-offer/' },
];
const schemaPayload = [breadcrumbSchema(breadcrumbs)];
---

<BaseLayout
  title="Claim Your $997 Loyalty Offer | Pro Exteriors"
  description="Claim your $997 Pro Exteriors Total Home Shield loyalty offer. Annual exterior care for the home you don't want to think about."
  canonicalPath="/total-home-shield/claim-offer/"
  jsonLd={schemaPayload}
>
  <Breadcrumb items={breadcrumbs.slice(1)} />
  <HeroSection
    title="Your $997 Loyalty Offer"
    subtitle="Annual Total Home Shield coverage. Limited to 50 households this quarter."
    primaryCta={{ label: 'Reserve Your Spot', href: '/total-home-shield/booking/' }}
  />
  <section class="py-16 px-4 max-w-2xl mx-auto">
    <p class="text-gray-700">Phase 1 placeholder. The campaign lead form (campaign=&quot;total-home-shield-anchor&quot;) lands with Step 8c + Step 11.</p>
    <div class="mt-8">
      <Button href="/total-home-shield/last-call/" variant="ghost">Read more before deciding</Button>
    </div>
  </section>
  <div class="mx-auto max-w-3xl px-4 pb-16">
    <PartnerNetworkDisclosure />
  </div>
</BaseLayout>
