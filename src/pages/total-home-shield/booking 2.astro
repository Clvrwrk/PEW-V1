---
import BaseLayout from '../../components/seo/BaseLayout.astro';
import HeroSection from '../../components/molecules/HeroSection.astro';
import Breadcrumb from '../../components/molecules/Breadcrumb.astro';
import { breadcrumbSchema } from '../../lib/schema/BreadcrumbList';

const breadcrumbs = [
  { label: 'Home', href: '/' },
  { label: 'Total Home Shield', href: '/total-home-shield/' },
  { label: 'Booking', href: '/total-home-shield/booking/' },
];
const schemaPayload = [breadcrumbSchema(breadcrumbs)];
---

<BaseLayout
  title="Book Your Total Home Shield Onboarding | Pro Exteriors"
  description="Schedule your Pro Exteriors Total Home Shield onboarding call. Walk through annual coverage, scheduling, and your home's specific exterior plan."
  canonicalPath="/total-home-shield/booking/"
  noindex={true}
  jsonLd={schemaPayload}
>
  <Breadcrumb items={breadcrumbs.slice(1)} />
  <HeroSection title="Schedule Your Onboarding" subtitle="Pick a time. Our team will walk you through the annual coverage." />
  <article class="prose mx-auto max-w-3xl px-4 py-16">
    <p>Phase 1 placeholder. Calendly/GHL embed lands with Step 8c.</p>
    <h2>While you wait</h2>
    <ul>
      <li><a href="/projects/">Recent Pro Exteriors projects</a></li>
      <li><a href="/about/">Meet the team</a></li>
    </ul>
  </article>
</BaseLayout>
