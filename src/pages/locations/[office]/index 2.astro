---
/**
 * src/pages/locations/[office]/index.astro
 * Office-location / GBP destination template (Step 8b).
 * Renders one page per offices-collection entry.
 */
import { getCollection, type CollectionEntry } from 'astro:content';
import BaseLayout from '../../../components/seo/BaseLayout.astro';
import HeroSection from '../../../components/molecules/HeroSection.astro';
import Breadcrumb from '../../../components/molecules/Breadcrumb.astro';
import Button from '../../../components/atoms/Button.astro';
import { localBusinessSchema } from '../../../lib/schema/LocalBusiness';
import { breadcrumbSchema } from '../../../lib/schema/BreadcrumbList';

export async function getStaticPaths() {
  const offices = await getCollection('offices');
  return offices.map((entry) => ({
    params: { office: entry.slug },
    props: { entry },
  }));
}

interface Props {
  entry: CollectionEntry<'offices'>;
}

const { entry } = Astro.props;
const { Content } = await entry.render();
const data = entry.data;
const addr = data.address;
const fullAddress = `${addr.street}, ${addr.city}, ${addr.state} ${addr.zip}`;

const breadcrumbs = [
  { label: 'Home', href: '/' },
  { label: 'Locations', href: '/locations/' },
  { label: data.name, href: data.canonicalPath },
];

const schemaPayload = [
  localBusinessSchema({
    name: `${data.address.city}, ${data.address.state}`,
    address: fullAddress,
    phone: data.phone,
    email: 'hello@proexteriors.com',
    url: `https://pc-demo.cleverwork.io${data.canonicalPath}`,
    lat: data.lat,
    lng: data.lng,
  }),
  breadcrumbSchema(breadcrumbs),
];
---

<BaseLayout
  title={data.title}
  description={data.description}
  canonicalPath={data.canonicalPath}
  jsonLd={schemaPayload}
>
  <Breadcrumb items={breadcrumbs.slice(1)} />

  <HeroSection
    title={`Pro Exteriors — ${data.metro} from our ${addr.city} office`}
    subtitle={`Serving ${addr.city} and the surrounding ${data.metro} region for commercial and residential roofing.`}
    primaryCta={{ label: 'Schedule a Visit', href: '/contact/' }}
    secondaryCta={{ label: `Call ${data.phone}`, href: `tel:${data.phone.replace(/\D/g, '')}` }}
  />

  <section class="py-16 px-4 max-w-5xl mx-auto">
    <div class="grid grid-cols-1 md:grid-cols-2 gap-10">
      <div>
        <h2 class="text-2xl font-bold mb-4">Office Address</h2>
        <address class="not-italic text-gray-700 leading-7">
          <div class="font-medium text-gray-900">{data.name}</div>
          <div>{addr.street}</div>
          <div>{addr.city}, {addr.state} {addr.zip}</div>
        </address>

        <h2 class="text-2xl font-bold mt-8 mb-4">Hours</h2>
        <p class="text-gray-700">{data.hours}</p>

        <h2 class="text-2xl font-bold mt-8 mb-4">Contact</h2>
        <p>
          <a href={`tel:${data.phone.replace(/\D/g, '')}`} class="text-brand-primary font-medium hover:underline">
            {data.phone}
          </a>
        </p>
      </div>

      <div class="bg-brand-bg-alt rounded-2xl p-8">
        <h2 class="text-2xl font-bold mb-4">Two ways to start</h2>
        <p class="text-gray-700 mb-6">Whether you're managing a commercial portfolio or protecting a single home, our {addr.city} team is your local point of contact.</p>
        <div class="flex flex-col sm:flex-row gap-3">
          <Button href="/commercial-roofing/" variant="primary" size="lg">Commercial</Button>
          <Button href="/residential-roofing/" variant="secondary" size="lg">Residential</Button>
        </div>
      </div>
    </div>
  </section>

  <article class="prose mx-auto max-w-3xl px-4 pb-16">
    <Content />
  </article>
</BaseLayout>
