    aspect-ratio: 16/9;
    overflow: hidden;
    background: #F3F4F6;
  }
  .card-v3__image img {
    width: 100%; height: 100%; object-fit: cover;
    transition: transform 400ms ease;
  }
  .card-v3:hover .card-v3__image img { transform: scale(1.05); }
  .card-v3__content {
    position: relative;
    padding: 1.25rem 1.25rem 1.5rem 1.5rem;
    flex: 1;
    display: flex;
    flex-direction: column;
    border-left: 4px solid #3b6b4c;
  }
  .card-v3__icon-square {
    position: absolute;
    top: 1.25rem; right: 1.25rem;
    width: 40px; height: 40px;
    background: #11133f;
    color: #eaa221;
    display: flex; align-items: center; justify-content: center;
    border-radius: 4px;
  }
  .card-v3__content h3 {
    font-size: 1.125rem;
    font-weight: 700;
    color: #11133f;
    margin: 0 0 0.5rem;
    padding-right: 3.25rem;  /* room for icon */
  }
  .card-v3__content p {
    font-size: 0.875rem;
    line-height: 1.5;
    color: #374151;
    margin: 0;
    flex: 1;
  }
  .card-v3__cta {
    margin-top: 1rem;
    color: #C22326;
