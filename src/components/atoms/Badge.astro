---
export interface Props {
  variant: 'primary' | 'verified' | 'cert' | 'new' | 'todo';
  class?: string;
}

const { variant, class: className = '' } = Astro.props;

const baseStyles = 'inline-flex items-center px-2.5 py-0.5 rounded-full text-xs font-medium';

const variantStyles = {
  primary: 'bg-accent/10 text-accent',
  verified: 'bg-success-surface text-success-text',
  cert: 'bg-info-surface text-info-text',
  new: 'bg-warning-surface text-warning-text',
  todo: 'bg-surface-inset text-text-primary border border-dashed border-border',
};

const classes = `${baseStyles} ${variantStyles[variant]} ${className}`;
---

<span class={classes}>
  <slot />
</span>
