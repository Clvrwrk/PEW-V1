---
export interface Props {
  class?: string;
}

const { class: className = 'h-10 w-auto' } = Astro.props;

const lightLogo = '/Logos/pro-exteriors-logo-light.webp';
const darkLogo = '/Logos/pro-exteriors-logo-dark.webp';
---

<span class="inline-flex items-center" aria-hidden="true">
  <img
    src={lightLogo}
    alt=""
    width="360"
    height="84"
    class={`${className} block dark:hidden`}
    loading="eager"
    decoding="async"
  />
  <img
    src={darkLogo}
    alt=""
    width="360"
    height="84"
    class={`${className} hidden dark:block`}
    loading="eager"
    decoding="async"
  />
</span>
