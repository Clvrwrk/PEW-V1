---
export interface Props {
  variant?: 'primary' | 'secondary' | 'ghost' | 'danger' | 'white' | 'outline' | 'inverted' | 'onBrandOutline';
  size?: 'sm' | 'md' | 'lg';
  href?: string;
  class?: string;
  'data-cta-name'?: string;
  type?: 'button' | 'submit' | 'reset';
}

const {
  variant = 'primary',
  size = 'md',
  href,
  class: className = '',
  'data-cta-name': ctaName,
  type = 'button',
  ...rest
} = Astro.props;

const baseStyles = 'inline-flex items-center justify-center font-medium rounded-md focus:outline-none focus:ring-2 focus:ring-offset-2 transition-colors';

const sizeStyles = {
  sm: 'px-3 py-1.5 text-sm',
  md: 'px-4 py-2 text-sm',
  lg: 'px-6 py-3 text-base',
};

const variantStyles = {
  primary: 'bg-brand-accent text-text-on-brand hover:bg-brand-accent-hover focus:ring-accent',
  secondary: 'bg-surface-elevated text-text-secondary border border-border hover:bg-surface-inset focus:ring-accent',
  ghost: 'bg-transparent text-text-primary hover:bg-surface-inset focus:ring-accent',
  danger: 'bg-danger text-text-on-brand hover:bg-danger-hover focus:ring-danger',
  white: 'bg-surface-elevated text-text-primary border border-border hover:bg-surface-inset focus:ring-accent',
  outline: 'bg-transparent text-text-primary border border-border hover:bg-surface-inset focus:ring-accent',
  inverted: 'bg-transparent text-text-inverted hover:bg-white/10 focus:ring-accent',
  onBrandOutline: 'bg-transparent text-text-on-brand border border-white hover:bg-white hover:text-accent focus:ring-accent',
};

const classes = `${baseStyles} ${sizeStyles[size]} ${variantStyles[variant]} ${className}`;

const Tag = href ? 'a' : 'button';
---

<Tag
  href={href}
  type={href ? undefined : type}
  class={classes}
  data-cta-name={ctaName}
  {...rest}
>
  <slot />
</Tag>
