---
export interface Props {
  name: string;
  label: string;
  type?: 'text' | 'email' | 'tel' | 'url' | 'number' | 'password';
  required?: boolean;
  error?: string;
  placeholder?: string;
  class?: string;
}

const {
  name,
  label,
  type = 'text',
  required = false,
  error,
  placeholder,
  class: className = '',
  ...rest
} = Astro.props;
---

<div class={`flex flex-col space-y-1 ${className}`}>
  <label for={name} class="text-sm font-medium text-text-secondary">
    {label} {required && <span class="text-danger" aria-hidden="true">*</span>}
  </label>
  <div class="relative rounded-md shadow-sm">
    <input
      type={type}
      name={name}
      id={name}
      required={required}
      placeholder={placeholder}
      class={`block w-full rounded-md sm:text-sm ${
        error
          ? 'border-danger-border text-danger-text placeholder-danger-border focus:border-danger focus:ring-danger'
          : 'border-border focus:border-accent focus:ring-accent'
      }`}
      aria-invalid={error ? "true" : undefined}
      aria-describedby={error ? `${name}-error` : undefined}
      {...rest}
    />
  </div>
  {error && (
    <p class="text-sm text-danger" id={`${name}-error`}>
      {error}
    </p>
  )}
</div>
