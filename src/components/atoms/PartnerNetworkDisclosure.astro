---
export interface Props {
  class?: string;
}

const { class: className = '' } = Astro.props;
---

<div class={`inline-flex items-center text-sm text-text-tertiary bg-surface-inset rounded-md px-3 py-2 border border-border ${className}`}>
  <span>
    Coordinated by Pro Exteriors &bull; Installed by our trusted partner network.
    <a href="/partners/" class="ml-1 text-text-primary font-medium hover:text-accent transition-colors focus:outline-none focus:underline">
      Learn more &rarr;
    </a>
  </span>
</div>
