---
import Icon from '../atoms/Icon.astro';

export interface Props {
  name: string;
  description: string;
  href: string;
  icon?: string;
  class?: string;
}

const {
  name,
  description,
  href,
  icon = 'hammer',
  class: className = '',
} = Astro.props;
---

<a href={href} class={`group relative flex flex-col items-start p-6 bg-white rounded-xl shadow-sm ring-1 ring-gray-200 transition-all hover:shadow-md hover:ring-brand-primary ${className}`}>
  <div class="rounded-lg bg-brand-bg-alt p-3 ring-1 ring-white/10 mb-4 text-brand-primary group-hover:bg-brand-primary group-hover:text-white transition-colors">
    <Icon name={icon} size={24} />
  </div>
  <h3 class="text-lg font-semibold text-gray-900 group-hover:text-brand-primary transition-colors">
    <span class="absolute inset-0" aria-hidden="true"></span>
    {name}
  </h3>
  <p class="mt-2 text-sm text-gray-500 line-clamp-2">
    {description}
  </p>
  <div class="mt-4 flex items-center text-sm font-medium text-brand-accent group-hover:text-orange-600 transition-colors">
    Learn More 
    <svg class="ml-1 h-4 w-4 transition-transform group-hover:translate-x-1" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor">
      <path stroke-linecap="round" stroke-linejoin="round" d="M13.5 4.5L21 12m0 0l-7.5 7.5M21 12H3" />
    </svg>
  </div>
</a>
