---
import Icon from '../atoms/Icon.astro';

export interface BenefitItem {
  icon: string;
  title: string;
  description: string;
}

export interface Props {
  heading: string;
  subtitle?: string;
  items: BenefitItem[];
  class?: string;
}

const {
  heading,
  subtitle,
  items,
  class: className = '',
} = Astro.props;
---

<section class={`py-16 sm:py-24 bg-surface-inset ${className}`}>
  <div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8">
    <!-- Header -->
    <div class="text-center max-w-2xl mx-auto mb-16">
      <h2 class="text-3xl font-display font-bold tracking-tight text-text-primary sm:text-4xl">
        {heading}
      </h2>
      {subtitle && (
        <p class="mt-4 text-lg text-text-secondary">{subtitle}</p>
      )}
    </div>

    <!-- Grid -->
    <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-8 lg:gap-10">
      {items.map((item) => (
        <div class="flex flex-col items-start">
          <div class="flex h-12 w-12 items-center justify-center rounded-lg bg-accent/10 text-accent mb-5">
            <Icon name={item.icon} size={24} />
          </div>
          <h3 class="text-lg font-bold text-text-primary">{item.title}</h3>
          <p class="mt-2 text-sm leading-6 text-text-secondary">{item.description}</p>
        </div>
      ))}
    </div>
  </div>
</section>
