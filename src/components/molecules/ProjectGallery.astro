---
export interface Props {
  heading?: string;
  images: string[];
  class?: string;
}

const {
  heading = 'Completed Projects',
  images,
  class: className = '',
} = Astro.props;
---

<section class={`py-16 sm:py-24 bg-surface-inverted ${className}`}>
  <div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8">
    <h2 class="text-3xl font-display font-bold tracking-tight text-text-inverted mb-12">
      {heading}
    </h2>

    <div class="grid grid-cols-2 lg:grid-cols-4 gap-4">
      {images.map((src, i) => (
        <div class="aspect-[4/3] overflow-hidden rounded-lg">
          <img
            src={src}
            alt={`Project ${i + 1}`}
            class="h-full w-full object-cover transition-transform duration-300 hover:scale-105"
            loading="lazy"
          />
        </div>
      ))}
    </div>
  </div>
</section>
