---
export interface ProcessStepItem {
  title: string;
  description: string;
}

export interface Props {
  heading: string;
  image: string;
  steps: ProcessStepItem[];
  class?: string;
}

const {
  heading,
  image,
  steps,
  class: className = '',
} = Astro.props;
---

<section class={`py-16 sm:py-24 bg-surface-inset ${className}`}>
  <div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8">
    <h2 class="text-3xl font-display font-bold tracking-tight text-text-primary text-center sm:text-4xl mb-16">
      {heading}
    </h2>

    <div class="grid grid-cols-1 lg:grid-cols-2 gap-12 lg:gap-16 items-center">
      <!-- Image -->
      <div class="relative">
        <div class="aspect-[4/3] overflow-hidden rounded-2xl shadow-lg">
          <img
            src={image}
            alt={heading}
            class="h-full w-full object-cover"
            loading="lazy"
          />
        </div>
      </div>

      <!-- Steps -->
      <div class="space-y-10">
        {steps.map((step, i) => (
          <div class="flex gap-5">
            <!-- Number circle -->
            <div class="flex-shrink-0 flex h-10 w-10 items-center justify-center rounded-full bg-brand-accent text-text-on-brand text-sm font-bold">
              {i + 1}
            </div>
            <div>
              <h3 class="text-lg font-bold text-text-primary">{step.title}</h3>
              <p class="mt-2 text-sm leading-6 text-text-secondary">{step.description}</p>
            </div>
          </div>
        ))}
      </div>
    </div>
  </div>
</section>
