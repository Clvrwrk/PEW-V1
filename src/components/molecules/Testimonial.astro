---
import SchemaJsonLd from '../seo/SchemaJsonLd.astro';
import Icon from '../atoms/Icon.astro';

export interface Props {
  quote: string;
  author: string;
  role?: string;
  org?: string;
  photo?: string;
  rating?: number;
  class?: string;
}

const {
  quote,
  author,
  role,
  org,
  photo,
  rating = 5,
  class: className = '',
} = Astro.props;

// Generate Review Schema Fragment
const reviewSchema = {
  "@context": "https://schema.org",
  "@type": "Review",
  "reviewRating": {
    "@type": "Rating",
    "ratingValue": rating.toString(),
    "bestRating": "5"
  },
  "author": {
    "@type": "Person",
    "name": author
  },
  "reviewBody": quote,
  "itemReviewed": {
    "@type": "LocalBusiness",
    "name": "Pro Exteriors"
  }
};
---

<SchemaJsonLd jsonLd={reviewSchema} />

<figure class={`bg-surface-elevated rounded-2xl p-8 shadow-sm ring-1 ring-border ${className}`}>
  <div class="flex items-center gap-1 text-accent mb-6">
    {[...Array(5)].map((_, i) => (
      <Icon name="star" class={i < Math.floor(rating) ? 'fill-accent' : 'text-border'} size={20} />
    ))}
  </div>
  
  <blockquote class="text-lg leading-8 text-text-primary mb-6">
    <p>"{quote}"</p>
  </blockquote>
  
  <figcaption class="flex items-center gap-x-4">
    {photo ? (
      <img src={photo} alt="" class="h-12 w-12 rounded-full bg-surface-inset object-cover" loading="lazy" />
    ) : (
      <div class="flex h-12 w-12 items-center justify-center rounded-full bg-surface-inset text-text-primary font-bold">
        {author.charAt(0)}
      </div>
    )}
    <div>
      <div class="font-semibold text-text-primary">{author}</div>
      {(role || org) && (
        <div class="text-sm text-text-tertiary">
          {role}{role && org ? ', ' : ''}{org}
        </div>
      )}
    </div>
  </figcaption>
</figure>
