---
export interface Props {
  title: string;
  description: string;
  image?: string;
  eyebrow?: string;
  href?: string;
  ctaText?: string;
  class?: string;
}

const {
  title,
  description,
  image,
  eyebrow,
  href,
  ctaText = 'Learn More',
  class: className = '',
} = Astro.props;

const Element = href ? 'a' : 'div';
---

<Element
  href={href}
  class={`group flex flex-col overflow-hidden rounded-xl bg-surface-elevated shadow-sm ring-1 ring-border transition-all hover:shadow-md ${href ? 'hover:ring-accent cursor-pointer' : ''} ${className}`}
>
  {image && (
    <div class="aspect-w-16 aspect-h-9 w-full overflow-hidden bg-surface-inset">
      <img src={image} alt={title} class="h-full w-full object-cover transition-transform duration-300 group-hover:scale-105" loading="lazy" />
    </div>
  )}
  <div class="flex flex-1 flex-col p-6">
    {eyebrow && (
      <p class="text-xs font-semibold uppercase tracking-wide text-text-primary mb-2">
        {eyebrow}
      </p>
    )}
    <h3 class="text-xl font-bold text-text-primary group-hover:text-accent transition-colors">
      {title}
    </h3>
    <p class="mt-3 flex-1 text-base text-text-tertiary">
      {description}
    </p>
    {href && (
      <div class="mt-6 flex items-center text-sm font-medium text-accent group-hover:text-accent-hover">
        {ctaText}
        <svg class="ml-1 h-4 w-4 transition-transform group-hover:translate-x-1" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor">
          <path stroke-linecap="round" stroke-linejoin="round" d="M13.5 4.5L21 12m0 0l-7.5 7.5M21 12H3" />
        </svg>
      </div>
    )}
  </div>
</Element>
