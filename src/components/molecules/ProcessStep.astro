---
import Icon from '../atoms/Icon.astro';

export interface Props {
  number: number;
  title: string;
  description: string;
  icon?: string;
  class?: string;
}

const {
  number,
  title,
  description,
  icon,
  class: className = '',
} = Astro.props;
---

<div class={`relative pl-16 ${className}`}>
  <dt class="text-base font-semibold leading-7 text-text-primary">
    <div class="absolute left-0 top-0 flex h-10 w-10 items-center justify-center rounded-lg bg-brand-primary text-text-on-brand">
      {icon ? (
        <Icon name={icon} size={20} class="text-text-on-brand" />
      ) : (
        <span class="text-lg font-bold">{number}</span>
      )}
    </div>
    {title}
  </dt>
  <dd class="mt-2 text-base leading-7 text-text-secondary">
    {description}
  </dd>
</div>
