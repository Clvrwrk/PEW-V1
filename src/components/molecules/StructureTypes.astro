---
import Icon from '../atoms/Icon.astro';

export interface StructureItem {
  icon: string;
  title: string;
  description: string;
}

export interface Props {
  heading: string;
  items: StructureItem[];
  class?: string;
}

const {
  heading,
  items,
  class: className = '',
} = Astro.props;
---

<section class={`py-16 sm:py-24 ${className}`}>
  <div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8">
    <h2 class="text-3xl font-display font-bold tracking-tight text-text-primary text-center sm:text-4xl mb-16">
      {heading}
    </h2>

    <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-12">
      {items.map((item) => (
        <div class="text-center">
          <div class="mx-auto flex h-16 w-16 items-center justify-center rounded-full bg-surface-inset text-text-secondary mb-6">
            <Icon name={item.icon} size={28} />
          </div>
          <h3 class="text-lg font-bold text-text-primary">{item.title}</h3>
          <p class="mt-3 text-sm leading-6 text-text-secondary max-w-xs mx-auto">{item.description}</p>
        </div>
      ))}
    </div>
  </div>
</section>
