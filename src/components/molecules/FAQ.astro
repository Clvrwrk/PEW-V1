---
import SchemaJsonLd from '../seo/SchemaJsonLd.astro';

export interface FaqItem {
  question: string;
  answer: string;
}

export interface Props {
  faqs?: FaqItem[];
  items?: FaqItem[];
  class?: string;
  schemaType?: string;
}

const {
  faqs,
  items,
  class: className = '',
} = Astro.props;

const faqItems = faqs ?? items ?? [];

// Generate FAQPage Schema
const faqSchema = {
  "@context": "https://schema.org",
  "@type": "FAQPage",
  "mainEntity": faqItems.map(faq => ({
    "@type": "Question",
    "name": faq.question,
    "acceptedAnswer": {
      "@type": "Answer",
      // Strip HTML tags for schema text — Google rejects markup in Answer.text
      "text": faq.answer.replace(/<[^>]+>/g, '').replace(/\s+/g, ' ').trim()
    }
  }))
};
---

{faqItems.length > 0 && <SchemaJsonLd jsonLd={faqSchema} />}

<div class={`space-y-4 ${className}`}>
  {faqItems.map((faq, index) => (
    <details class="group rounded-lg border border-border bg-surface-elevated shadow-sm open:ring-1 open:ring-accent/20">
      <summary class="flex cursor-pointer items-center justify-between px-6 py-4 text-left font-medium text-text-primary focus:outline-none focus:ring-2 focus:ring-inset focus:ring-accent list-none">
        <span>{faq.question}</span>
        <span class="ml-4 flex-shrink-0 text-text-primary">
          <svg class="h-5 w-5 transition-transform duration-200 group-open:rotate-180" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor">
            <path stroke-linecap="round" stroke-linejoin="round" d="M19.5 8.25l-7.5 7.5-7.5-7.5" />
          </svg>
        </span>
      </summary>
      <div class="px-6 pb-4 text-text-secondary prose prose-sm max-w-none">
        <p set:html={faq.answer} />
      </div>
    </details>
  ))}
</div>
