---
import SchemaJsonLd from '../seo/SchemaJsonLd.astro';

export interface FaqItem {
  question: string;
  answer: string;
}

export interface Props {
  faqs: FaqItem[];
  class?: string;
}

const { faqs, class: className = '' } = Astro.props;

// Generate FAQPage Schema
const faqSchema = {
  "@context": "https://schema.org",
  "@type": "FAQPage",
  "mainEntity": faqs.map(faq => ({
    "@type": "Question",
    "name": faq.question,
    "acceptedAnswer": {
      "@type": "Answer",
      "text": faq.answer
    }
  }))
};
---

{faqs.length > 0 && <SchemaJsonLd jsonLd={faqSchema} />}

<div class={`space-y-4 ${className}`}>
  {faqs.map((faq, index) => (
    <details class="group rounded-lg border border-gray-200 bg-white shadow-sm open:ring-1 open:ring-brand-primary/20">
      <summary class="flex cursor-pointer items-center justify-between px-6 py-4 text-left font-medium text-gray-900 focus:outline-none focus:ring-2 focus:ring-inset focus:ring-brand-primary list-none">
        <span>{faq.question}</span>
        <span class="ml-4 flex-shrink-0 text-brand-primary">
          <svg class="h-5 w-5 transition-transform duration-200 group-open:rotate-180" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor">
            <path stroke-linecap="round" stroke-linejoin="round" d="M19.5 8.25l-7.5 7.5-7.5-7.5" />
          </svg>
        </span>
      </summary>
      <div class="px-6 pb-4 text-gray-600 prose prose-sm max-w-none">
        <p>{faq.answer}</p>
      </div>
    </details>
  ))}
</div>
