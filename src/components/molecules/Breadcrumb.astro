---
import SchemaJsonLd from '../seo/SchemaJsonLd.astro';
import Icon from '../atoms/Icon.astro';

export interface BreadcrumbItem {
  label: string;
  href: string;
}

export interface Props {
  items: BreadcrumbItem[];
  class?: string;
}

const { items = [], class: className = '' } = Astro.props;

// Generate BreadcrumbList Schema
const breadcrumbSchema = {
  "@context": "https://schema.org",
  "@type": "BreadcrumbList",
  "itemListElement": items.map((item, index) => ({
    "@type": "ListItem",
    "position": index + 1,
    "name": item.label,
    "item": new URL(item.href, import.meta.env.SITE_URL || 'https://pc-demo.cleverwork.io').toString()
  }))
};
---

<SchemaJsonLd jsonLd={breadcrumbSchema} />

<nav class={`flex ${className}`} aria-label="Breadcrumb">
  <ol role="list" class="flex items-center space-x-2">
    <li>
      <div>
        <a href="/" class="text-text-tertiary hover:text-text-secondary">
          <Icon name="home" size={20} class="flex-shrink-0" />
          <span class="sr-only">Home</span>
        </a>
      </div>
    </li>
    {items.map((item, index) => (
      <li>
        <div class="flex items-center">
          <Icon name="chevron-right" size={20} class="flex-shrink-0 text-text-tertiary" />
          <a
            href={item.href}
            class="ml-2 text-sm font-medium text-text-tertiary hover:text-text-secondary"
            aria-current={index === items.length - 1 ? 'page' : undefined}
          >
            {item.label}
          </a>
        </div>
      </li>
    ))}
  </ol>
</nav>
