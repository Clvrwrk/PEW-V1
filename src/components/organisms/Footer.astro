---
import SiteLogo from '../atoms/SiteLogo.astro';
---

<footer class="bg-surface-inset pt-16 pb-8" aria-labelledby="footer-heading">
  <h2 id="footer-heading" class="sr-only">Footer</h2>
  <div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8">
    <div class="xl:grid xl:grid-cols-3 xl:gap-8">
      
      <!-- Brand & Mission Info -->
      <div class="space-y-8 xl:col-span-1">
        <a href="/" class="inline-flex items-center" aria-label="Pro Exteriors home">
          <SiteLogo class="h-11 w-auto" />
        </a>
        <p class="text-base text-text-secondary max-w-xs">
          Your trusted partner for commercial and residential exterior solutions. Local experts. Not "storm chasers."
        </p>
        <div class="flex space-x-6">
          <!-- Social Placeholders -->
          <a href="#" class="text-text-tertiary hover:text-accent">
            <span class="sr-only">Facebook</span>
            <div class="h-6 w-6 bg-border rounded-full" aria-hidden="true" data-todo="social-facebook"></div>
          </a>
          <a href="#" class="text-text-tertiary hover:text-accent">
            <span class="sr-only">LinkedIn</span>
            <div class="h-6 w-6 bg-border rounded-full" aria-hidden="true" data-todo="social-linkedin"></div>
          </a>
        </div>
      </div>

      <div class="mt-16 grid grid-cols-2 gap-8 xl:col-span-2 xl:mt-0">
        <div class="md:grid md:grid-cols-2 md:gap-8">
          <!-- Company Column -->
          <div>
            <h3 class="text-sm font-semibold leading-6 text-text-primary uppercase tracking-wider">Company</h3>
            <ul role="list" class="mt-6 space-y-4">
              <li><a href="/about/" class="text-sm leading-6 text-text-secondary hover:text-accent">About</a></li>
              <li><a href="/about/mission/" class="text-sm leading-6 text-text-secondary hover:text-accent">Mission & Values</a></li>
              <li><a href="/about/leadership/" class="text-sm leading-6 text-text-secondary hover:text-accent">Leadership</a></li>
              <li><a href="/careers/" class="text-sm leading-6 text-text-secondary hover:text-accent">Careers</a></li>
              <li><a href="/blog/" class="text-sm leading-6 text-text-secondary hover:text-accent">Press & Blog</a></li>
            </ul>
          </div>
          
          <!-- Services Column -->
          <div class="mt-10 md:mt-0">
            <h3 class="text-sm font-semibold leading-6 text-text-primary uppercase tracking-wider">Services</h3>
            <ul role="list" class="mt-6 space-y-4">
              <li><a href="/commercial-roofing/" class="text-sm leading-6 text-text-secondary hover:text-accent">Commercial Roofing</a></li>
              <li><a href="/residential-roofing/" class="text-sm leading-6 text-text-secondary hover:text-accent">Residential Roofing</a></li>
              <li><a href="/proplan/" class="text-sm leading-6 text-text-secondary hover:text-accent">ProPlan Maintenance</a></li>
            </ul>
          </div>
        </div>
        
        <div class="md:grid md:grid-cols-2 md:gap-8">
          <!-- Locations Column -->
          <div>
            <h3 class="text-sm font-semibold leading-6 text-text-primary uppercase tracking-wider">Locations</h3>
            <ul role="list" class="mt-6 space-y-4">
              {/* Updated 2026-05-03 per Chris's Option B decision in /decisions/2026-05-03-office-footprint-reconciliation.md.
                  These five metro pages do not yet exist (planned per /strategy/Pro-Exteriors_GBP-and-Silo-Memo Q1 build).
                  Six prior DFW-specific links (Dallas HQ / Fort Worth / Frisco / Southlake / Arlington / Edmond OK) removed
                  because they misrepresented the multi-state footprint. Trade-off accepted: these links 404 until the
                  /locations/* pages ship in M2/M3. Search Console will surface the 404s — we accept that signal. */}
              <li><a href="/locations/" class="text-sm leading-6 text-text-secondary hover:text-accent">All Locations</a></li>
              <li><a href="/locations/dallas-hq/" class="text-sm leading-6 text-text-secondary hover:text-accent">Dallas HQ</a></li>
              <li><a href="/locations/fort-worth/" class="text-sm leading-6 text-text-secondary hover:text-accent">Fort Worth, TX</a></li>
              <li><a href="/locations/denver/" class="text-sm leading-6 text-text-secondary hover:text-accent">Denver, CO</a></li>
              <li><a href="/locations/wichita/" class="text-sm leading-6 text-text-secondary hover:text-accent">Wichita, KS</a></li>
              <li><a href="/locations/kansas-city/" class="text-sm leading-6 text-text-secondary hover:text-accent">Kansas City, MO</a></li>
              <li><a href="/locations/atlanta/" class="text-sm leading-6 text-text-secondary hover:text-accent">Atlanta, GA</a></li>
            </ul>
          </div>
          
          <!-- Legal Column -->
          <div class="mt-10 md:mt-0">
            <h3 class="text-sm font-semibold leading-6 text-text-primary uppercase tracking-wider">Legal & Utility</h3>
            <ul role="list" class="mt-6 space-y-4">
              <li><a href="/privacy/" class="text-sm leading-6 text-text-secondary hover:text-accent">Privacy Policy</a></li>
              <li><a href="/terms/" class="text-sm leading-6 text-text-secondary hover:text-accent">Terms of Service</a></li>
              <li><a href="/accessibility/" class="text-sm leading-6 text-text-secondary hover:text-accent">Accessibility</a></li>
              <li><a href="/cookies/" class="text-sm leading-6 text-text-secondary hover:text-accent">Cookies Policy</a></li>
              <li><a href="/sitemap.xml" class="text-sm leading-6 text-text-secondary hover:text-accent">Sitemap</a></li>
            </ul>
          </div>
        </div>
      </div>
    </div>
    
    <!-- Bottom Strip -->
    <div class="mt-16 border-t border-border pt-8 sm:mt-20 md:flex md:items-center md:justify-between">
      <div class="flex space-x-6 md:order-2">
        <!-- Certification Badges Placeholders -->
        <div class="flex space-x-4 items-center">
          <span class="text-xs text-text-tertiary font-semibold uppercase">Certifications:</span>
          <div class="h-8 w-20 bg-border flex items-center justify-center text-xs text-text-tertiary" data-todo="cert-gaf">GAF</div>
          <div class="h-8 w-20 bg-border flex items-center justify-center text-xs text-text-tertiary" data-todo="cert-carlisle">Carlisle</div>
          <div class="h-8 w-20 bg-border flex items-center justify-center text-xs text-text-tertiary" data-todo="cert-versico">Versico</div>
        </div>
      </div>
      <p class="mt-8 text-xs leading-5 text-text-tertiary md:order-1 md:mt-0">
        &copy; {new Date().getFullYear()} Pro Exteriors. All rights reserved.
      </p>
    </div>
  </div>
</footer>
