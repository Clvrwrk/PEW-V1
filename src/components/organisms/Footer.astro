---
---

<footer class="bg-brand-bg-alt pt-16 pb-8" aria-labelledby="footer-heading">
  <h2 id="footer-heading" class="sr-only">Footer</h2>
  <div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8">
    <div class="xl:grid xl:grid-cols-3 xl:gap-8">
      
      <!-- Brand & Mission Info -->
      <div class="space-y-8 xl:col-span-1">
        <a href="/" class="text-2xl font-display font-bold text-brand-primary">
          Pro Exteriors
        </a>
        <p class="text-base text-gray-600 max-w-xs">
          Your trusted partner for commercial and residential exterior solutions. Local experts. Not "storm chasers."
        </p>
        <div class="flex space-x-6">
          <!-- Social Placeholders -->
          <a href="#" class="text-gray-400 hover:text-brand-accent">
            <span class="sr-only">Facebook</span>
            <div class="h-6 w-6 bg-gray-300 rounded-full" aria-hidden="true" data-todo="social-facebook"></div>
          </a>
          <a href="#" class="text-gray-400 hover:text-brand-accent">
            <span class="sr-only">LinkedIn</span>
            <div class="h-6 w-6 bg-gray-300 rounded-full" aria-hidden="true" data-todo="social-linkedin"></div>
          </a>
        </div>
      </div>

      <div class="mt-16 grid grid-cols-2 gap-8 xl:col-span-2 xl:mt-0">
        <div class="md:grid md:grid-cols-2 md:gap-8">
          <!-- Company Column -->
          <div>
            <h3 class="text-sm font-semibold leading-6 text-brand-primary uppercase tracking-wider">Company</h3>
            <ul role="list" class="mt-6 space-y-4">
              <li><a href="/about/" class="text-sm leading-6 text-gray-600 hover:text-brand-accent">About</a></li>
              <li><a href="/about/mission/" class="text-sm leading-6 text-gray-600 hover:text-brand-accent">Mission & Values</a></li>
              <li><a href="/about/leadership/" class="text-sm leading-6 text-gray-600 hover:text-brand-accent">Leadership</a></li>
              <li><a href="/careers/" class="text-sm leading-6 text-gray-600 hover:text-brand-accent">Careers</a></li>
              <li><a href="/blog/" class="text-sm leading-6 text-gray-600 hover:text-brand-accent">Press & Blog</a></li>
            </ul>
          </div>
          
          <!-- Services Column -->
          <div class="mt-10 md:mt-0">
            <h3 class="text-sm font-semibold leading-6 text-brand-primary uppercase tracking-wider">Services</h3>
            <ul role="list" class="mt-6 space-y-4">
              <li><a href="/commercial-roofing/" class="text-sm leading-6 text-gray-600 hover:text-brand-accent">Commercial Roofing</a></li>
              <li><a href="/residential-roofing/" class="text-sm leading-6 text-gray-600 hover:text-brand-accent">Residential Roofing</a></li>
              <li><a href="/proplan/" class="text-sm leading-6 text-gray-600 hover:text-brand-accent">ProPlan Maintenance</a></li>
            </ul>
          </div>
        </div>
        
        <div class="md:grid md:grid-cols-2 md:gap-8">
          <!-- Locations Column -->
          <div>
            <h3 class="text-sm font-semibold leading-6 text-brand-primary uppercase tracking-wider">Locations</h3>
            <ul role="list" class="mt-6 space-y-4">
              <li><a href="/locations/" class="text-sm leading-6 text-gray-600 hover:text-brand-accent">All Locations</a></li>
              <li><a href="/locations/dallas-hq/" class="text-sm leading-6 text-gray-600 hover:text-brand-accent">Dallas HQ</a></li>
              <li><a href="/locations/fort-worth/" class="text-sm leading-6 text-gray-600 hover:text-brand-accent">Fort Worth</a></li>
              <li><a href="/locations/frisco/" class="text-sm leading-6 text-gray-600 hover:text-brand-accent">Frisco</a></li>
              <li><a href="/locations/southlake/" class="text-sm leading-6 text-gray-600 hover:text-brand-accent">Southlake</a></li>
              <li><a href="/locations/arlington/" class="text-sm leading-6 text-gray-600 hover:text-brand-accent">Arlington</a></li>
              <li><a href="/locations/edmond/" class="text-sm leading-6 text-gray-600 hover:text-brand-accent">Edmond, OK</a></li>
            </ul>
          </div>
          
          <!-- Legal Column -->
          <div class="mt-10 md:mt-0">
            <h3 class="text-sm font-semibold leading-6 text-brand-primary uppercase tracking-wider">Legal & Utility</h3>
            <ul role="list" class="mt-6 space-y-4">
              <li><a href="/privacy-policy/" class="text-sm leading-6 text-gray-600 hover:text-brand-accent">Privacy Policy</a></li>
              <li><a href="/terms/" class="text-sm leading-6 text-gray-600 hover:text-brand-accent">Terms of Service</a></li>
              <li><a href="/accessibility/" class="text-sm leading-6 text-gray-600 hover:text-brand-accent">Accessibility</a></li>
              <li><a href="/cookies/" class="text-sm leading-6 text-gray-600 hover:text-brand-accent">Cookies Policy</a></li>
              <li><a href="/sitemap.xml" class="text-sm leading-6 text-gray-600 hover:text-brand-accent">Sitemap</a></li>
            </ul>
          </div>
        </div>
      </div>
    </div>
    
    <!-- Bottom Strip -->
    <div class="mt-16 border-t border-gray-200 pt-8 sm:mt-20 md:flex md:items-center md:justify-between">
      <div class="flex space-x-6 md:order-2">
        <!-- Certification Badges Placeholders -->
        <div class="flex space-x-4 items-center">
          <span class="text-xs text-gray-500 font-semibold uppercase">Certifications:</span>
          <div class="h-8 w-20 bg-gray-200 flex items-center justify-center text-xs text-gray-500" data-todo="cert-gaf">GAF</div>
          <div class="h-8 w-20 bg-gray-200 flex items-center justify-center text-xs text-gray-500" data-todo="cert-carlisle">Carlisle</div>
          <div class="h-8 w-20 bg-gray-200 flex items-center justify-center text-xs text-gray-500" data-todo="cert-versico">Versico</div>
        </div>
      </div>
      <p class="mt-8 text-xs leading-5 text-gray-500 md:order-1 md:mt-0">
        &copy; {new Date().getFullYear()} Pro Exteriors. All rights reserved.
      </p>
    </div>
  </div>
</footer>
