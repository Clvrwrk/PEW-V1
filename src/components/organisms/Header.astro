---
---

<header class="bg-white border-b border-gray-200 sticky top-0 z-50">
  <div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8">
    <div class="flex h-16 justify-between items-center">
      
      <!-- Logo placeholder -->
      <div class="flex-shrink-0 flex items-center">
        <a href="/" class="text-2xl font-display font-bold text-brand-primary">
          Pro Exteriors
        </a>
      </div>

      <!-- Desktop Navigation -->
      <nav class="hidden md:flex space-x-8">
        <!-- Services Mega Menu Dropdown Placeholder -->
        <details class="relative group">
          <summary class="inline-flex items-center text-sm font-medium text-gray-700 hover:text-brand-primary cursor-pointer list-none">
            Services
            <svg class="ml-1 h-4 w-4" fill="currentColor" viewBox="0 0 20 20">
              <path fill-rule="evenodd" d="M5.293 7.293a1 1 0 011.414 0L10 10.586l3.293-3.293a1 1 0 111.414 1.414l-4 4a1 1 0 01-1.414 0l-4-4a1 1 0 010-1.414z" clip-rule="evenodd" />
            </svg>
          </summary>
          <!-- Mega Menu content -->
          <div class="absolute z-10 -ml-4 mt-3 w-screen max-w-md transform px-2 sm:px-0 lg:left-1/2 lg:ml-0 lg:-translate-x-1/2 hidden group-open:block">
            <div class="overflow-hidden rounded-lg shadow-lg ring-1 ring-black ring-opacity-5">
              <div class="relative grid gap-6 bg-white px-5 py-6 sm:gap-8 sm:p-8 lg:grid-cols-2">
                <div>
                  <h3 class="text-sm font-semibold text-brand-primary uppercase tracking-wider">Commercial</h3>
                  <ul class="mt-4 space-y-4">
                    <li><a href="/commercial-roofing/" class="text-base text-gray-900 hover:text-brand-accent">Overview</a></li>
                    <li><a href="/commercial-roofing/tpo/" class="text-base text-gray-900 hover:text-brand-accent">TPO</a></li>
                  </ul>
                </div>
                <div>
                  <h3 class="text-sm font-semibold text-brand-primary uppercase tracking-wider">Residential</h3>
                  <ul class="mt-4 space-y-4">
                    <li><a href="/residential-roofing/" class="text-base text-gray-900 hover:text-brand-accent">Overview</a></li>
                    <li><a href="/residential-roofing/replacement/" class="text-base text-gray-900 hover:text-brand-accent">Replacement</a></li>
                  </ul>
                </div>
              </div>
            </div>
          </div>
        </details>

        <a href="/locations/" class="inline-flex items-center text-sm font-medium text-gray-700 hover:text-brand-primary">Locations</a>
        <a href="/projects/" class="inline-flex items-center text-sm font-medium text-gray-700 hover:text-brand-primary">Projects</a>
        <a href="/about/" class="inline-flex items-center text-sm font-medium text-gray-700 hover:text-brand-primary">About</a>
        <a href="/blog/" class="inline-flex items-center text-sm font-medium text-gray-700 hover:text-brand-primary">Resources</a>
        <a href="/contact/" class="inline-flex items-center text-sm font-medium text-gray-700 hover:text-brand-primary">Contact</a>
      </nav>

      <!-- Utility Nav (Desktop) -->
      <div class="hidden md:flex items-center space-x-4">
        <a href="/portal/" class="text-sm font-medium text-gray-500 hover:text-brand-primary">Portal Login</a>
        <a href="tel:+18005551234" class="text-sm font-bold text-brand-primary hover:text-brand-accent" data-cta-name="header_phone">(800) 555-1234</a>
        <a href="/contact/" class="inline-flex items-center justify-center rounded-md border border-transparent bg-brand-accent px-4 py-2 text-sm font-medium text-white shadow-sm hover:bg-orange-600" data-cta-name="header_quote">
          Get a Quote
        </a>
      </div>

      <!-- Mobile menu button -->
      <div class="flex items-center md:hidden">
        <details class="group">
          <summary class="inline-flex items-center justify-center rounded-md p-2 text-gray-400 hover:bg-gray-100 hover:text-gray-500 focus:outline-none focus:ring-2 focus:ring-inset focus:ring-brand-primary cursor-pointer list-none">
            <span class="sr-only">Open main menu</span>
            <svg class="block h-6 w-6 group-open:hidden" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor">
              <path stroke-linecap="round" stroke-linejoin="round" d="M3.75 6.75h16.5M3.75 12h16.5m-16.5 5.25h16.5" />
            </svg>
            <svg class="hidden h-6 w-6 group-open:block" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor">
              <path stroke-linecap="round" stroke-linejoin="round" d="M6 18L18 6M6 6l12 12" />
            </svg>
          </summary>
          <!-- Mobile Menu Drawer -->
          <div class="absolute left-0 top-16 w-full bg-white shadow-lg z-50">
            <div class="space-y-1 pb-3 pt-2 px-4">
              <a href="/commercial-roofing/" class="block py-2 text-base font-medium text-gray-700 hover:bg-gray-50 hover:text-brand-primary">Commercial Services</a>
              <a href="/residential-roofing/" class="block py-2 text-base font-medium text-gray-700 hover:bg-gray-50 hover:text-brand-primary">Residential Services</a>
              <a href="/proplan/" class="block py-2 text-base font-medium text-gray-700 hover:bg-gray-50 hover:text-brand-primary">ProPlan</a>
              <a href="/locations/" class="block py-2 text-base font-medium text-gray-700 hover:bg-gray-50 hover:text-brand-primary">Locations</a>
              <a href="/projects/" class="block py-2 text-base font-medium text-gray-700 hover:bg-gray-50 hover:text-brand-primary">Projects</a>
              <a href="/about/" class="block py-2 text-base font-medium text-gray-700 hover:bg-gray-50 hover:text-brand-primary">About</a>
              <a href="/blog/" class="block py-2 text-base font-medium text-gray-700 hover:bg-gray-50 hover:text-brand-primary">Resources</a>
              <a href="/contact/" class="block py-2 text-base font-medium text-gray-700 hover:bg-gray-50 hover:text-brand-primary">Contact</a>
            </div>
            <div class="border-t border-gray-200 pb-4 pt-4 px-4 space-y-2">
              <a href="/portal/" class="block text-base font-medium text-gray-500 hover:text-brand-primary">Portal Login</a>
              <a href="tel:+18005551234" class="block text-base font-bold text-brand-primary hover:text-brand-accent">(800) 555-1234</a>
              <a href="/contact/" class="mt-2 block w-full rounded-md bg-brand-accent px-4 py-2 text-center text-base font-medium text-white shadow hover:bg-orange-600">Get a Quote</a>
            </div>
          </div>
        </details>
      </div>

    </div>
  </div>
</header>
