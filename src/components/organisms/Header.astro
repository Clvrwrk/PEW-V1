---
import SiteLogo from '../atoms/SiteLogo.astro';

/**
 * Services nav model — single source of truth for the dropdown + mobile drawer.
 * Order is intent-based (top of column = highest buyer intent), not alphabetical.
 * If a service is added to /src/content/services/, add it here too. Labels are
 * deliberately short — the column header already says "Commercial" / "Residential",
 * so we don't repeat that word in every child.
 */
const commercialOverview = '/commercial-roofing/';
const residentialOverview = '/residential/';

const commercialServices = [
  { label: 'TPO Roofing Systems', href: '/commercial-roofing/tpo-roofing-systems/' },
  { label: 'EPDM',                href: '/commercial-roofing/epdm/' },
  { label: 'Metal',               href: '/commercial-roofing/metal/' },
  { label: 'Flat Roof Systems',   href: '/commercial-roofing/flat-roof-systems/' },
  { label: 'Replacement',         href: '/commercial-roofing/replacement/' },
  { label: 'Repair',              href: '/commercial-roofing/repair/' },
];

/**
 * Residential nav — updated 2026-05-03 to point at the new /residential/ silo.
 * Ordered by buyer intent: emergency/transactional first, material pages second.
 * Natural Slate, Tile & Clay, Gutters, and Siding are accessible via the hub
 * (/residential/) rather than the dropdown — nav stays scannable at 8 items.
 * "Inspection" and "Emergency" placeholders from the old /residential-roofing/
 * structure have been removed; those intents are covered by the entries below.
 */
const residentialServices = [
  { label: 'Roof Replacement',      href: '/residential/roof-replacement' },
  { label: 'Storm Damage Repair',   href: '/residential/storm-damage-repair' },
  { label: 'Hail Damage Repair',    href: '/residential/hail-damage-repair' },
  { label: 'Insurance Claim Help',  href: '/residential/insurance-claim-assistance' },
  { label: 'Emergency Tarping',     href: '/residential/tarp-installation' },
  { label: 'Asphalt Shingles',      href: '/residential/asphalt-shingles' },
  { label: 'Metal Roofing',         href: '/residential/metal-roofing' },
  { label: 'Tile & Clay',           href: '/residential/tile-clay-roofing' },
];
---

<header class="bg-surface border-b border-border sticky top-0 z-50">
  <div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8">
    <div class="flex h-16 justify-between items-center">
      
      <div class="flex-shrink-0 flex items-center">
        <a href="/" class="inline-flex items-center" aria-label="Pro Exteriors home">
          <SiteLogo class="h-9 w-auto sm:h-10" />
        </a>
      </div>

      <!-- Desktop Navigation -->
      <nav class="hidden md:flex space-x-8">
        <!-- Services Mega Menu Dropdown Placeholder -->
        <details class="relative group">
          <summary class="inline-flex items-center text-sm font-medium text-text-secondary hover:text-accent cursor-pointer list-none">
            Services
            <svg class="ml-1 h-4 w-4" fill="currentColor" viewBox="0 0 20 20">
              <path fill-rule="evenodd" d="M5.293 7.293a1 1 0 011.414 0L10 10.586l3.293-3.293a1 1 0 111.414 1.414l-4 4a1 1 0 01-1.414 0l-4-4a1 1 0 010-1.414z" clip-rule="evenodd" />
            </svg>
          </summary>
          <!-- Mega Menu content -->
          <div class="absolute z-10 -ml-4 mt-3 w-screen max-w-md transform px-2 sm:px-0 lg:left-1/2 lg:ml-0 lg:-translate-x-1/2 hidden group-open:block">
            <div class="overflow-hidden rounded-lg shadow-lg ring-1 ring-black ring-opacity-5">
              <div class="relative grid gap-6 bg-surface-elevated px-5 py-6 sm:gap-8 sm:p-8 lg:grid-cols-2">
                <div>
                  <a
                    href={commercialOverview}
                    class="block text-sm font-semibold text-text-primary uppercase tracking-wider hover:text-accent"
                    data-cta-name="nav_commercial_overview"
                  >
                    Commercial
                  </a>
                  <ul class="mt-4 space-y-4">
                    {commercialServices.map((s) => (
                      <li>
                        <a href={s.href} class="text-base text-text-primary hover:text-accent">{s.label}</a>
                      </li>
                    ))}
                  </ul>
                </div>
                <div>
                  <a
                    href={residentialOverview}
                    class="block text-sm font-semibold text-text-primary uppercase tracking-wider hover:text-accent"
                    data-cta-name="nav_residential_overview"
                  >
                    Residential
                  </a>
                  <ul class="mt-4 space-y-4">
                    {residentialServices.map((s) => (
                      <li>
                        <a href={s.href} class="text-base text-text-primary hover:text-accent">{s.label}</a>
                      </li>
                    ))}
                  </ul>
                </div>
              </div>
            </div>
          </div>
        </details>

        <a href="/locations/" class="inline-flex items-center text-sm font-medium text-text-secondary hover:text-accent">Locations</a>
        <a href="/projects/" class="inline-flex items-center text-sm font-medium text-text-secondary hover:text-accent">Projects</a>
        <a href="/about/" class="inline-flex items-center text-sm font-medium text-text-secondary hover:text-accent">About</a>
        <a href="/blog/" class="inline-flex items-center text-sm font-medium text-text-secondary hover:text-accent">Resources</a>
        <a href="/contact/" class="inline-flex items-center text-sm font-medium text-text-secondary hover:text-accent">Contact</a>
      </nav>

      <!-- Utility Nav (Desktop) -->
      <div class="hidden md:flex items-center space-x-4">
        <a href="/portal/" class="text-sm font-medium text-text-tertiary hover:text-accent">Portal Login</a>
        <a href="tel:+18005551234" class="text-sm font-bold text-text-primary hover:text-accent" data-cta-name="header_phone">(800) 555-1234</a>
        <a href="/contact/" class="inline-flex items-center justify-center rounded-md border border-transparent bg-brand-accent px-4 py-2 text-sm font-medium text-text-on-brand shadow-sm hover:bg-brand-accent-hover" data-cta-name="header_quote">
          Get a Quote
        </a>
      </div>

      <!-- Mobile menu button -->
      <div class="flex items-center md:hidden">
        <details class="group">
          <summary class="inline-flex items-center justify-center rounded-md p-2 text-text-tertiary hover:bg-surface-inset hover:text-text-secondary focus:outline-none focus:ring-2 focus:ring-inset focus:ring-accent cursor-pointer list-none">
            <span class="sr-only">Open main menu</span>
            <svg class="block h-6 w-6 group-open:hidden" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor">
              <path stroke-linecap="round" stroke-linejoin="round" d="M3.75 6.75h16.5M3.75 12h16.5m-16.5 5.25h16.5" />
            </svg>
            <svg class="hidden h-6 w-6 group-open:block" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor">
              <path stroke-linecap="round" stroke-linejoin="round" d="M6 18L18 6M6 6l12 12" />
            </svg>
          </summary>
          <!-- Mobile Menu Drawer -->
          <div class="absolute left-0 top-16 w-full bg-surface shadow-lg z-50">
            <div class="space-y-1 pb-3 pt-2 px-4">
              <details class="group/sub">
                <summary class="flex items-center justify-between py-2 text-base font-medium text-text-secondary hover:bg-surface-inset hover:text-accent cursor-pointer list-none">
                  Commercial
                  <svg class="h-4 w-4 transition-transform group-open/sub:rotate-180" fill="currentColor" viewBox="0 0 20 20" aria-hidden="true">
                    <path fill-rule="evenodd" d="M5.293 7.293a1 1 0 011.414 0L10 10.586l3.293-3.293a1 1 0 111.414 1.414l-4 4a1 1 0 01-1.414 0l-4-4a1 1 0 010-1.414z" clip-rule="evenodd" />
                  </svg>
                </summary>
                <div class="pl-3 mt-1 space-y-1">
                  <a href={commercialOverview} class="block py-2 text-sm font-semibold uppercase tracking-wider text-text-primary hover:text-accent">Commercial Overview</a>
                  {commercialServices.map((s) => (
                    <a href={s.href} class="block py-2 text-sm text-text-secondary hover:text-accent">{s.label}</a>
                  ))}
                </div>
              </details>
              <details class="group/sub">
                <summary class="flex items-center justify-between py-2 text-base font-medium text-text-secondary hover:bg-surface-inset hover:text-accent cursor-pointer list-none">
                  Residential
                  <svg class="h-4 w-4 transition-transform group-open/sub:rotate-180" fill="currentColor" viewBox="0 0 20 20" aria-hidden="true">
                    <path fill-rule="evenodd" d="M5.293 7.293a1 1 0 011.414 0L10 10.586l3.293-3.293a1 1 0 111.414 1.414l-4 4a1 1 0 01-1.414 0l-4-4a1 1 0 010-1.414z" clip-rule="evenodd" />
                  </svg>
                </summary>
                <div class="pl-3 mt-1 space-y-1">
                  <a href={residentialOverview} class="block py-2 text-sm font-semibold uppercase tracking-wider text-text-primary hover:text-accent">Residential Overview</a>
                  {residentialServices.map((s) => (
                    <a href={s.href} class="block py-2 text-sm text-text-secondary hover:text-accent">{s.label}</a>
                  ))}
                </div>
              </details>
              <a href="/proplan/" class="block py-2 text-base font-medium text-text-secondary hover:bg-surface-inset hover:text-accent">ProPlan</a>
              <a href="/locations/" class="block py-2 text-base font-medium text-text-secondary hover:bg-surface-inset hover:text-accent">Locations</a>
              <a href="/projects/" class="block py-2 text-base font-medium text-text-secondary hover:bg-surface-inset hover:text-accent">Projects</a>
              <a href="/about/" class="block py-2 text-base font-medium text-text-secondary hover:bg-surface-inset hover:text-accent">About</a>
              <a href="/blog/" class="block py-2 text-base font-medium text-text-secondary hover:bg-surface-inset hover:text-accent">Resources</a>
              <a href="/contact/" class="block py-2 text-base font-medium text-text-secondary hover:bg-surface-inset hover:text-accent">Contact</a>
            </div>
            <div class="border-t border-border pb-4 pt-4 px-4 space-y-2">
              <a href="/portal/" class="block text-base font-medium text-text-tertiary hover:text-accent">Portal Login</a>
              <a href="tel:+18005551234" class="block text-base font-bold text-text-primary hover:text-accent">(800) 555-1234</a>
              <a href="/contact/" class="mt-2 block w-full rounded-md bg-brand-accent px-4 py-2 text-center text-base font-medium text-text-on-brand shadow hover:bg-brand-accent-hover">Get a Quote</a>
            </div>
          </div>
        </details>
      </div>

    </div>
  </div>
</header>
