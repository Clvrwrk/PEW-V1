# Required — Sanity (comment out if using MDX fallback)
# SANITY_PROJECT_ID=
# SANITY_DATASET=production
# SANITY_API_TOKEN=

# Google Analytics 4
PUBLIC_GA4_MEASUREMENT_ID=

# PostHog analytics
PUBLIC_POSTHOG_KEY=

# Lead routing
LEAD_WEBHOOK_URL=
SLACK_EMERGENCY_WEBHOOK=

# Booking calendar embed (Calendly or GoHighLevel)
BOOKING_CALENDAR_EMBED_URL=

# Customer portal SSO URL
PORTAL_SSO_URL=

# Site URL (staging vs production)
SITE_URL=https://pc-demo.Cleverwork.io

# ─────────────────────────────────────────────────────────────────────────
# AIA4 sprint integrations — copy + image generation pipeline
# ─────────────────────────────────────────────────────────────────────────

# OpenRouter — copy generation gateway
# Docs: https://openrouter.ai/docs/quickstart
OPENROUTER_API_KEY=

# DataForSEO — keyword + SERP data (HTTP Basic auth, base64 of login:password)
# Docs: https://docs.dataforseo.com/v3/
DATAFORSEO_LOGIN=
DATAFORSEO_AUTH_B64=

# Google AI Studio — Gemini text + image (nano banana / gemini-2.5-flash-image)
# Docs: https://ai.google.dev/gemini-api/docs/ai-studio-quickstart
GOOGLE_AI_API_KEY=
GOOGLE_AI_PROJECT_ID=

# Hue Write — humanizer API (Pro/Max plan required for ultraMode)
# Docs: https://huewrite.com/api  ·  POST /api/v1/humanize
HUEWRITE_API_KEY=

# Fal.ai — image generation (Flux, Recraft, Imagen, Ideogram)
# For Nano Banana Pro / GPT Image 2, use the Higgsfield MCP instead.
# Docs: https://fal.ai/docs
FAL_KEY=
